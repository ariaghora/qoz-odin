// expect: 42

import std/result

let parse_num(s: string): Result<i64, string> = {
    if s == "ok" { Ok(42) } else { Err("nope") }
}

let chain(s: string): Result<i64, string> = {
    let n = parse_num(s)?
    Ok(n)
}

let main(): i64 = {
    match chain("ok") {
    | Ok(v)  -> v
    | Err(_) -> 0
    }
}
