// expect: 0
// Expr recurses through *Expr, so it is a value enum whose default
// structural eq/hash would compare the child pointers by identity. An
// @operator("==") and @operator("hash") overload takes precedence and
// makes Expr compare and hash by evaluated value, so two structurally
// different trees with the same value are equal and usable as a map key.

import fmt
import map

type Expr =
    | Num(i64)
    | Add(*Expr, *Expr)

let eval(e: Expr): i64 =
    match e {
    | Num(n)    -> n
    | Add(l, r) -> eval(*l) + eval(*r)
    }

@operator("==")
let expr_eq(a: *Expr, b: *Expr): bool = eval(*a) == eval(*b)

@operator("hash")
let expr_hash(p: *Expr): u64 = eval(*p) as u64

let main(): i64 = {
    let a = Add(new_clone(Num(1)), new_clone(Num(2)))
    let b = Add(new_clone(Num(2)), new_clone(Num(1)))
    let c = Num(5)
    var bad: i64 = 0
    if !(a == b) { bad += 1 }
    if a == c   { bad += 1 }
    if a != b   { bad += 1 }
    if !(a != c) { bad += 1 }

    var m: Map<Expr, i64> = map.make()
    m[a] = 100
    m[c] = 500
    // b has the same evaluated value as a, so it hits a's entry.
    match map.get(&m, b) {
    | Some(v) -> { if v != 100 { bad += 1 } }
    | None    -> { bad += 1 }
    }
    fmt.println(`bad={bad}`)
    bad
}
