import cmath

let close_enough(a: f64, b: f64): bool = {
    let d = a - b
    let ad = if d < 0.0 { 0.0 - d } else { d }
    ad < 0.0001
}

let main(): i64 = {
    if !close_enough(cmath.sqrt(4.0), 2.0)   { return 1 }
    if !close_enough(cmath.pow(2.0, 10.0), 1024.0) { return 2 }
    if !close_enough(cmath.fabs(0.0 - 3.5), 3.5)   { return 3 }
    if !close_enough(cmath.floor(2.9), 2.0)        { return 4 }
    if !close_enough(cmath.ceil(2.1), 3.0)         { return 5 }
    if !close_enough(cmath.sin(0.0), 0.0)          { return 6 }
    if !close_enough(cmath.cos(0.0), 1.0)          { return 7 }
    if !close_enough(cmath.exp(0.0), 1.0)          { return 8 }
    if !close_enough(cmath.log(1.0), 0.0)          { return 9 }
    if !close_enough(cmath.fmin(2.0, 5.0), 2.0)    { return 10 }
    if !close_enough(cmath.fmax(2.0, 5.0), 5.0)    { return 11 }
    0
}
