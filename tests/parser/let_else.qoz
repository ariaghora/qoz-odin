// stage-b-skip: the compiler has no SLetElse AST yet; the test relies
// on `let Pattern = expr else { ... }` syntax. Re-enable once that
// feature lands.
import strings
import fmt

type Option =
    | None
    | Some(i64)

let unwrap_or_zero(opt: Option): i64 = {
    let Option.Some(v) = opt else {
        return 0
    }
    v
}

let main() = {
    fmt.println("Some(7) => {unwrap_or_zero(Option.Some(7))}")
    fmt.println("None    => {unwrap_or_zero(Option.None)}")
}
