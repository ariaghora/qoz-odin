import fmt
import strings
import vec

let main() = {
    let parts = strings.split("alpha,beta,gamma,delta", 44)
    fmt.println("count = {len(parts)}")
    var i: i64 = 0
    while i < len(parts) {
        fmt.println(parts[i])
        i = i + 1
    }

    let hp = strings.has_prefix("hello world", "hello")
    fmt.println(`has_prefix(hello world, hello) = {hp}`)
    let hs = strings.has_suffix("hello world", "world")
    fmt.println(`has_suffix(hello world, world) = {hs}`)
    let pi1 = strings.parse_int("42")
    fmt.println(`parse_int(42) = {pi1}`)
    let pi2 = strings.parse_int("-7")
    fmt.println(`parse_int(-7) = {pi2}`)
}
