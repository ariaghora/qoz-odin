import strings
import fmt

type Expr =
    | Num(i64)
    | Add(*Expr, *Expr)
    | Mul(*Expr, *Expr)

let eval(e: Expr): i64 =
    match e {
    | Expr.Num(n)    -> n
    | Expr.Add(a, b) -> eval(*a) + eval(*b)
    | Expr.Mul(a, b) -> eval(*a) * eval(*b)
    }

let main() = {
    let e = Expr.Add(
        new_clone(Expr.Num(3)),
        new_clone(Expr.Mul(new_clone(Expr.Num(4)), new_clone(Expr.Num(5)))),
    )
    fmt.println(`result: {eval(e)}`)
}
