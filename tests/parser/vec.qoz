import strings
import fmt

external let qoz_alloc(size: i64): *void
external let qoz_realloc(ptr: *void, size: i64): *void

// Renamed to UserVec so the test's local generic does not clash with
// std/vec::Vec, which std/strings pulls in transitively.
type UserVec<T> = {
    data: *T,
    len:  i64,
    cap:  i64,
}

let uv_new<T>(): UserVec<T> = UserVec { data: nil, len: 0, cap: 0 }

let uv_grow<T>(v: *UserVec<T>) = {
    let new_cap = if v.cap == 0 { 8 } else { v.cap * 2 }
    let new_data = qoz_realloc(v.data as *void, new_cap * size_of(T)) as *T
    v.data = new_data
    v.cap = new_cap
}

let uv_push<T>(v: *UserVec<T>, x: T) = {
    if v.len == v.cap {
        uv_grow(v)
    }
    v.data[v.len] = x
    v.len = v.len + 1
}

let uv_get<T>(v: *UserVec<T>, i: i64): T = v.data[i]

let main() = {
    var v: UserVec<i32> = uv_new()
    uv_push(&v, 10)
    uv_push(&v, 20)
    uv_push(&v, 30)
    uv_push(&v, 40)

    var i: i64 = 0
    while i < v.len {
        let x = uv_get(&v, i)
        fmt.println("v[ {i} ] = {x}")
        i = i + 1
    }
    fmt.println("len = {v.len} cap = {v.cap}")
}
