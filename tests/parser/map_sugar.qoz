import strings
import fmt
import map

let main() = {
    var m: Map<string, i64> = map.make()

    m["one"]   = 1
    m["two"]   = 2
    m["three"] = 3

    fmt.println("len = {map.len(&m)}")

    match map.get(&m, "two") {
    | Some(v) -> fmt.println("two = {v}")
    | None    -> fmt.println("two missing")
    }

    m["two"] = 22
    match map.get(&m, "two") {
    | Some(v) -> fmt.println("two after overwrite = {v}")
    | None    -> fmt.println("two missing after overwrite")
    }
    fmt.println("len after overwrite = {map.len(&m)}")
}
