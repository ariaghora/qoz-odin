import strings
import fmt

type Pair = { x: i64, y: i64 }

@operator("+")
let pair_add(a: *Pair, b: *Pair): Pair = Pair { x: a.x + b.x, y: a.y + b.y }

@operator("==")
let pair_eq(a: *Pair, b: *Pair): bool = a.x == b.x && a.y == b.y

@operator("unary-")
let pair_neg(a: *Pair): Pair = Pair { x: -a.x, y: -a.y }

let main() = {
    let p = Pair { x: 1, y: 2 }
    let q = Pair { x: 10, y: 20 }
    let r = p + q
    fmt.println("r.x = {r.x} r.y = {r.y}")

    let s = -p
    fmt.println("s.x = {s.x} s.y = {s.y}")

    if p == p {
        fmt.println("p == p")
    }
    if p == q {
        fmt.println("p == q (unexpected)")
    } else {
        fmt.println("p != q")
    }
}
