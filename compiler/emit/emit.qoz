// compiler/emit: codegen.

import fmt
import os
import strings
import vec
import map
import compiler/ast

type Instantiation = {
    name:    string,         // base type name, e.g. "Vec"
    args:    Vec<ast.TypeExpr>,  // concrete type arguments
    mangled: string,         // generated C name, e.g. "Vec__int32_t"
}

type Emitter = {
    out:               strings.Strbuf,
    // Per-expression TypeExpr map, keyed by expr_id (Expr pointer as
    // i64). Populated by the check phase. Read by infer_value_te_cached.
    expr_types:        Map<i64, ast.TypeExpr>,
    // Generic-instantiation substitution active while emitting a
    // monomorphised function body. Cached TypeExprs that mention these
    // params are substituted at lookup time.
    current_tparams:   Vec<string>,
    current_targs:     Vec<ast.TypeExpr>,
    // Sentinel positions: byte offsets in `out` where render() inserts
    // the typedef and synth-fn blocks. -1 means "not recorded yet".
    pos_fn_typedefs:   i64,
    pos_tuple_typedefs: i64,
    pos_synth_fn_decls: i64,
    variant_of:        Map<string, string>,  // bare variant name -> enum name (unique only)
    is_enum:           Map<string, bool>,    // names that refer to declared ADTs
    enum_decls:        Map<string, ast.Decl>,    // bare enum name -> DEnum (generic or not)
    c_enum_decls:      Map<string, ast.Decl>,    // bare C-enum name -> DCEnum
    struct_decls:      Map<string, ast.Decl>,    // bare struct name -> DStruct (generic or not)
    generic_decls:     Map<string, ast.Decl>,    // bare name -> declaration with type_params
    generic_fn_decls:  Map<string, ast.Decl>,    // (possibly package-prefixed) name -> generic fn declaration
    packages:          Map<string, bool>,    // known package names (from import resolution)
    consts:            Map<string, bool>,    // package-prefixed const names
    record_insts:      Vec<Instantiation>,
    record_seen:       Map<string, bool>,    // mangled -> seen
    enum_insts:        Vec<Instantiation>,
    enum_seen:         Map<string, bool>,
    fn_insts:          Vec<Instantiation>,
    fn_seen:           Map<string, bool>,
    locals:            Map<string, ast.TypeExpr>, // variable name -> TypeExpr for current fn body
    externs:           Map<string, string>,    // (possibly package-prefixed) name -> link symbol
    fn_returns:        Map<string, ast.TypeExpr>,  // qualified fn/extern name -> return TypeExpr
    fn_params:         Map<string, Vec<ast.TypeExpr>>, // qualified fn/extern name -> param TypeExprs
    match_counter:     i64,                    // monotonic counter for match temp variables
    current_ret_te:    ast.TypeExpr,                // declared return type of the fn being emitted
    match_hint:        ast.TypeExpr,                // hint TypeExpr for the current match expression's result
    fn_typedefs:       Map<string, string>,    // mangled name -> typedef body (for function types)
    op_dispatch:       Map<string, string>,    // "<op>::<TypeName>" -> fn name registered via @operator
    byval_helpers_emitted: Map<string, bool>,  // fn_name -> already emitted a _qoz_byval_FN forwarder
    // Statements queued for emission just before the current C
    // statement. Set up by emit_stmt. Written to by sub-emits that
    // need to hoist a complex sub-expression (match in value position,
    // closure construction, etc.) out of expression position.
    pending_prologue:  Vec<string>,
    // Text prepended to every `return` emitted in the current function.
    // Used to restore the shadow stack to the function-entry snapshot
    // without relying on __attribute__((cleanup)).
    current_return_restore: string,
    tuple_typedefs:    Map<string, string>,    // mangled tuple name -> typedef body
    tuple_typedef_order: Vec<string>,          // mangled tuple names in insertion order
    fn_typedef_order:  Vec<string>,            // mangled names in insertion order
    closure_counter:   i64,                    // monotonic counter for closure-lifted function names
    synth_fn_defs:     Vec<string>,            // pre-rendered C source for each lifted closure body
    synth_fn_decls:    Vec<string>,            // pre-rendered forward declarations for lifted closures
    show_pending:      Map<string, ast.TypeExpr>,  // mangled type -> TypeExpr, queued for show-fn emission
    show_order:        Vec<string>,            // mangled type names in registration order
    show_emitted:      Map<string, bool>,      // mangled type names whose show fn has been rendered
}

let make_emitter(): Emitter = Emitter {
    out:               strings.Strbuf { buf: nil as *u8, len: 0, cap: 0 },
    expr_types:        map.make(),
    current_tparams:   vec.make(),
    current_targs:     vec.make(),
    pos_fn_typedefs:   -1,
    pos_tuple_typedefs: -1,
    pos_synth_fn_decls: -1,
    variant_of:       map.make(),
    is_enum:          map.make(),
    enum_decls:       map.make(),
    c_enum_decls:     map.make(),
    struct_decls:     map.make(),
    generic_decls:    map.make(),
    generic_fn_decls: map.make(),
    packages:         map.make(),
    consts:           map.make(),
    record_insts:     vec.make(),
    record_seen:      map.make(),
    enum_insts:       vec.make(),
    enum_seen:        map.make(),
    fn_insts:         vec.make(),
    fn_seen:          map.make(),
    locals:           map.make(),
    externs:          map.make(),
    fn_returns:       map.make(),
    fn_params:        map.make(),
    match_counter:    0,
    current_ret_te:   TEUnit(ast.Span { file: "", line: 0, col: 0 }),
    match_hint:       TEUnit(ast.Span { file: "", line: 0, col: 0 }),
    fn_typedefs:      map.make(),
    op_dispatch:      map.make(),
    byval_helpers_emitted: map.make(),
    pending_prologue:  vec.make(),
    current_return_restore: "",
    tuple_typedefs:   map.make(),
    tuple_typedef_order: vec.make(),
    fn_typedef_order: vec.make(),
    closure_counter:  0,
    synth_fn_defs:    vec.make(),
    synth_fn_decls:   vec.make(),
    show_pending:     map.make(),
    show_order:       vec.make(),
    show_emitted:     map.make(),
}

let register_generics(e: *Emitter, file: ast.File) = {
    for d in file.decls {
        match d {
        | DStruct(_, name, params, _) -> {
            if len(params) > 0 {
                e.generic_decls[name] = d
            }
        }
        | DEnum(_, name, params, _) -> {
            if len(params) > 0 {
                e.generic_decls[name] = d
            }
        }
        | DFn(_, name, params, _, _, _, _) -> {
            if len(params) > 0 {
                e.generic_fn_decls[name] = d
            }
        }
        | _ -> { }
        }
    }
}

let register_fn_instantiation(e: *Emitter, callee: ast.Expr, type_args: Vec<ast.TypeExpr>) = {
    if len(type_args) == 0 { return }
    let name = generic_callee_name(e, callee)
    if strings.eq_raw(name, "") { return }
    if !map.contains(&e.generic_fn_decls, name) { return }
    let mangled = mangle_inst(e, name, type_args)
    if map.contains(&e.fn_seen, mangled) { return }
    e.fn_seen[mangled] = true
    vec.push(&e.fn_insts, Instantiation { name: name, args: type_args, mangled: mangled })
    for ta in type_args { walk_typeexpr(e, ta) }
}

// Extract the variant name when `callee` references a variant of a
// known enum, in any of the three accepted call shapes. Returns ""
// when the callee is not a variant constructor.
let variant_callee_name(e: *Emitter, callee: ast.Expr): string = {
    match callee {
    | EIdent(_, name) -> {
        match map.get(&e.variant_of, name) {
        | Some(_) -> name
        | None    -> ""
        }
    }
    | EField(_, base, method) -> {
        match base {
        | EIdent(_, enum_name) -> {
            if !map.contains(&e.enum_decls, enum_name) { return "" }
            match map.get(&e.variant_of, method) {
            | Some(_) -> method
            | None    -> ""
            }
        }
        | _ -> ""
        }
    }
    | EPath(_, segs) -> {
        if len(segs) != 2 { return "" }
        if !map.contains(&e.enum_decls, segs[0]) { return "" }
        match map.get(&e.variant_of, segs[1]) {
        | Some(_) -> segs[1]
        | None    -> ""
        }
    }
    | _ -> ""
    }
}

// Pull the explicit enum name out of a qualified variant callee.
// Returns the empty string when the callee is a bare identifier. The
// caller falls back to the global variant_of mapping in that case.
let variant_enum_from_callee(callee: ast.Expr): string = {
    match callee {
    | EField(_, base, _) -> {
        match base {
        | EIdent(_, en) -> en
        | _             -> ""
        }
    }
    | EPath(_, segs) -> {
        if len(segs) == 2 { segs[0] } else { "" }
    }
    | _ -> ""
    }
}

// Resolve the enum that owns the variant call. The qualified form
// (Enum.Variant) takes precedence so the path the user wrote is
// respected even when the bare name is registered to a different
// enum in variant_of.
let resolve_variant_enum(e: *Emitter, callee: ast.Expr, variant_name: string): string = {
    let explicit = variant_enum_from_callee(callee)
    if !strings.eq_raw(explicit, "") {
        return explicit
    }
    match map.get(&e.variant_of, variant_name) {
    | Some(en) -> en
    | None     -> ""
    }
}

let generic_callee_name(e: *Emitter, callee: ast.Expr): string = {
    match callee {
    | EIdent(_, name) -> name
    | EField(_, base, method) -> {
        match base {
        | EIdent(_, pkg) -> {
            if map.contains(&e.packages, pkg) {
                return strings.cat(strings.cat(pkg, "_"), method)
            }
            // `Enum.Variant(...)`: when the base is a known enum and
            // the method is one of its variants, the callee is the
            // variant constructor. Return the bare variant name so
            // the variant_of dispatch downstream picks it up.
            if map.contains(&e.enum_decls, pkg) {
                match map.get(&e.variant_of, method) {
                | Some(_) -> return method
                | None    -> { }
                }
            }
            ""
        }
        | _ -> ""
        }
    }
    | EPath(_, segs) -> {
        if len(segs) == 2 {
            let pkg    = segs[0]
            let method = segs[1]
            if map.contains(&e.packages, pkg) {
                return strings.cat(strings.cat(pkg, "_"), method)
            }
            if map.contains(&e.enum_decls, pkg) {
                match map.get(&e.variant_of, method) {
                | Some(_) -> return method
                | None    -> { }
                }
            }
        }
        ""
    }
    | _ -> ""
    }
}

let collect_type_instantiations(e: *Emitter, file: ast.File) = {
    for d in file.decls {
        walk_decl_for_types(e, d)
    }
    // Iterate the three instantiation lists until none grows.
    var stable = false
    var iters: i64 = 0
    while !stable {
        if iters > 32 { stable = true }
        iters += 1
        let before_r = len(e.record_insts)
        let before_e = len(e.enum_insts)
        let before_f = len(e.fn_insts)
        var i: i64 = 0
        while i < len(e.record_insts) {
            let inst = e.record_insts[i]
            if let Some(decl) = map.get(&e.generic_decls, inst.name) {
                walk_struct_fields_with_subst(e, decl, inst.args)
            }
            i += 1
        }
        var j: i64 = 0
        while j < len(e.enum_insts) {
            let inst = e.enum_insts[j]
            if let Some(decl) = map.get(&e.generic_decls, inst.name) {
                walk_enum_variants_with_subst(e, decl, inst.args)
            }
            j += 1
        }
        var k: i64 = 0
        while k < len(e.fn_insts) {
            let inst = e.fn_insts[k]
            if let Some(decl) = map.get(&e.generic_fn_decls, inst.name) {
                walk_fn_body_with_subst(e, decl, inst.args)
            }
            k += 1
        }
        if len(e.record_insts) == before_r && len(e.enum_insts) == before_e && len(e.fn_insts) == before_f {
            stable = true
        }
    }
}

let walk_fn_body_with_subst(e: *Emitter, d: ast.Decl, args: Vec<ast.TypeExpr>) = {
    match d {
    | DFn(_, _, params, fn_params, ret, body, _) -> {
        for pp in fn_params {
            walk_typeexpr(e, substitute_type(e, pp.ty, params, args))
        }
        walk_typeexpr(e, substitute_type(e, ret, params, args))
        let subst_body = substitute_expr(e, body, params, args)
        walk_expr_for_types(e, subst_body)
    }
    | _ -> { }
    }
}

let walk_struct_fields_with_subst(e: *Emitter, d: ast.Decl, args: Vec<ast.TypeExpr>) = {
    match d {
    | DStruct(_, _, params, fields) -> {
        for f in fields {
            let substituted = substitute_type(e, f.ty, params, args)
            walk_typeexpr(e, substituted)
        }
    }
    | _ -> { }
    }
}

let walk_enum_variants_with_subst(e: *Emitter, d: ast.Decl, args: Vec<ast.TypeExpr>) = {
    match d {
    | DEnum(_, _, params, variants) -> {
        for v in variants {
            for pt in v.pos {
                let substituted = substitute_type(e, pt, params, args)
                walk_typeexpr(e, substituted)
            }
            for nf in v.named {
                let substituted = substitute_type(e, nf.ty, params, args)
                walk_typeexpr(e, substituted)
            }
        }
    }
    | _ -> { }
    }
}

let walk_decl_for_types(e: *Emitter, d: ast.Decl) = {
    match d {
    | DStruct(_, _, params, fields) -> {
        if len(params) == 0 {
            for f in fields {
                walk_typeexpr(e, f.ty)
            }
        }
    }
    | DEnum(_, _, params, variants) -> {
        if len(params) == 0 {
            for v in variants {
                for pt in v.pos {
                    walk_typeexpr(e, pt)
                }
                for nf in v.named {
                    walk_typeexpr(e, nf.ty)
                }
            }
        }
    }
    | DFn(_, _, params, fn_params, ret, body, _) -> {
        if len(params) == 0 {
            for fp in fn_params {
                walk_typeexpr(e, fp.ty)
            }
            walk_typeexpr(e, ret)
            e.locals = map.make()
            for fp in fn_params { e.locals[fp.name] = fp.ty }
            walk_expr_for_types(e, body)
        }
    }
    | DExternal(_, _, _, fn_params, ret) -> {
        for fp in fn_params {
            walk_typeexpr(e, fp.ty)
        }
        walk_typeexpr(e, ret)
    }
    | DConst(_, _, ty, value) -> {
        walk_typeexpr(e, ty)
        walk_expr_for_types(e, value)
    }
    | _ -> { }
    }
}

let walk_typeexpr(e: *Emitter, te: ast.TypeExpr) = {
    match te {
    | TEUnit(_) -> { }
    | TEPtr(_, inner) -> walk_typeexpr(e, inner)
    | TETuple(_, elems) -> {
        for el in elems { walk_typeexpr(e, el) }
    }
    | TENamed(_, path, args) -> {
        if len(path) == 1 && len(args) > 0 {
            let name = path[0]
            if map.contains(&e.generic_decls, name) {
                for a in args { walk_typeexpr(e, a) }
                register_instance(e, name, args)
            }
        }
        for a in args { walk_typeexpr(e, a) }
    }
    | TEFn(_, params, ret) -> {
        for p in params { walk_typeexpr(e, p) }
        walk_typeexpr(e, ret)
    }
    }
}

let literal_typeexpr(ex: ast.Expr): Option<ast.TypeExpr> = {
    match ex {
    | EInt(sp, _)    -> Some(single_named_te(sp, "i64"))
    | EFloat(sp, _)  -> Some(single_named_te(sp, "f64"))
    | EString(sp, _) -> Some(single_named_te(sp, "string"))
    | EBool(sp, _)   -> Some(single_named_te(sp, "bool"))
    | EChar(sp, _)   -> Some(single_named_te(sp, "char"))
    | ECast(_, _, t) -> Some(t)
    | _              -> None
    }
}

// When a `let v: Vec<T> = [...]` declares an explicit element type that
// differs from what the array literal's first element would infer (for
// example `Vec<i32> = [10, 20]` where the literals default to i64),
// register the annotated instantiation up front so vec.make<T> and
// vec.push<T> exist with the correct C suffix at link time.
let walk_let_value_for_array_hint(e: *Emitter, ty: ast.TypeExpr, val: ast.Expr) = {
    if is_unit_typeexpr(ty) { return }
    match ty {
    | TENamed(sp, path, args) -> {
        if len(path) < 1 { return }
        if !strings.eq_raw(path[len(path) - 1], "Vec") { return }
        if len(args) < 1 { return }
        match val {
        | EArrayLit(_, _) -> {
            var vec_args: Vec<ast.TypeExpr> = vec.make()
            vec.push(&vec_args, args[0])
            walk_typeexpr(e, TENamed(sp, path, vec_args))
            register_fn_instantiation(e, EField(sp, EIdent(sp, "vec"), "make"), vec_args)
            register_fn_instantiation(e, EField(sp, EIdent(sp, "vec"), "push"), vec_args)
        }
        | _ -> { }
        }
    }
    | _ -> { }
    }
}

let walk_expr_for_types(e: *Emitter, ex: ast.Expr) = {
    match ex {
    | EBlock(_, stmts, tail) -> {
        for s in stmts {
            match s {
            | SLet(_, name, ty, val) -> {
                walk_typeexpr(e, ty)
                walk_let_value_for_array_hint(e, ty, val)
                walk_expr_for_types(e, val)
                if !is_unit_typeexpr(ty) {
                    e.locals[name] = ty
                }
            }
            | SVar(_, name, ty, val) -> {
                walk_typeexpr(e, ty)
                walk_let_value_for_array_hint(e, ty, val)
                walk_expr_for_types(e, val)
                if !is_unit_typeexpr(ty) {
                    e.locals[name] = ty
                }
            }
            | SExpr(_, ex2) -> walk_expr_for_types(e, ex2)
            }
        }
        walk_expr_for_types(e, tail)
    }
    | ERecord(_, te, fields) -> {
        walk_typeexpr(e, te)
        for f in fields { walk_expr_for_types(e, f.value) }
    }
    | ECast(_, val, te) -> { walk_typeexpr(e, te); walk_expr_for_types(e, val) }
    | ESizeOf(_, te) -> walk_typeexpr(e, te)
    | EBinary(_, _, l, r) -> { walk_expr_for_types(e, l); walk_expr_for_types(e, r) }
    | EUnary(_, _, rhs) -> walk_expr_for_types(e, rhs)
    | EAssign(_, _, l, r) -> {
        walk_expr_for_types(e, l)
        walk_expr_for_types(e, r)
        walk_assign_for_map_helpers(e, l)
    }
    | ECall(sp, callee, type_args, args) -> {
        walk_expr_for_types(e, callee)
        for ta in type_args { walk_typeexpr(e, ta) }
        for a in args { walk_expr_for_types(e, a) }
        register_fn_instantiation(e, callee, type_args)
        // Implicit variant-constructor instantiation: `Option.Some(42)`
        // with no explicit type args reaches this point with empty
        // type_args. Walk-time inference uses literal_typeexpr only,
        // because locals are not yet bound. The full emit-time inference
        // covers the rest of the cases through the normal dispatch.
        if len(type_args) == 0 {
            let vname = variant_callee_name(e, callee)
            if !strings.eq_raw(vname, "") {
                match map.get(&e.variant_of, vname) {
                | Some(en) -> {
                    let inferred = literal_variant_type_args(e, en, vname, args, sp)
                    if len(inferred) > 0 {
                        var path: Vec<string> = vec.make()
                        vec.push(&path, en)
                        walk_typeexpr(e, TENamed(sp, path, inferred))
                    }
                }
                | None -> { }
                }
            }
        }
    }
    | EField(_, base, _) -> walk_expr_for_types(e, base)
    | EIndex(_, base, idx) -> { walk_expr_for_types(e, base); walk_expr_for_types(e, idx) }
    | ETry(_, val) -> walk_expr_for_types(e, val)
    | EIf(_, c, t, f) -> { walk_expr_for_types(e, c); walk_expr_for_types(e, t); walk_expr_for_types(e, f) }
    | EMatch(_, scrut, arms) -> {
        walk_expr_for_types(e, scrut)
        for arm in arms { walk_expr_for_types(e, arm.body) }
    }
    | EWhile(_, c, b) -> { walk_expr_for_types(e, c); walk_expr_for_types(e, b) }
    | EFor(_, _, _, it, b) -> { walk_expr_for_types(e, it); walk_expr_for_types(e, b) }
    | EReturn(_, v) -> walk_expr_for_types(e, v)
    | EDefer(_, b) -> walk_expr_for_types(e, b)
    | ETuple(_, elems) -> { for el in elems { walk_expr_for_types(e, el) } }
    | EArrayLit(sp, elems) -> {
        for el in elems { walk_expr_for_types(e, el) }
        if len(elems) > 0 {
            let elem_te = literal_typeexpr(elems[0])
            match elem_te {
            | Some(et) -> {
                var args: Vec<ast.TypeExpr> = vec.make()
                vec.push(&args, et)
                var path: Vec<string> = vec.make()
                vec.push(&path, "Vec")
                walk_typeexpr(e, TENamed(sp, path, args))
                register_fn_instantiation(e, EField(sp, EIdent(sp, "vec"), "make"), args)
                register_fn_instantiation(e, EField(sp, EIdent(sp, "vec"), "push"), args)
            }
            | None -> { }
            }
        }
    }
    | EClosure(_, _, _, body) -> walk_expr_for_types(e, body)
    | _ -> { }
    }
}

let register_instance(e: *Emitter, name: string, args: Vec<ast.TypeExpr>) = {
    let mangled = mangle_inst(e, name, args)
    if map.contains(&e.is_enum, name) {
        if map.contains(&e.enum_seen, mangled) { return }
        e.enum_seen[mangled] = true
        vec.push(&e.enum_insts, Instantiation { name: name, args: args, mangled: mangled })
    } else {
        if map.contains(&e.record_seen, mangled) { return }
        e.record_seen[mangled] = true
        vec.push(&e.record_insts, Instantiation { name: name, args: args, mangled: mangled })
    }
}

let mangle_inst(e: *Emitter, name: string, args: Vec<ast.TypeExpr>): string = {
    var acc = name
    for a in args {
        acc = strings.cat(acc, "__")
        acc = strings.cat(acc, mangle_type(e, a))
    }
    acc
}

// ----------------------------------------------------------------
// Auto-derived show.
// ----------------------------------------------------------------
//
// Backtick interpolation routes every non-primitive slot through a
// per-type show function. The function takes the value, builds a
// string with the runtime's interpolation builder, and returns it.
// Show functions are synthesised on demand, deduplicated by mangled
// type name, and emitted once at render time.

// Compact text used in diagnostics. The proper `c_type_for` mapping
// needs an emitter. This version stays self-contained so it can be
// called from contexts that only have a TypeExpr.
let te_show_dbg(te: ast.TypeExpr): string = {
    match te {
    | TEUnit(_)            -> "unit"
    | TEPtr(_, inner)      -> strings.cat("*", te_show_dbg(inner))
    | TETuple(_, _)        -> "tuple"
    | TEFn(_, _, _)        -> "fn"
    | TENamed(_, path, args) -> {
        if len(path) == 0 { return "<unnamed>" }
        var out = path[len(path) - 1]
        if len(args) > 0 {
            out = strings.cat(out, "<")
            var i: i64 = 0
            for a in args {
                if i > 0 { out = strings.cat(out, ", ") }
                out = strings.cat(out, te_show_dbg(a))
                i += 1
            }
            out = strings.cat(out, ">")
        }
        out
    }
    }
}

let register_show_needed(e: *Emitter, mangled: string, te: ast.TypeExpr) = {
    if map.contains(&e.show_pending, mangled) { return }
    e.show_pending[mangled] = te
    vec.push(&e.show_order, mangled)
    let arg_c = c_type_for(e, te)
    let fwd = `static qoz_string qoz_show_{mangled}({arg_c} v);\n`
    vec.push(&e.synth_fn_decls, fwd)
}

// Emit a C statement that pushes `c_expr` (already a valid C
// expression of type `te`) onto the interpolation buffer `b`. The
// dispatch follows the same primitive/composite split as the parser
// desugar: primitives go through a typed push. Composite types route
// through a (lazily registered) show fn.
let emit_show_push(e: *Emitter, body_acc: string, c_expr: string, te: ast.TypeExpr): string = {
    let pname = show_primitive_kind(te)
    if !strings.eq_raw(pname, "") {
        if strings.eq_raw(pname, "str") {
            return strings.cat(body_acc, `qoz_interp_push_str(b, {c_expr});\n`)
        }
        if strings.eq_raw(pname, "i64") {
            return strings.cat(body_acc, `qoz_interp_push_i64(b, (int64_t)({c_expr}));\n`)
        }
        if strings.eq_raw(pname, "f64") {
            return strings.cat(body_acc, `qoz_interp_push_f64(b, (double)({c_expr}));\n`)
        }
        if strings.eq_raw(pname, "bool") {
            return strings.cat(body_acc, `qoz_interp_push_bool(b, {c_expr});\n`)
        }
        if strings.eq_raw(pname, "char") {
            return strings.cat(body_acc, `qoz_interp_push_char(b, (int64_t)({c_expr}));\n`)
        }
    }
    // Composite: register a show fn for `te` and call it.
    let mangled = mangle_type(e, te)
    if strings.eq_raw(mangled, "") {
        return strings.cat(body_acc, `qoz_interp_push_str(b, QOZ_STR_LIT("<unprintable>"));\n`)
    }
    register_show_needed(e, mangled, te)
    strings.cat(body_acc, `qoz_interp_push_str(b, qoz_show_{mangled}({c_expr}));\n`)
}

let show_primitive_kind(te: ast.TypeExpr): string = {
    match te {
    | TENamed(_, path, _) -> {
        if len(path) != 1 { return "" }
        let n = path[0]
        if strings.eq_raw(n, "string")  { return "str" }
        if strings.eq_raw(n, "bool")    { return "bool" }
        if strings.eq_raw(n, "char")    { return "char" }
        if strings.eq_raw(n, "f32") || strings.eq_raw(n, "f64") { return "f64" }
        if strings.eq_raw(n, "i8") || strings.eq_raw(n, "i16") || strings.eq_raw(n, "i32") || strings.eq_raw(n, "i64") { return "i64" }
        if strings.eq_raw(n, "u8") || strings.eq_raw(n, "u16") || strings.eq_raw(n, "u32") || strings.eq_raw(n, "u64") { return "i64" }
        ""
    }
    | _ -> ""
    }
}

let push_literal(body_acc: string, lit: string): string = {
    // The literal must already be a safe C string body (no embedded
    // unescaped quotes). The callers in this module only pass static
    // ASCII chunks ("(", ", ", " }", variant names, field names), so
    // escaping does not need to be re-applied here.
    strings.cat(body_acc, `qoz_interp_push_str(b, QOZ_STR_LIT("{lit}"));\n`)
}

// Render a show fn body for a record type. `bare` is the
// unparametrised struct name (e.g. "Point", "Vec"). `mangled` is the
// C-level name (`qoz_Point`, `qoz_Vec__int64_t`, ...). `args` is the
// type-argument vector for generic instantiations.
let render_show_body_record(e: *Emitter, bare: string, mangled: string, args: Vec<ast.TypeExpr>): string = {
    if strings.eq_raw(bare, "Vec") && len(args) == 1 {
        return render_show_body_vec(e, mangled, args[0])
    }
    if strings.eq_raw(bare, "Map") && len(args) == 2 {
        return render_show_body_map(e, mangled, args[0], args[1])
    }
    match map.get(&e.struct_decls, bare) {
    | None -> {
        var body = ""
        body = push_literal(body, `<{bare}>`)
        body
    }
    | Some(d) -> {
        match d {
        | DStruct(_, _, tparams, fields) -> {
            var body = ""
            body = push_literal(body, strings.cat(bare, " { "))
            var fi: i64 = 0
            for f in fields {
                if fi > 0 { body = push_literal(body, ", ") }
                body = push_literal(body, strings.cat(f.name, ": "))
                let field_te = if len(tparams) > 0 && len(args) == len(tparams) {
                    substitute_type(e, f.ty, tparams, args)
                } else { f.ty }
                let access = `v.{f.name}`
                body = emit_show_push(e, body, access, field_te)
                fi += 1
            }
            body = push_literal(body, " }")
            body
        }
        | _ -> {
            var body = ""
            body = push_literal(body, `<{bare}>`)
            body
        }
        }
    }
    }
}

let render_show_body_vec(e: *Emitter, mangled: string, elem_te: ast.TypeExpr): string = {
    var body = ""
    body = push_literal(body, "[")
    body = strings.cat(body, "for (int64_t i = 0; i < v.len; i++) {\n")
    body = strings.cat(body, "if (i > 0) qoz_interp_push_str(b, QOZ_STR_LIT(\", \"));\n")
    body = emit_show_push(e, body, "v.data[i]", elem_te)
    body = strings.cat(body, "}\n")
    body = push_literal(body, "]")
    body
}

let render_show_body_map(e: *Emitter, mangled: string, key_te: ast.TypeExpr, val_te: ast.TypeExpr): string = {
    var body = ""
    body = push_literal(body, "{ ")
    body = strings.cat(body, "int64_t printed = 0;\n")
    body = strings.cat(body, "for (int64_t i = 0; i < v.cap; i++) {\n")
    body = strings.cat(body, "if (!v.slots[i].occupied || v.slots[i].deleted) continue;\n")
    body = strings.cat(body, "if (printed > 0) qoz_interp_push_str(b, QOZ_STR_LIT(\", \"));\n")
    body = emit_show_push(e, body, "v.slots[i].key", key_te)
    body = strings.cat(body, "qoz_interp_push_str(b, QOZ_STR_LIT(\": \"));\n")
    body = emit_show_push(e, body, "v.slots[i].value", val_te)
    body = strings.cat(body, "printed += 1;\n")
    body = strings.cat(body, "}\n")
    body = push_literal(body, " }")
    body
}

// Render a show fn body for an ADT. The C parameter `v` is the
// `qoz_<MangledEnum>*` pointer. The switch dispatches on its tag
// and prints `Variant(payload, ...)` for each.
let render_show_body_adt(e: *Emitter, bare: string, mangled: string, args: Vec<ast.TypeExpr>): string = {
    let inst_args = if len(args) > 0 { args } else { mangled_args(e, mangled, bare) }
    // Case labels and enum-prefixed identifiers in the emitted C use
    // the mangled type name without the leading "qoz_" that mangle_type
    // adds. Strip it once here so the labels match what emit_enum
    // produces.
    let case_prefix = if strings.has_prefix(mangled, "qoz_") {
        strings.slice(mangled, 4, len(mangled))
    } else { mangled }
    match map.get(&e.enum_decls, bare) {
    | None -> {
        var body = ""
        body = push_literal(body, `<{bare}>`)
        body
    }
    | Some(d) -> {
        match d {
        | DEnum(_, _, tparams, variants) -> {
            var body = ""
            body = strings.cat(body, `switch (v->tag) {{\n`)
            for vd in variants {
                let vname = vd.name
                body = strings.cat(body, `case qoz_{case_prefix}_{vname}: {{\n`)
                if len(vd.pos) == 0 {
                    body = push_literal(body, vname)
                } else {
                    body = push_literal(body, strings.cat(vname, "("))
                    var pi: i64 = 0
                    for pte in vd.pos {
                        if pi > 0 { body = push_literal(body, ", ") }
                        let sub_te = if len(tparams) > 0 && len(inst_args) == len(tparams) {
                            substitute_type(e, pte, tparams, inst_args)
                        } else { pte }
                        let pstr = int_to_string(pi)
                        let access = `v->payload.{vname}.f{pstr}`
                        body = emit_show_push(e, body, access, sub_te)
                        pi += 1
                    }
                    body = push_literal(body, ")")
                }
                body = strings.cat(body, "break;\n} \n")
            }
            body = strings.cat(body, `default: qoz_interp_push_str(b, QOZ_STR_LIT("<{bare}:?>")); break;\n`)
            body = strings.cat(body, "}\n")
            body
        }
        | _ -> {
            var body = ""
            body = push_literal(body, `<{bare}>`)
            body
        }
        }
    }
    }
}

let render_show_body_tuple(e: *Emitter, elems: Vec<ast.TypeExpr>): string = {
    var body = ""
    body = push_literal(body, "(")
    var i: i64 = 0
    for el in elems {
        if i > 0 { body = push_literal(body, ", ") }
        let pstr = int_to_string(i)
        let access = `v._{pstr}`
        body = emit_show_push(e, body, access, el)
        i += 1
    }
    body = push_literal(body, ")")
    body
}

let render_show_fn(e: *Emitter, mangled: string, te: ast.TypeExpr): string = {
    let arg_c = c_type_for(e, te)
    let body_inner = match te {
    | TENamed(_, path, args) -> {
        if len(path) == 0 {
            push_literal("", "<unnamed>")
        } else {
            let bare = path[len(path) - 1]
            if map.contains(&e.enum_decls, bare) {
                render_show_body_adt(e, bare, mangled, args)
            } else {
                render_show_body_record(e, bare, mangled, args)
            }
        }
    }
    | TEPtr(_, inner) -> {
        // Pointer to a printable value: emit a show fn whose `v` is
        // the pointer and whose body forwards to the underlying
        // type's show fn through an automatic dereference.
        let inner_mangled = mangle_type(e, inner)
        register_show_needed(e, inner_mangled, inner)
        var body = `qoz_interp_push_str(b, qoz_show_{inner_mangled}(*v));\n`
        body
    }
    | TETuple(_, elems) -> render_show_body_tuple(e, elems)
    | _                 -> push_literal("", "<unprintable>")
    }
    var out = `static qoz_string qoz_show_{mangled}({arg_c} v) {{\n`
    out = strings.cat(out, "void* b = qoz_interp_init();\n")
    out = strings.cat(out, body_inner)
    out = strings.cat(out, "return qoz_interp_finish(b);\n")
    out = strings.cat(out, "}\n")
    out
}

let mangle_type(e: *Emitter, t: ast.TypeExpr): string = {
    match t {
    | TEUnit(_)                  -> "void"
    | TEPtr(_, inner)            -> strings.cat(mangle_type(e, inner), "_ptr")
    | TETuple(_, elems)          -> {
        var acc = "tuple"
        for el in elems {
            acc = strings.cat(acc, "__")
            acc = strings.cat(acc, mangle_type(e, el))
        }
        acc
    }
    | TENamed(_, path, args)     -> mangle_named(e, path, args)
    | TEFn(_, _, _)              -> "fn"
    }
}

let mangle_named(e: *Emitter, path: Vec<string>, args: Vec<ast.TypeExpr>): string = {
    if len(path) == 0 {
        return "unknown"
    }
    // Qualified paths (`pkg.TypeName`) collapse to the last segment.
    // Type names share a flat C-level namespace. The check phase has
    // already verified the qualifier matches the type's home package.
    let n = path[len(path) - 1]
    let prim = primitive_c_name(n)
    if !strings.eq_raw(prim, "") {
        return prim
    }
    if len(args) > 0 {
        return strings.cat("qoz_", mangle_inst(e, n, args))
    }
    strings.cat("qoz_", n)
}

let primitive_c_name(n: string): string = {
    if strings.eq_raw(n, "i8")     { return "int8_t" }
    if strings.eq_raw(n, "i16")    { return "int16_t" }
    if strings.eq_raw(n, "i32")    { return "int32_t" }
    if strings.eq_raw(n, "i64")    { return "int64_t" }
    if strings.eq_raw(n, "u8")     { return "uint8_t" }
    if strings.eq_raw(n, "u16")    { return "uint16_t" }
    if strings.eq_raw(n, "u32")    { return "uint32_t" }
    if strings.eq_raw(n, "u64")    { return "uint64_t" }
    if strings.eq_raw(n, "f32")    { return "float" }
    if strings.eq_raw(n, "f64")    { return "double" }
    if strings.eq_raw(n, "bool")   { return "bool" }
    if strings.eq_raw(n, "char")   { return "char" }
    if strings.eq_raw(n, "string") { return "qoz_string" }
    ""
}

let substitute_type(e: *Emitter, t: ast.TypeExpr, params: Vec<string>, args: Vec<ast.TypeExpr>): ast.TypeExpr = {
    match t {
    | TEUnit(_) -> t
    | TEPtr(span, inner) -> TEPtr(span, substitute_type(e, inner, params, args))
    | TETuple(span, elems) -> {
        var new_elems: Vec<ast.TypeExpr> = vec.make()
        for el in elems { vec.push(&new_elems, substitute_type(e, el, params, args)) }
        TETuple(span, new_elems)
    }
    | TENamed(span, path, t_args) -> {
        if len(path) == 1 && len(t_args) == 0 {
            // Bare type parameter? Look it up.
            let n = path[0]
            var i: i64 = 0
            for p in params {
                if strings.eq_raw(p, n) {
                    return args[i]
                }
                i += 1
            }
        }
        var new_args: Vec<ast.TypeExpr> = vec.make()
        for a in t_args { vec.push(&new_args, substitute_type(e, a, params, args)) }
        TENamed(span, path, new_args)
    }
    | TEFn(span, fparams, ret) -> {
        var new_fparams: Vec<ast.TypeExpr> = vec.make()
        for fp in fparams { vec.push(&new_fparams, substitute_type(e, fp, params, args)) }
        TEFn(span, new_fparams, substitute_type(e, ret, params, args))
    }
    }
}

let substitute_expr(e: *Emitter, x: ast.Expr, params: Vec<string>, args: Vec<ast.TypeExpr>): ast.Expr = {
    match x {
    | EInt(_, _)
    | EFloat(_, _)
    | EString(_, _)
    | EChar(_, _)
    | EBool(_, _)
    | ENil(_)
    | EIdent(_, _)
    | EPath(_, _)             -> x
    | EUnary(sp, op, rhs)     -> EUnary(sp, op, substitute_expr(e, rhs, params, args))
    | EBinary(sp, op, l, r)   -> EBinary(sp, op, substitute_expr(e, l, params, args), substitute_expr(e, r, params, args))
    | EAssign(sp, op, l, r)   -> EAssign(sp, op, substitute_expr(e, l, params, args), substitute_expr(e, r, params, args))
    | ECall(sp, callee, ta, ax) -> {
        var new_ta: Vec<ast.TypeExpr> = vec.make()
        for t in ta { vec.push(&new_ta, substitute_type(e, t, params, args)) }
        var new_args: Vec<ast.Expr> = vec.make()
        for a in ax { vec.push(&new_args, substitute_expr(e, a, params, args)) }
        ECall(sp, substitute_expr(e, callee, params, args), new_ta, new_args)
    }
    | EField(sp, base, name)  -> EField(sp, substitute_expr(e, base, params, args), name)
    | EIndex(sp, base, idx)   -> EIndex(sp, substitute_expr(e, base, params, args), substitute_expr(e, idx, params, args))
    | ECast(sp, value, t)     -> ECast(sp, substitute_expr(e, value, params, args), substitute_type(e, t, params, args))
    | ETry(sp, value)         -> ETry(sp, substitute_expr(e, value, params, args))
    | ETuple(sp, elems)       -> {
        var new_e: Vec<ast.Expr> = vec.make()
        for el in elems { vec.push(&new_e, substitute_expr(e, el, params, args)) }
        ETuple(sp, new_e)
    }
    | ERecord(sp, te, fields) -> {
        var new_fields: Vec<ast.RecordFieldLit> = vec.make()
        for f in fields {
            vec.push(&new_fields, ast.RecordFieldLit { name: f.name, value: substitute_expr(e, f.value, params, args) })
        }
        ERecord(sp, substitute_type(e, te, params, args), new_fields)
    }
    | EClosure(sp, cps, ret, body) -> {
        var new_cps: Vec<ast.ClosureParam> = vec.make()
        for cp in cps {
            vec.push(&new_cps, ast.ClosureParam { name: cp.name, ty: substitute_type(e, cp.ty, params, args) })
        }
        EClosure(sp, new_cps, substitute_type(e, ret, params, args), substitute_expr(e, body, params, args))
    }
    | EBlock(sp, stmts, tail) -> {
        var new_stmts: Vec<ast.Stmt> = vec.make()
        for s in stmts { vec.push(&new_stmts, substitute_stmt(e, s, params, args)) }
        EBlock(sp, new_stmts, substitute_expr(e, tail, params, args))
    }
    | EIf(sp, c, t, f)        -> EIf(sp, substitute_expr(e, c, params, args), substitute_expr(e, t, params, args), substitute_expr(e, f, params, args))
    | EMatch(sp, scrut, arms) -> {
        var new_arms: Vec<ast.MatchArm> = vec.make()
        for a in arms { vec.push(&new_arms, ast.MatchArm { pat: a.pat, body: substitute_expr(e, a.body, params, args), has_guard: a.has_guard, guard: if a.has_guard { substitute_expr(e, a.guard, params, args) } else { a.guard } }) }
        EMatch(sp, substitute_expr(e, scrut, params, args), new_arms)
    }
    | EWhile(sp, c, b)        -> EWhile(sp, substitute_expr(e, c, params, args), substitute_expr(e, b, params, args))
    | EFor(sp, b1, b2, it, body) -> EFor(sp, b1, b2, substitute_expr(e, it, params, args), substitute_expr(e, body, params, args))
    | EReturn(sp, v)          -> EReturn(sp, substitute_expr(e, v, params, args))
    | EDefer(sp, v)           -> EDefer(sp, substitute_expr(e, v, params, args))
    | ESizeOf(sp, t)          -> ESizeOf(sp, substitute_type(e, t, params, args))
    | EArrayLit(sp, elems)    -> {
        var new_e: Vec<ast.Expr> = vec.make()
        for el in elems { vec.push(&new_e, substitute_expr(e, el, params, args)) }
        EArrayLit(sp, new_e)
    }
    }
}

let substitute_stmt(e: *Emitter, s: ast.Stmt, params: Vec<string>, args: Vec<ast.TypeExpr>): ast.Stmt = {
    match s {
    | SLet(sp, name, te, val)  -> SLet(sp, name, substitute_type(e, te, params, args), substitute_expr(e, val, params, args))
    | SVar(sp, name, te, val)  -> SVar(sp, name, substitute_type(e, te, params, args), substitute_expr(e, val, params, args))
    | SExpr(sp, x)             -> SExpr(sp, substitute_expr(e, x, params, args))
    }
}

let operator_first_param_type_name(te: ast.TypeExpr): string = {
    match te {
    | TEPtr(_, inner) -> {
        match inner {
        | TENamed(_, path, _) -> {
            if len(path) > 0 { return path[len(path) - 1] }
            ""
        }
        | _ -> ""
        }
    }
    | TENamed(_, path, _) -> {
        if len(path) > 0 { return path[len(path) - 1] }
        ""
    }
    | _ -> ""
    }
}

let register_variants(e: *Emitter, file: ast.File) = {
    // Prelude packages are always reachable from any file regardless
    // of explicit imports. Pre-populate the package set so qualified
    // calls produced by the container-builtin dispatch (vec.push,
    // map.insert, ...) resolve through the package path.
    e.packages["vec"]    = true
    e.packages["map"]    = true
    e.packages["option"] = true
    e.packages["result"] = true
    for d in file.decls {
        match d {
        | DEnum(_, name, _, variants) -> {
            e.is_enum[name] = true
            e.enum_decls[name] = d
            for v in variants {
                e.variant_of[v.name] = name
            }
        }
        | DCEnum(_, name, _, _) -> {
            e.c_enum_decls[name] = d
        }
        | DStruct(_, name, _, _) -> {
            e.struct_decls[name] = d
        }
        | DExternal(_, name, symbol, fps, ret) -> {
            e.externs[name] = symbol
            e.fn_returns[name] = ret
            var pts: Vec<ast.TypeExpr> = vec.make()
            for fp in fps { vec.push(&pts, fp.ty) }
            e.fn_params[name] = pts
        }
        | DFn(_, name, tparams, fps, ret, _, attr) -> {
            if len(tparams) == 0 {
                e.fn_returns[name] = ret
                var pts: Vec<ast.TypeExpr> = vec.make()
                for fp in fps { vec.push(&pts, fp.ty) }
                e.fn_params[name] = pts
            }
            if !strings.eq_raw(attr, "") {
                if len(fps) > 0 {
                    let tname = operator_first_param_type_name(fps[0].ty)
                    if !strings.eq_raw(tname, "") {
                        let key = strings.cat(strings.cat(attr, "::"), tname)
                        e.op_dispatch[key] = name
                    }
                }
            }
        }
        | DImport(_, ipath, alias) -> {
            var pkg = alias
            if strings.eq_raw(pkg, "") && len(ipath) > 0 {
                pkg = ipath[len(ipath) - 1]
            }
            if !strings.eq_raw(pkg, "") {
                e.packages[pkg] = true
            }
        }
        | DConst(_, name, _, _) -> {
            e.consts[name] = true
        }
        | _ -> { }
        }
    }
}

let strip_numeric_underscores(s: string): string = {
    var clean = s
    if strings.index_byte(s, 95) >= 0 {
        clean = ""
        var i: i64 = 0
        let n = len(s)
        while i < n {
            let c = strings.byte_at(s, i)
            if c != 95 {
                clean = strings.cat(clean, strings.slice(s, i, i + 1))
            }
            i += 1
        }
    }
    // C11 does not accept binary literals. Convert 0b... to decimal so
    // the emitted C compiles under -pedantic.
    if len(clean) >= 2 && strings.byte_at(clean, 0) == 48 {
        let c1 = strings.byte_at(clean, 1)
        if c1 == 98 || c1 == 66 {
            var v: i64 = 0
            var j: i64 = 2
            let m = len(clean)
            while j < m {
                let b = strings.byte_at(clean, j)
                if b == 48 || b == 49 {
                    v = v * 2 + (b - 48)
                    j += 1
                } else {
                    // Hit a non-binary suffix. Bail with original to surface a clang error.
                    return s
                }
            }
            return `{v}`
        }
    }
    clean
}

let push(e: *Emitter, s: string) = {
    strings.sb_append(&e.out, s)
}

let render(e: *Emitter): string = {
    let total = strings.sb_len(&e.out)
    if total == 0 { return "" }

    var typedef_block = ""
    for name in e.fn_typedef_order {
        if let Some(body) = map.get(&e.fn_typedefs, name) {
            typedef_block = strings.cat(typedef_block, body)
        }
    }
    if len(typedef_block) > 0 {
        typedef_block = strings.cat(typedef_block, "\n")
    }
    var synth_decl_block = ""
    for d in e.synth_fn_decls {
        synth_decl_block = strings.cat(synth_decl_block, d)
    }
    if len(synth_decl_block) > 0 {
        synth_decl_block = strings.cat(synth_decl_block, "\n")
    }
    var tuple_block = ""
    for tn in e.tuple_typedef_order {
        if let Some(body) = map.get(&e.tuple_typedefs, tn) {
            tuple_block = strings.cat(tuple_block, body)
        }
    }
    if len(tuple_block) > 0 {
        tuple_block = strings.cat(tuple_block, "\n")
    }

    // Splice the typedef and synth-fn blocks into the strbuf at the
    // recorded sentinel positions. Positions are monotonically
    // increasing (FN_TYPEDEFS <= TUPLE_TYPEDEFS <= SYNTH_FN_DECLS) by
    // construction in emit_program, so a single forward walk suffices.
    let p1 = e.pos_fn_typedefs
    let p2 = e.pos_tuple_typedefs
    let p3 = e.pos_synth_fn_decls
    var acc = ""
    acc = strings.cat(acc, strings.sb_slice_copy(&e.out, 0, p1))
    acc = strings.cat(acc, typedef_block)
    acc = strings.cat(acc, strings.sb_slice_copy(&e.out, p1, p2))
    acc = strings.cat(acc, tuple_block)
    acc = strings.cat(acc, strings.sb_slice_copy(&e.out, p2, p3))
    acc = strings.cat(acc, synth_decl_block)
    acc = strings.cat(acc, strings.sb_slice_copy(&e.out, p3, total))
    acc
}

let register_fn_typedef(e: *Emitter, params: Vec<ast.TypeExpr>, ret: ast.TypeExpr): string = {
    var name = "qoz_fn_"
    name = strings.cat(name, mangle_type(e, ret))
    for p in params {
        name = strings.cat(name, "__")
        name = strings.cat(name, mangle_type(e, p))
    }
    if !map.contains(&e.fn_typedefs, name) {
        // Closure ABI: every (T) -> R value is a {env, fn} pair. The fn's
        // first parameter is the captured environment (void* or NULL when
        // the value originated from a plain top-level function).
        var fn_field = c_type_for(e, ret)
        fn_field = strings.cat(fn_field, " (*fn)(void*")
        for p in params {
            fn_field = strings.cat(fn_field, ", ")
            fn_field = strings.cat(fn_field, c_type_for(e, p))
        }
        fn_field = strings.cat(fn_field, ")")
        var body = "typedef struct { void *env; "
        body = strings.cat(body, fn_field)
        body = strings.cat(body, "; } ")
        body = strings.cat(body, name)
        body = strings.cat(body, ";\n")
        e.fn_typedefs[name] = body
        vec.push(&e.fn_typedef_order, name)
    }
    name
}

let c_type_for(e: *Emitter, t: ast.TypeExpr): string = {
    match t {
    | TEUnit(_)                  -> "void"
    | TEPtr(_, inner)            -> strings.cat(c_type_for(e, inner), "*")
    | TETuple(_, elems)          -> register_tuple_typedef(e, elems)
    | TENamed(_, path, args)     -> c_type_for_named_with_args(e, path, args)
    | TEFn(_, params, ret)       -> register_fn_typedef(e, params, ret)
    }
}

let register_tuple_typedef(e: *Emitter, elems: Vec<ast.TypeExpr>): string = {
    var name = "qoz_tuple"
    for el in elems {
        name = strings.cat(name, "__")
        name = strings.cat(name, mangle_type(e, el))
    }
    if !map.contains(&e.tuple_typedefs, name) {
        var body = "typedef struct { "
        var i: i64 = 0
        for el in elems {
            body = strings.cat(body, c_type_for(e, el))
            body = strings.cat(body, " _")
            body = strings.cat(body, int_to_string(i))
            body = strings.cat(body, "; ")
            i += 1
        }
        body = strings.cat(body, "} ")
        body = strings.cat(body, name)
        body = strings.cat(body, ";\n")
        e.tuple_typedefs[name] = body
        vec.push(&e.tuple_typedef_order, name)
    }
    name
}

let c_type_for_named_with_args(e: *Emitter, path: Vec<string>, args: Vec<ast.TypeExpr>): string = {
    if len(path) == 0 {
        return "int64_t"
    }
    let n = path[len(path) - 1]
    let prim = primitive_c_name(n)
    if !strings.eq_raw(prim, "") { return prim }
    if strings.eq_raw(n, "cstring"){ return "const char *" }
    if strings.eq_raw(n, "void")   { return "void" }
    if strings.eq_raw(n, "unit")   { return "void" }
    // C-style enum lowers to its underlying primitive. The name
    // matters only to the type checker.
    match map.get(&e.c_enum_decls, n) {
    | Some(d) -> {
        match d {
        | DCEnum(_, _, underlying, _) -> return c_type_for(e, underlying)
        | _ -> { }
        }
    }
    | None -> { }
    }
    let base = if len(args) > 0 {
        strings.cat("qoz_", mangle_inst(e, n, args))
    } else {
        strings.cat("qoz_", n)
    }
    // ADTs are heap-allocated. Their C representation is a pointer.
    if map.contains(&e.is_enum, n) {
        return strings.cat(base, "*")
    }
    base
}

type CaptureScope = { bound: Map<string, bool> }

let collect_closure_captures(e: *Emitter, ex: ast.Expr, sc: *CaptureScope, out: *Vec<string>) = {
    match ex {
    | EInt(_, _) | EFloat(_, _) | EString(_, _) | EChar(_, _) | EBool(_, _)
    | ENil(_) | EPath(_, _) | ESizeOf(_, _) -> { }
    | EIdent(_, name) -> {
        if !map.contains(&sc.bound, name) {
            if map.contains(&e.locals, name) {
                vec.push(out, name)
            }
        }
    }
    | EUnary(_, _, sub)               -> collect_closure_captures(e, sub, sc, out)
    | EBinary(_, _, l, r)
    | EAssign(_, _, l, r) -> {
        collect_closure_captures(e, l, sc, out)
        collect_closure_captures(e, r, sc, out)
    }
    | ECall(_, callee, _, args)       -> { collect_closure_captures(e, callee, sc, out); for a in args { collect_closure_captures(e, a, sc, out) } }
    | EField(_, base, _)              -> collect_closure_captures(e, base, sc, out)
    | EIndex(_, base, idx)            -> { collect_closure_captures(e, base, sc, out); collect_closure_captures(e, idx, sc, out) }
    | ECast(_, v, _)
    | ETry(_, v)
    | EReturn(_, v)
    | EDefer(_, v)                    -> collect_closure_captures(e, v, sc, out)
    | ETuple(_, elems)
    | EArrayLit(_, elems)             -> { for el in elems { collect_closure_captures(e, el, sc, out) } }
    | ERecord(_, _, fields)           -> { for fl in fields { collect_closure_captures(e, fl.value, sc, out) } }
    | EClosure(_, _, _, _) -> { }
    | EBlock(_, stmts, tail) -> {
        for st in stmts {
            match st {
            | SLet(_, name, _, value) -> {
                collect_closure_captures(e, value, sc, out)
                sc.bound[name] = true
            }
            | SVar(_, name, _, value) -> {
                collect_closure_captures(e, value, sc, out)
                sc.bound[name] = true
            }
            | SExpr(_, expr)          -> collect_closure_captures(e, expr, sc, out)
            }
        }
        collect_closure_captures(e, tail, sc, out)
    }
    | EIf(_, c, t, f)         -> { collect_closure_captures(e, c, sc, out); collect_closure_captures(e, t, sc, out); collect_closure_captures(e, f, sc, out) }
    | EMatch(_, scrut, arms) -> {
        collect_closure_captures(e, scrut, sc, out)
        for arm in arms {
            collect_closure_captures(e, arm.body, sc, out)
        }
    }
    | EWhile(_, c, b)         -> { collect_closure_captures(e, c, sc, out); collect_closure_captures(e, b, sc, out) }
    | EFor(_, bn, bn2, it, b) -> {
        collect_closure_captures(e, it, sc, out)
        sc.bound[bn] = true
        if !strings.eq_raw(bn2, "") { sc.bound[bn2] = true }
        collect_closure_captures(e, b, sc, out)
    }
    }
}

let result_mangle_for(e: *Emitter, te: ast.TypeExpr): string = {
    match te {
    | TENamed(_, path, args) -> {
        if len(path) == 0 { return "" }
        let last = path[len(path) - 1]
        if !strings.eq_raw(last, "Result") { return "" }
        if len(args) != 2 { return "" }
        mangle_inst(e, "Result", args)
    }
    | _ -> ""
    }
}

let emit_try(e: *Emitter, sp: ast.Span, value: ast.Expr) = {
    let inner_te = infer_value_te(e, value)
    let outer_te = e.current_ret_te
    let inner_mangle = result_mangle_for(e, inner_te)
    let outer_mangle = result_mangle_for(e, outer_te)
    if strings.eq_raw(inner_mangle, "") {
        emit_die(sp, "try operator: operand is not Result<T, E>")
        return
    }
    if strings.eq_raw(outer_mangle, "") {
        emit_die(sp, "try operator: enclosing function does not return Result<T, E>")
        return
    }
    e.closure_counter = e.closure_counter + 1
    let tmp = strings.cat("_qoz_try_", `{e.closure_counter}`)

    // Build `qoz_<inner>* tmp = VALUE; if (tmp->tag == Err) {
    // qoz_gc_shadow_set_top(_g); return MAKE_ERR; }` as prologue,
    // then emit `tmp->payload.Ok.f0` in expression position.
    let start = strings.sb_len(&e.out)
    push(e, `qoz_{inner_mangle}* {tmp} = `)
    emit_expr(e, value)
    let crr = e.current_return_restore
    push(e, `; if ({tmp}->tag == qoz_{inner_mangle}_Err) {{ {crr}return qoz_make_{outer_mangle}_Err({tmp}->payload.Err.f0); }} `)
    hoist_to_prologue(e, start)

    push(e, `{tmp}->payload.Ok.f0`)
}

let emit_tuple_lit(e: *Emitter, sp: ast.Span, elems: Vec<ast.Expr>) = {
    var elem_tes: Vec<ast.TypeExpr> = vec.make()
    for el in elems { vec.push(&elem_tes, infer_value_te(e, el)) }
    let tname = register_tuple_typedef(e, elem_tes)
    push(e, `(({tname}){{ `)
    var i: i64 = 0
    for el in elems {
        if i > 0 { push(e, ", ") }
        emit_expr(e, el)
        i += 1
    }
    push(e, " })")
}

let emit_array_lit_with_hint(e: *Emitter, sp: ast.Span, elems: Vec<ast.Expr>, hint: ast.TypeExpr) = {
    var elem_hint: ast.TypeExpr = TEUnit(sp)
    match hint {
    | TENamed(_, path, args) -> {
        if len(path) > 0 && len(args) >= 1 {
            let last = path[len(path) - 1]
            if strings.eq_raw(last, "Vec") {
                elem_hint = args[0]
            }
        }
    }
    | _ -> { }
    }
    emit_array_lit_using(e, sp, elems, elem_hint)
}

let emit_array_lit_using(e: *Emitter, sp: ast.Span, elems: Vec<ast.Expr>, hint: ast.TypeExpr) = {
    if len(elems) == 0 && is_unit_typeexpr(hint) {
        emit_die(sp, "empty array literal: element type cannot be inferred")
        return
    }
    var elem_te: ast.TypeExpr = hint
    if is_unit_typeexpr(elem_te) {
        elem_te = infer_value_te(e, elems[0])
    }
    var elem_args: Vec<ast.TypeExpr> = vec.make()
    vec.push(&elem_args, elem_te)
    var pkg_path: Vec<string> = vec.make()
    vec.push(&pkg_path, "vec")
    let vec_callee_make: ast.Expr = EField(sp, EIdent(sp, "vec"), "make")
    let vec_callee_push: ast.Expr = EField(sp, EIdent(sp, "vec"), "push")
    register_fn_instantiation(e, vec_callee_make, elem_args)
    register_fn_instantiation(e, vec_callee_push, elem_args)
    var vec_path: Vec<string> = vec.make()
    vec.push(&vec_path, "Vec")
    walk_typeexpr(e, TENamed(sp, vec_path, elem_args))
    let make_mangled = mangle_inst(e, "vec_make", elem_args)
    let push_mangled = mangle_inst(e, "vec_push", elem_args)
    let vec_c = strings.cat("qoz_", mangle_inst(e, "Vec", elem_args))
    e.closure_counter = e.closure_counter + 1
    let tmp = strings.cat("_qoz_arr_", `{e.closure_counter}`)
    let start = strings.sb_len(&e.out)
    push(e, `{vec_c} {tmp} = qoz_{make_mangled}(); `)
    for el in elems {
        push(e, `qoz_{push_mangled}(&{tmp}, `)
        emit_expr(e, el)
        push(e, "); ")
    }
    hoist_to_prologue(e, start)
    push(e, tmp)
}

let emit_closure_lifted(e: *Emitter, sp: ast.Span, cps: Vec<ast.ClosureParam>, ret: ast.TypeExpr, body: ast.Expr) = {
    var sc: CaptureScope = CaptureScope { bound: map.make() }
    for cp in cps { sc.bound[cp.name] = true }
    var captures: Vec<string> = vec.make()
    collect_closure_captures(e, body, &sc, &captures)

    let counter = e.closure_counter
    e.closure_counter = e.closure_counter + 1
    let cname = strings.cat("qoz_clo_", `{counter}`)
    let env_struct = strings.cat("qoz_clo_env_", `{counter}`)

    var capture_tes: Vec<ast.TypeExpr> = vec.make()
    for c in captures {
        match map.get(&e.locals, c) {
        | Some(te) -> vec.push(&capture_tes, te)
        | None     -> vec.push(&capture_tes, TEUnit(sp))
        }
    }

    // Closure-type typedef for the value the closure produces.
    var ptes: Vec<ast.TypeExpr> = vec.make()
    for cp in cps { vec.push(&ptes, cp.ty) }
    let clo_type = register_fn_typedef(e, ptes, ret)

    var fparams: Vec<ast.FnParam> = vec.make()
    for cp in cps {
        vec.push(&fparams, ast.FnParam { name: cp.name, ty: cp.ty })
    }

    // Forward declaration of the lifted fn.
    var sig = "static "
    sig = strings.cat(sig, c_type_for(e, ret))
    sig = strings.cat(sig, " ")
    sig = strings.cat(sig, cname)
    sig = strings.cat(sig, "(void *_qoz_env")
    for fp in fparams {
        sig = strings.cat(sig, ", ")
        sig = strings.cat(sig, c_type_for(e, fp.ty))
        sig = strings.cat(sig, " ")
        sig = strings.cat(sig, fp.name)
    }
    sig = strings.cat(sig, ");\n")
    vec.push(&e.synth_fn_decls, sig)

    // Env struct (when captures exist).
    if len(captures) > 0 {
        var env_decl = "struct "
        env_decl = strings.cat(env_decl, env_struct)
        env_decl = strings.cat(env_decl, " { ")
        var ci: i64 = 0
        for c in captures {
            env_decl = strings.cat(env_decl, c_type_for(e, capture_tes[ci]))
            env_decl = strings.cat(env_decl, " ")
            env_decl = strings.cat(env_decl, c)
            env_decl = strings.cat(env_decl, "; ")
            ci += 1
        }
        env_decl = strings.cat(env_decl, "};\n")
        vec.push(&e.synth_fn_decls, env_decl)
    }

    // Emit the lifted function body at the end of `e.out`, then slice
    // it out into `def` and truncate `e.out` back to the entry length.
    let saved_start = strings.sb_len(&e.out)
    let saved_locals = e.locals
    let saved_ret = e.current_ret_te
    let saved_hint = e.match_hint
    let ret_c = c_type_for(e, ret)
    push(e, `static {ret_c} {cname}(void *_qoz_env`)
    for fp in fparams {
        let fp_c = c_type_for(e, fp.ty)
        let fp_n = fp.name
        push(e, `, {fp_c} {fp_n}`)
    }
    push(e, ") {\n    ")
    e.locals = map.make()
    for fp in fparams { e.locals[fp.name] = fp.ty }
    if len(captures) > 0 {
        push(e, `struct {env_struct} *_env = (struct {env_struct} *)_qoz_env;\n    `)
        var ci2: i64 = 0
        for c in captures {
            let c_c = c_type_for(e, capture_tes[ci2])
            push(e, `{c_c} {c} = _env->{c};\n    `)
            e.locals[c] = capture_tes[ci2]
            ci2 += 1
        }
    }
    e.current_ret_te = ret
    if is_block(body) {
        emit_fn_body_block(e, body, ret)
    } else {
        let saved = open_statement_scope(e)
        if is_unit_typeexpr(ret) {
            emit_expr(e, body)
            push(e, ";\n    return;\n")
        } else {
            push(e, "return ")
            emit_value_with_hint(e, body, ret)
            push(e, ";\n")
        }
        close_statement_scope(e, saved)
    }
    push(e, "}\n\n")
    let def = strings.sb_slice_copy(&e.out, saved_start, strings.sb_len(&e.out))
    strings.sb_truncate(&e.out, saved_start)
    e.locals = saved_locals
    e.current_ret_te = saved_ret
    e.match_hint = saved_hint
    vec.push(&e.synth_fn_defs, def)

    // Now emit the closure value at the call site:
    //   ((qoz_fn_...){ .env = NULL, .fn = cname })
    //  with captures:
    //   ((qoz_fn_...){ .env = ({ struct qoz_clo_env_N *e = qoz_alloc(sizeof *e); e->cap1 = cap1; ...; (void *)e; }), .fn = cname })
    push(e, `(({clo_type}){{ .env = `)
    if len(captures) == 0 {
        push(e, "NULL")
    } else {
        // Hoist the env alloc and field stores into a prologue. The
        // expression position becomes `(void*)_e_<counter>`.
        let env_local = strings.cat("_qoz_env_", `{counter}`)
        let start = strings.sb_len(&e.out)
        push(e, `struct {env_struct} *{env_local} = qoz_alloc(sizeof(struct {env_struct})); `)
        for c in captures {
            push(e, `{env_local}->{c} = {c}; `)
        }
        hoist_to_prologue(e, start)
        push(e, `(void *){env_local}`)
    }
    push(e, `, .fn = {cname} }})`)
}

let emit_expr(e: *Emitter, ex: ast.Expr) = {
    match ex {
    | EInt(_, text)     -> push(e, strip_numeric_underscores(text))
    | EFloat(_, text)   -> push(e, strip_numeric_underscores(text))
    | EBool(_, v)       -> push(e, if v { "true" } else { "false" })
    | ENil(_)           -> push(e, "NULL")
    | EIdent(_, name)   -> {
        match map.get(&e.variant_of, name) {
        | Some(enum_name) -> {
            push(e, `qoz_make_{enum_name}_{name}()`)
        }
        | None -> {
            if map.contains(&e.consts, name) {
                push(e, `qoz_{name}()`)
            } else {
                push(e, name)
            }
        }
        }
    }
    | EString(_, text)  -> push(e, `QOZ_STR_LIT({text})`)
    | EBinary(_, op, lhs, rhs) -> emit_binary(e, op, lhs, rhs)
    | EUnary(_, op, rhs) -> {
        // Operator-overload dispatch: `-pair`, `!pair`, etc. fall back
        // to the user-registered `@operator(\"unary-\")` function when
        // the operand is a record type. Other operands take the C
        // unary form below.
        let op_text = unary_op_text(op)
        if !strings.eq_raw(op_text, "") {
            let rhs_te = infer_value_te(e, rhs)
            let tname = operator_first_param_type_name(rhs_te)
            if !strings.eq_raw(tname, "") {
                let key = strings.cat(strings.cat(op_text, "::"), tname)
                if let Some(fn_name) = map.get(&e.op_dispatch, key) {
                    let ct = c_type_for(e, rhs_te)
                    let ret_te = match map.get(&e.fn_returns, fn_name) {
                    | Some(t) -> t
                    | None    -> {
                        let _ = emit_die(span_of_expr(rhs), `operator '{op_text}' for '{tname}' has no recorded return type`)
                        TEUnit(span_of_expr(rhs))
                    }
                    }
                    let ret_ct = c_type_for(e, ret_te)
                    ensure_unary_byval_dispatch_helper(e, fn_name, ct, ret_ct)
                    push(e, `_qoz_byval_{fn_name}(`)
                    emit_expr(e, rhs)
                    push(e, ")")
                    return
                }
            }
        }
        push(e, unary_c_op(op))
        // Parenthesise the operand when omitting parens would change
        // the C parse. A binary operand needs parens so `!(a == b)`
        // does not become `!a == b`. A unary operand needs them so
        // `-(-x)` and `!(!x)` do not collapse to `--x` / `!!x` which
        // clang reads as predecrement / nested logical-not (the
        // latter is harmless but the former is not).
        match rhs {
        | EBinary(_, _, _, _) | EUnary(_, _, _) | EAssign(_, _, _, _) | ECast(_, _, _) -> {
            push(e, "(")
            emit_expr(e, rhs)
            push(e, ")")
        }
        | _ -> emit_expr(e, rhs)
        }
    }
    | EReturn(_, value) -> {
        if is_nil_expr(value) {
            push(e, "return")
        } else {
            push(e, "return ")
            emit_value_with_hint(e, value, e.current_ret_te)
        }
    }
    | EBlock(sp, stmts, tail) -> {
        if len(stmts) == 0 {
            emit_block_tail_as_value(e, tail)
            return
        }
        // A statement-shape tail (for, while, assign, defer, return)
        // contributes no value. Hoist the block as a void compound and
        // leave a placeholder 0 in the expression position so the
        // surrounding context still has a syntactic value.
        match tail {
        | EWhile(_, _, _) | EFor(_, _, _, _, _) | EAssign(_, _, _, _) | EDefer(_, _) | EReturn(_, _) -> {
            let start_s = strings.sb_len(&e.out)
            push(e, "{\n        ")
            for s in stmts { emit_stmt(e, s) }
            let saved = open_statement_scope(e)
            emit_stmt_expr(e, tail)
            close_statement_scope(e, saved)
            push(e, "\n    }\n    ")
            hoist_to_prologue(e, start_s)
            push(e, "0")
            return
        }
        | _ -> { }
        }
        // Hoist the block into a fresh C compound and a result temp.
        // The compound runs at the enclosing statement's prologue and
        // the expression position reads the result temp. A unit-typed
        // tail skips the result temp because `void` cannot be a C
        // variable type. The placeholder 0 sits in the expression slot
        // and the tail emits as a statement.
        let tail_te = infer_value_te(e, tail)
        if is_unit_typeexpr(tail_te) {
            let start_u = strings.sb_len(&e.out)
            push(e, "{\n        ")
            for s in stmts { emit_stmt(e, s) }
            let saved_tail = open_statement_scope(e)
            emit_stmt_expr(e, tail)
            close_statement_scope(e, saved_tail)
            push(e, "\n    }\n    ")
            hoist_to_prologue(e, start_u)
            push(e, "0")
            return
        }
        e.closure_counter = e.closure_counter + 1
        let counter = e.closure_counter
        let tmp_res = strings.cat("_qoz_bv_", `{counter}`)
        let result_c = c_type_for(e, tail_te)
        let start = strings.sb_len(&e.out)
        push(e, `{result_c} {tmp_res};\n    {{\n        `)
        for s in stmts { emit_stmt(e, s) }
        let saved_inner = open_statement_scope(e)
        push(e, `{tmp_res} = `)
        emit_expr(e, tail)
        push(e, ";\n    ")
        close_statement_scope(e, saved_inner)
        push(e, "}\n    ")
        hoist_to_prologue(e, start)
        push(e, tmp_res)
    }
    | EChar(_, text)               -> push(e, text)
    | EPath(sp, _)                 -> { let _ = emit_die(sp, "path expression in value position; only Enum::Variant in call position is supported") }
    | EAssign(sp, op, lhs, rhs)    -> {
        assert_plain_assign(op, sp)
        emit_assign(e, lhs, rhs)
    }
    | ECall(_, callee, ta, args)   -> emit_call(e, callee, ta, args)
    | EField(_, base, name)        -> emit_field(e, base, name)
    | EIndex(_, base, idx)         -> emit_index(e, base, idx)
    | ECast(_, value, t)           -> {
        let tc = c_type_for(e, t)
        push(e, `(({tc})`)
        emit_expr(e, value)
        push(e, ")")
    }
    | ETry(sp, value)              -> emit_try(e, sp, value)
    | ETuple(sp, elems)            -> emit_tuple_lit(e, sp, elems)
    | ERecord(_, te, fields)       -> emit_record_lit_with_hint(e, te, fields, te)
    | EClosure(sp, cps, ret, body) -> emit_closure_lifted(e, sp, cps, ret, body)
    | EIf(sp, c, t, f)             -> {
        // Bare `if` with no else parses with a nil else branch. A nil
        // ternary arm forces clang to pick a type which usually fails;
        // reject the value-position use and direct the user to a
        // statement-position pattern instead.
        if is_nil_expr(f) {
            let _ = emit_die(sp, "if without else cannot appear in value position; wrap in a block or add an else branch")
        }
        push(e, "(")
        emit_expr(e, c)
        push(e, " ? ")
        emit_expr(e, t)
        push(e, " : ")
        emit_expr(e, f)
        push(e, ")")
    }
    | EMatch(span, scrut, arms)    -> {
        let saved = e.match_hint
        e.match_hint = TEUnit(ast.Span { file: "", line: 0, col: 0 })
        emit_match_as_expr(e, span, scrut, arms)
        e.match_hint = saved
    }
    | EWhile(sp, _, _)             -> { let _ = emit_die(sp, "while expression in value position; wrap in a block or use a tail expression") }
    | EFor(sp, _, _, _, _)         -> { let _ = emit_die(sp, "for expression in value position; wrap in a block or use a tail expression") }
    | EDefer(sp, _)                -> { let _ = emit_die(sp, "defer cannot appear in value position; use defer as a statement") }
    | ESizeOf(_, te)               -> { let tc = c_type_for(e, te); push(e, `(int64_t)sizeof({tc})`) }
    | EArrayLit(sp, elems)         -> {
        // Use the check phase's recorded type for this expression
        // as the hint, so an empty `[]` whose surrounding context
        // pinned a Vec<T> annotation still resolves.
        let recorded = match map.get(&e.expr_types, expr_id(ex)) {
        | Some(te) -> te
        | None     -> TEUnit(sp)
        }
        emit_array_lit_using(e, sp, elems, recorded)
    }
    }
}

let infer_value_ctype(e: *Emitter, ty: ast.TypeExpr, value: ast.Expr): string = {
    match ty {
    | TEUnit(_) -> c_type_for(e, binding_te(e, ty, value))
    | _         -> c_type_for(e, ty)
    }
}

// Statements have no value type in C. Everything else delegates to
// the TypeExpr inferer plus c_type_for. EBlock ingests stmt locals so
// downstream lookups see the bindings the block introduces.
let infer_expr_ctype(e: *Emitter, ex: ast.Expr): string = {
    match ex {
    | EAssign(_, _, _, _) | EReturn(_, _) | EWhile(_, _, _) | EFor(_, _, _, _, _) | EDefer(_, _) -> "void"
    | EBlock(_, stmts, tail) -> {
        for s in stmts { ingest_stmt_locals(e, s) }
        if is_nil_expr(tail) { return "void" }
        infer_expr_ctype(e, tail)
    }
    | EMatch(sp, scrut, arms) -> {
        if len(arms) == 0 { emit_die(sp, "match expression with no arms") }
        let bare_enum = bare_enum_for_pat(e, arms[0].pat)
        let enum_name = if strings.eq_raw(bare_enum, "") { bare_enum } else { enum_lookup_name(e, scrut, bare_enum) }
        bind_arm_locals(e, enum_name, arms[0].pat)
        infer_expr_ctype(e, arms[0].body)
    }
    | EPath(sp, _) -> emit_die(sp, "EPath in value position is not supported")
    | _ -> c_type_for(e, infer_value_te(e, ex))
    }
}

let ingest_stmt_locals(e: *Emitter, s: ast.Stmt) = {
    match s {
    | SLet(_, name, te, val) -> e.locals[name] = binding_te(e, te, val)
    | SVar(_, name, te, val) -> e.locals[name] = binding_te(e, te, val)
    | SExpr(_, _) -> { }
    }
}

let bare_enum_for_pat(e: *Emitter, pat: ast.Pattern): string = {
    match pat {
    | PatVariant(_, path, _) -> {
        if len(path) == 0 { return "" }
        match map.get(&e.variant_of, path[len(path) - 1]) {
        | Some(en) -> en
        | None     -> ""
        }
    }
    | PatBind(_, name) -> {
        match map.get(&e.variant_of, name) {
        | Some(en) -> en
        | None     -> ""
        }
    }
    | _ -> ""
    }
}

// Hard fail with a span-anchored diagnostic. Used wherever the emit
// cannot continue with a meaningful default. Every silent fallback to
// "int64_t" is a bug.
let emit_die(sp: ast.Span, msg: string): string = {
    fmt.println(`{sp.file}:{sp.line}:{sp.col}: emit error: {msg}`)
    os.exit(1)
    ""
}

// Compound assignment forms (+=, -=, *=, /=, %=) are desugared at
// parse time to `lhs = lhs <bin> rhs`. The emitter only handles plain
// assignment. This guard catches a future parser regression where a
// compound op reaches the emit phase instead of being desugared.
let assert_plain_assign(op: ast.AssignOp, sp: ast.Span) = {
    match op {
    | AOpSet -> { }
    | _      -> { let _ = emit_die(sp, "internal: compound assignment reached emit; parse should have desugared it") }
    }
}

let infer_base_typeexpr(e: *Emitter, base: ast.Expr): ast.TypeExpr = {
    match base {
    | EIdent(sp, ident) -> {
        match map.get(&e.locals, ident) {
        | Some(te) -> te
        | None -> {
            match map.get(&e.variant_of, ident) {
            | Some(en) -> {
                var path: Vec<string> = vec.make()
                vec.push(&path, en)
                TENamed(sp, path, vec.make())
            }
            | None -> {
                let _ = emit_die(sp, `identifier '{ident}' has no known ast.TypeExpr (not a local, parameter, or variant)`)
                TEUnit(sp)
            }
            }
        }
        }
    }
    | EField(sp, b, n) -> {
        let bte = infer_base_typeexpr(e, b)
        field_typeexpr_for(e, bte, n, sp)
    }
    | EUnary(sp, op, rhs) -> {
        match op {
        | UOpDeref -> {
            let inner = infer_base_typeexpr(e, rhs)
            match inner {
            | TEPtr(_, t) -> t
            | _           -> {
                let _ = emit_die(sp, "dereference of non-pointer base in EField/EIndex")
                TEUnit(sp)
            }
            }
        }
        | UOpAddr -> TEPtr(sp, infer_base_typeexpr(e, rhs))
        | _       -> {
            let _ = emit_die(sp, "unary operator does not yield a base ast.TypeExpr")
            TEUnit(sp)
        }
        }
    }
    | ECall(sp, c, ta, va) -> call_return_te(e, c, ta, va, sp)
    | ECast(_, _, t) -> t
    | ERecord(_, t, _) -> t
    | EIndex(sp, b, _) -> {
        let bte = infer_base_typeexpr(e, b)
        match bte {
        | TEPtr(_, inner) -> inner
        | TENamed(_, path, args) -> {
            if len(args) >= 1 && len(path) >= 1 && strings.eq_raw(path[len(path) - 1], "Vec") { return args[0] }
            let _ = emit_die(sp, "indexing into non-Vec/non-pointer base")
            TEUnit(sp)
        }
        | _ -> {
            let _ = emit_die(sp, "indexing into unrecognised base")
            TEUnit(sp)
        }
        }
    }
    | _ -> {
        let _ = emit_die(span_of_expr(base), "base expression has no resolvable ast.TypeExpr")
        TEUnit(span_of_expr(base))
    }
    }
}

let span_of_expr(e: ast.Expr): ast.Span = {
    match e {
    | ENil(sp)
    | EInt(sp, _) | EFloat(sp, _) | EString(sp, _) | EChar(sp, _) | EBool(sp, _)
    | EIdent(sp, _) | EPath(sp, _) | EReturn(sp, _) | EDefer(sp, _) | ESizeOf(sp, _)
    | EArrayLit(sp, _) | ETry(sp, _) | ETuple(sp, _)
    | EUnary(sp, _, _) | EField(sp, _, _) | EIndex(sp, _, _) | ECast(sp, _, _)
    | ERecord(sp, _, _) | EBlock(sp, _, _) | EWhile(sp, _, _) | EMatch(sp, _, _)
    | EBinary(sp, _, _, _) | EAssign(sp, _, _, _) | ECall(sp, _, _, _)
    | EIf(sp, _, _, _) | EClosure(sp, _, _, _)
    | EFor(sp, _, _, _, _) -> sp
    }
}

let field_typeexpr_for(e: *Emitter, base_te: ast.TypeExpr, field: string, sp: ast.Span): ast.TypeExpr = {
    let unwrapped = match base_te {
        | TEPtr(_, inner) -> inner
        | _               -> base_te
    }
    match unwrapped {
    | TENamed(_, path, args) -> {
        if len(path) < 1 {
            let _ = emit_die(sp, `field access '.{field}' on ast.TypeExpr with empty path`)
            return TEUnit(sp)
        }
        let lookup = type_lookup_key(e, path)
        let decl_opt = match map.get(&e.generic_decls, lookup) {
            | Some(d) -> Some(d)
            | None    -> map.get(&e.struct_decls, lookup)
        }
        match decl_opt {
        | Some(decl) -> {
            match decl {
            | DStruct(_, _, params, fields) -> {
                for f in fields {
                    if strings.eq_raw(f.name, field) {
                        if len(args) == len(params) {
                            return substitute_type(e, f.ty, params, args)
                        }
                        return f.ty
                    }
                }
                let _ = emit_die(sp, `struct '{lookup}' has no field '{field}'`)
                TEUnit(sp)
            }
            | _ -> {
                let _ = emit_die(sp, `decl '{lookup}' is not a struct`)
                TEUnit(sp)
            }
            }
        }
        | None -> {
            let _ = emit_die(sp, `unknown struct '{lookup}' for field '.{field}'`)
            TEUnit(sp)
        }
        }
    }
    | TETuple(_, elems) -> {
        let idx = tuple_field_index(field)
        if idx >= 0 && idx < len(elems) { return elems[idx] }
        let _ = emit_die(sp, `tuple has no field '.{field}'`)
        TEUnit(sp)
    }
    | _ -> {
        let _ = emit_die(sp, `field access '.{field}' on a non-named base`)
        TEUnit(sp)
    }
    }
}

let tuple_field_index(field: string): i64 = {
    if len(field) < 2 { return -1 }
    if strings.byte_at(field, 0) != 95 { return -1 }
    var n: i64 = 0
    var i: i64 = 1
    while i < len(field) {
        let b = strings.byte_at(field, i)
        if b < 48 || b > 57 { return -1 }
        n = n * 10 + (b - 48)
        i += 1
    }
    n
}

let span_of_te(te: ast.TypeExpr): ast.Span = {
    match te {
    | TEUnit(sp)
    | TEPtr(sp, _) | TETuple(sp, _)
    | TENamed(sp, _, _) | TEFn(sp, _, _) -> sp
    }
}

// Pick the TypeExpr to record in locals for a let/var binding. When the
// declared annotation is TEUnit ("no annotation"), derive from the value
// expression's structural shape so downstream emits (field access,
// indexing, match) know what they're looking at.
let binding_te(e: *Emitter, declared: ast.TypeExpr, value: ast.Expr): ast.TypeExpr = {
    match declared {
    | TEUnit(_) -> infer_value_te(e, value)
    | _         -> declared
    }
}

// Stable Expr identity for cache lookup. Matches check.expr_id.
let expr_id(e: ast.Expr): i64 = (e as *void) as i64

// Pick the better TypeExpr for an ERecord: prefer the check-phase
// cached TypeExpr when it includes the struct's type arguments, fall
// back to the literal's annotation otherwise.
let prefer_typed_record(e: *Emitter, lit: ast.TypeExpr, cached: ast.TypeExpr): ast.TypeExpr = {
    let cached_args = type_args_of(cached)
    let lit_args    = type_args_of(lit)
    if len(cached_args) > len(lit_args) { return cached }
    lit
}

let type_args_of(te: ast.TypeExpr): Vec<ast.TypeExpr> = {
    let empty: Vec<ast.TypeExpr> = vec.make()
    match te {
    | TENamed(_, _, args) -> args
    | _                   -> empty
    }
}

// Look up the type recorded for `v` by the check phase. Falls back to
// structural inference when no entry exists (synthesised exprs). The
// active generic-instantiation substitution is applied to the result
// so type-parameter names resolve to their bound types.

let infer_value_te_cached(e: *Emitter, v: ast.Expr): ast.TypeExpr = {
    match map.get(&e.expr_types, expr_id(v)) {
    | Some(te) -> {
        if len(e.current_tparams) > 0 {
            substitute_type(e, te, e.current_tparams, e.current_targs)
        } else {
            te
        }
    }
    | None -> infer_value_te(e, v)
    }
}

let infer_value_te(e: *Emitter, v: ast.Expr): ast.TypeExpr = {
    match v {
    | ECast(_, _, t) -> t
    | ERecord(_, t, _) -> {
        // The literal's TypeExpr may omit the struct's type arguments
        // (`Pair { fst: 7, snd: "hello" }` has te = TENamed("Pair", [])).
        // The check phase recorded the fully-inferred type in
        // expr_types. Prefer that when its arg count matches the
        // struct's tparam count.
        let cached = match map.get(&e.expr_types, expr_id(v)) {
        | Some(cte) -> cte
        | None      -> t
        }
        prefer_typed_record(e, t, cached)
    }
    | EField(sp, base, name) -> {
        // `EnumName.Variant` for a C-style enum lifts to the enum's
        // own TypeExpr. The base is either the renamed enum name
        // or the qualified form `pkg.EnumShort`. Detect both before
        // infer_base_typeexpr tries to look up the enum name as a
        // local and dies.
        let enum_lookup = match base {
        | EIdent(_, enum_name) -> enum_name
        | EField(_, inner, enum_short) -> {
            match inner {
            | EIdent(_, pkg) -> strings.cat(strings.cat(pkg, "_"), enum_short)
            | _              -> ""
            }
        }
        | _ -> ""
        }
        if !strings.eq_raw(enum_lookup, "") {
            if map.contains(&e.c_enum_decls, enum_lookup) {
                return single_named_te(sp, enum_lookup)
            }
        }
        field_typeexpr_for(e, infer_base_typeexpr(e, base), name, sp)
    }
    | EIndex(sp, base, _) -> {
        let bte = infer_base_typeexpr(e, base)
        match bte {
        | TEPtr(_, inner) -> inner
        | TENamed(_, path, args) -> {
            if len(args) >= 1 && len(path) >= 1 && strings.eq_raw(path[len(path) - 1], "Vec") { return args[0] }
            let _ = emit_die(sp, "let-binding value indexed into non-Vec base; cannot determine binding type")
            TEUnit(sp)
        }
        | _ -> {
            let _ = emit_die(sp, "let-binding value indexed into unrecognised base")
            TEUnit(sp)
        }
        }
    }
    | EIdent(sp, name) -> {
        match map.get(&e.locals, name) {
        | Some(t) -> t
        | None -> {
            // A bare identifier that is not a local may be a
            // nullary variant constructor used in scrutinee or arg
            // position. Return the owning enum's TypeExpr so the
            // match dispatcher can recognise it.
            match map.get(&e.variant_of, name) {
            | Some(en) -> single_named_te(sp, en)
            | None     -> {
                let _ = emit_die(sp, `let-binding value references unknown name '{name}'`)
                TEUnit(sp)
            }
            }
        }
        }
    }
    | ECall(sp, callee, type_args, vargs) -> call_return_te(e, callee, type_args, vargs, sp)
    | EInt(sp, _)    -> single_named_te(sp, "i64")
    | EFloat(sp, _)  -> single_named_te(sp, "f64")
    | EString(sp, _) -> single_named_te(sp, "string")
    | EBool(sp, _)   -> single_named_te(sp, "bool")
    | EChar(sp, _)   -> single_named_te(sp, "char")
    | ENil(sp)       -> TEPtr(sp, single_named_te(sp, "void"))
    | EUnary(sp, op, rhs) -> {
        match op {
        | UOpAddr -> TEPtr(sp, infer_value_te(e, rhs))
        | UOpDeref -> {
            let inner = infer_value_te(e, rhs)
            match inner {
            | TEPtr(_, t) -> t
            | _           -> {
                let _ = emit_die(sp, "let-binding dereferences a non-pointer")
                TEUnit(sp)
            }
            }
        }
        | UOpNot -> single_named_te(sp, "bool")
        | UOpNeg -> infer_value_te(e, rhs)
        }
    }
    | EBinary(sp, op, l, _) -> {
        match op {
        | BOpEq -> single_named_te(sp, "bool")
        | BOpNe -> single_named_te(sp, "bool")
        | BOpLt -> single_named_te(sp, "bool")
        | BOpGt -> single_named_te(sp, "bool")
        | BOpLe -> single_named_te(sp, "bool")
        | BOpGe -> single_named_te(sp, "bool")
        | BOpAnd -> single_named_te(sp, "bool")
        | BOpOr -> single_named_te(sp, "bool")
        | _ -> infer_value_te(e, l)
        }
    }
    | EBlock(_, stmts, tail) -> {
        for s in stmts { ingest_stmt_locals(e, s) }
        infer_value_te(e, tail)
    }
    | EIf(_, _, t, _) -> infer_value_te(e, t)
    | EMatch(sp, scrut, arms) -> {
        if len(arms) == 0 {
            let _ = emit_die(sp, "match expression with no arms")
            return TEUnit(sp)
        }
        let bare_enum = find_enum_from_arms_with_scrut(e, arms, infer_value_te(e, scrut))
        let enum_name = if strings.eq_raw(bare_enum, "") { bare_enum } else { enum_lookup_name(e, scrut, bare_enum) }
        bind_arm_locals(e, enum_name, arms[0].pat)
        infer_value_te(e, arms[0].body)
    }
    | ESizeOf(sp, _) -> single_named_te(sp, "i64")
    | ETuple(sp, elems) -> {
        var ets: Vec<ast.TypeExpr> = vec.make()
        for el in elems { vec.push(&ets, infer_value_te(e, el)) }
        TETuple(sp, ets)
    }
    | EClosure(sp, cps, ret, _) -> {
        var pte: Vec<ast.TypeExpr> = vec.make()
        for cp in cps { vec.push(&pte, cp.ty) }
        TEFn(sp, pte, ret)
    }
    | ETry(sp, value) -> {
        let inner = infer_value_te(e, value)
        match inner {
        | TENamed(_, path, args) -> {
            if len(args) == 2 {
                if len(path) > 0 {
                    let last = path[len(path) - 1]
                    if strings.eq_raw(last, "Result") {
                        return args[0]
                    }
                }
            }
            inner
        }
        | _ -> inner
        }
    }
    | EArrayLit(sp, elems) -> {
        if len(elems) == 0 {
            let _ = emit_die(sp, "empty array literal: element type cannot be inferred")
            return TEUnit(sp)
        }
        let elem_te = infer_value_te(e, elems[0])
        var args: Vec<ast.TypeExpr> = vec.make()
        vec.push(&args, elem_te)
        var path: Vec<string> = vec.make()
        vec.push(&path, "Vec")
        TENamed(sp, path, args)
    }
    // Statement-shape expressions have no value type. They occur in
    // value position when an outer block ends with one. The inferred
    // type is unit and the emitter renders them as statements with a
    // dummy 0 placeholder where a value is syntactically required.
    | EAssign(sp, _, _, _) -> TEUnit(sp)
    | EWhile(sp, _, _)     -> TEUnit(sp)
    | EFor(sp, _, _, _, _) -> TEUnit(sp)
    | EReturn(sp, _)       -> TEUnit(sp)
    | EDefer(sp, _)        -> TEUnit(sp)
    | EPath(sp, _) -> {
        let _ = emit_die(sp, "EPath in value position is not supported (expected pkg.fn or a record name)")
        TEUnit(sp)
    }
    | _ -> {
        let _ = emit_die(span_of_expr(v), "let-binding value shape not handled by inference")
        TEUnit(span_of_expr(v))
    }
    }
}

let single_named_te(sp: ast.Span, name: string): ast.TypeExpr = {
    var path: Vec<string> = vec.make()
    vec.push(&path, name)
    TENamed(sp, path, vec.make())
}

// Walk-time variant type-arg inference. Same shape as
// infer_variant_type_args but uses literal_typeexpr instead of
// infer_value_te so it works before locals are bound. Returns an
// empty Vec when any argument is not a literal whose type is known.
let literal_variant_type_args(e: *Emitter, enum_name: string, variant: string, args: Vec<ast.Expr>, sp: ast.Span): Vec<ast.TypeExpr> = {
    var out: Vec<ast.TypeExpr> = vec.make()
    let empty: Vec<ast.TypeExpr> = vec.make()
    match map.get(&e.enum_decls, enum_name) {
    | None -> empty
    | Some(d) -> {
        match d {
        | DEnum(_, _, tparams, variants) -> {
            if len(tparams) == 0 { return empty }
            var bindings: Map<string, ast.TypeExpr> = map.make()
            var resolved_all = true
            for v in variants {
                if strings.eq_raw(v.name, variant) {
                    var i: i64 = 0
                    for pos_te in v.pos {
                        if i < len(args) {
                            match literal_typeexpr(args[i]) {
                            | Some(arg_te) -> unify_te(pos_te, arg_te, &bindings)
                            | None         -> resolved_all = false
                            }
                        }
                        i += 1
                    }
                }
            }
            if !resolved_all { return empty }
            for tp in tparams {
                match map.get(&bindings, tp) {
                | Some(t) -> vec.push(&out, t)
                | None    -> { }
                }
            }
            if len(out) != len(tparams) { return empty }
            out
        }
        | _ -> empty
        }
    }
    }
}

// Unify the variant's declared positional TypeExprs (which may contain
// bare type-parameter names) with the actual value-argument TypeExprs.
// Returns the resolved per-tparam Vec<TypeExpr> in the enum's declared
// tparam order.
let infer_variant_type_args(e: *Emitter, enum_name: string, variant: string, args: Vec<ast.Expr>, sp: ast.Span): Vec<ast.TypeExpr> = {
    var out: Vec<ast.TypeExpr> = vec.make()
    match map.get(&e.enum_decls, enum_name) {
    | None -> out
    | Some(d) -> {
        match d {
        | DEnum(_, _, tparams, variants) -> {
            if len(tparams) == 0 { return out }
            var bindings: Map<string, ast.TypeExpr> = map.make()
            for v in variants {
                if strings.eq_raw(v.name, variant) {
                    var i: i64 = 0
                    for pos_te in v.pos {
                        if i < len(args) {
                            let arg_te = infer_value_te(e, args[i])
                            unify_te(pos_te, arg_te, &bindings)
                        }
                        i += 1
                    }
                }
            }
            for tp in tparams {
                match map.get(&bindings, tp) {
                | Some(t) -> vec.push(&out, t)
                | None    -> vec.push(&out, single_named_te(sp, "i64"))
                }
            }
            out
        }
        | _ -> out
        }
    }
    }
}

// Match a pattern TypeExpr against a concrete TypeExpr, accumulating
// per-tparam bindings. Bare TENamed names with single-segment path are
// treated as type-parameter variables.
let unify_te(pattern: ast.TypeExpr, concrete: ast.TypeExpr, env: *Map<string, ast.TypeExpr>) = {
    match pattern {
    | TENamed(_, path, p_args) -> {
        if len(path) == 1 && len(p_args) == 0 {
            let n = path[0]
            if is_type_var_name(n) {
                if !map.contains(env, n) { map.set(env, n, concrete) }
                return
            }
        }
        match concrete {
        | TENamed(_, c_path, c_args) -> {
            if len(p_args) == len(c_args) {
                var i: i64 = 0
                while i < len(p_args) {
                    unify_te(p_args[i], c_args[i], env)
                    i += 1
                }
            }
        }
        | _ -> { }
        }
    }
    | TEPtr(_, p_inner) -> {
        match concrete {
        | TEPtr(_, c_inner) -> unify_te(p_inner, c_inner, env)
        | _ -> { }
        }
    }
    | _ -> { }
    }
}

let is_type_var_name(n: string): bool = {
    if len(n) == 0 { return false }
    if len(n) > 2 { return false }
    let c = strings.byte_at(n, 0)
    c >= 65 && c <= 90
}

let call_return_te(e: *Emitter, callee: ast.Expr, type_args: Vec<ast.TypeExpr>, args: Vec<ast.Expr>, sp: ast.Span): ast.TypeExpr = {
    let name = generic_callee_name(e, callee)
    if strings.eq_raw(name, "") {
        let _ = emit_die(sp, "could not derive return type: callee has no recognisable name")
        return TEUnit(sp)
    }
    // Built-ins.
    if strings.eq_raw(name, "len")     { return single_named_te(sp, "i64") }
    if strings.eq_raw(name, "size_of") { return single_named_te(sp, "i64") }
    if strings.eq_raw(name, "hash")    { return single_named_te(sp, "u64") }
    if strings.has_prefix(name, "__qoz_interp_") {
        if strings.eq_raw(name, "__qoz_interp_init") {
            var vp: Vec<string> = vec.make()
            vec.push(&vp, "void")
            return TEPtr(sp, TENamed(sp, vp, vec.make()))
        }
        if strings.eq_raw(name, "__qoz_interp_finish") {
            return single_named_te(sp, "string")
        }
        return TEUnit(sp)
    }
    // Variant constructor. If no explicit type args, infer from value args.
    match map.get(&e.variant_of, name) {
    | Some(en) -> {
        var path: Vec<string> = vec.make()
        vec.push(&path, en)
        let final_args = if len(type_args) > 0 { type_args } else { infer_variant_type_args(e, en, name, args, sp) }
        return TENamed(sp, path, final_args)
    }
    | None -> { }
    }
    match map.get(&e.generic_fn_decls, name) {
    | Some(d) -> {
        match d {
        | DFn(_, _, tparams, _, ret, _, _) -> {
            if len(type_args) == len(tparams) && len(tparams) > 0 {
                return substitute_type(e, ret, tparams, type_args)
            }
            ret
        }
        | _ -> {
            let _ = emit_die(sp, `'{name}' is in generic_fn_decls but not a DFn`)
            TEUnit(sp)
        }
        }
    }
    | None -> {
        match map.get(&e.fn_returns, name) {
        | Some(t) -> t
        | None -> {
            let _ = emit_die(sp, `call to unknown function '{name}' (no DFn, DExternal, or builtin matched)`)
            TEUnit(sp)
        }
        }
    }
    }
}

type StmtScope = {
    start:    i64,
    prologue: Vec<string>,
}

// Open a new statement scope. Records the current strbuf length so
// that sub-emit bytes appended after this point can be captured at
// close time. Sub-emits may stash full C statements into
// `e.pending_prologue` (a hoisted match-as-value, a closure
// construction, an array literal). The caller is responsible for
// calling close_statement_scope to flush both.
let open_statement_scope(e: *Emitter): StmtScope = {
    let saved = StmtScope { start: strings.sb_len(&e.out), prologue: e.pending_prologue }
    e.pending_prologue = vec.make()
    saved
}

let close_statement_scope(e: *Emitter, saved: StmtScope) = {
    let cur = strings.sb_len(&e.out)
    let captured = strings.sb_slice_copy(&e.out, saved.start, cur)
    strings.sb_truncate(&e.out, saved.start)
    let prologues = e.pending_prologue
    e.pending_prologue = saved.prologue
    for p in prologues { push(e, p) }
    push(e, captured)
}

// Snapshot/slice helper used at each hoist site. The caller records the
// strbuf length, appends the C statements that should land in the
// enclosing statement's prologue (a hoisted match-as-value, a closure
// env construction, etc.), and then calls hoist_to_prologue to slice
// the captured bytes out of `e.out` and queue them as a prologue
// entry. Pattern: `let s = strings.sb_len(&e.out); push(...); ...;
// hoist_to_prologue(e, s)`.
let hoist_to_prologue(e: *Emitter, start: i64) = {
    let captured = strings.sb_slice_copy(&e.out, start, strings.sb_len(&e.out))
    strings.sb_truncate(&e.out, start)
    vec.push(&e.pending_prologue, captured)
}

// Sub-emit may stash text into `e.pending_prologue` for code that
// needs to land just before the current C statement (a hoisted
// match-as-value, a closure construction, and similar). Capture the
// statement's own text first, then flush the prologue, then the text.
let emit_stmt(e: *Emitter, s: ast.Stmt) = {
    let saved = open_statement_scope(e)
    emit_stmt_inner(e, s)
    close_statement_scope(e, saved)
}

let emit_stmt_inner(e: *Emitter, s: ast.Stmt) = {
    match s {
    | SLet(_, name, ty, value) -> {
        let bind_te = binding_te(e, ty, value)
        if strings.eq_raw(name, "_") {
            push(e, "(void)(")
            emit_value_with_hint(e, value, bind_te)
            push(e, "); ")
            return
        }
        let ct = infer_value_ctype(e, ty, value)
        push(e, `{ct} {name} = `)
        emit_value_with_hint(e, value, bind_te)
        push(e, "; ")
        if c_type_is_pointer(ct) {
            push(e, `qoz_gc_push_root(&{name}); `)
        }
        e.locals[name] = bind_te
    }
    | SVar(_, name, ty, value) -> {
        let bind_te = binding_te(e, ty, value)
        if strings.eq_raw(name, "_") {
            push(e, "(void)(")
            emit_value_with_hint(e, value, bind_te)
            push(e, "); ")
            return
        }
        let ct = infer_value_ctype(e, ty, value)
        push(e, `{ct} {name} = `)
        emit_value_with_hint(e, value, bind_te)
        push(e, "; ")
        if c_type_is_pointer(ct) {
            push(e, `qoz_gc_push_root(&{name}); `)
        }
        e.locals[name] = bind_te
    }
    | SExpr(_, expr) -> {
        match expr {
        | EDefer(_, _) -> { }
        | _            -> emit_stmt_expr(e, expr)
        }
    }
    }
}

let collect_defers_in_stmts(stmts: Vec<ast.Stmt>): Vec<ast.Expr> = {
    var defers: Vec<ast.Expr> = vec.make()
    for s in stmts {
        match s {
        | SExpr(_, expr) -> {
            match expr {
            | EDefer(_, body) -> vec.push(&defers, body)
            | _               -> { }
            }
        }
        | _ -> { }
        }
    }
    defers
}

let emit_defers_reverse(e: *Emitter, defers: Vec<ast.Expr>) = {
    var i: i64 = len(defers) - 1
    while i >= 0 {
        emit_stmt_expr(e, defers[i])
        i -= 1
    }
}

// Wrap a condition in a single pair of parens, expanding EBinary inline
// so clang does not flag `if ((a == b))` with -Wparentheses-equality.
let emit_cond(e: *Emitter, cond: ast.Expr) = {
    push(e, "(")
    match cond {
    | EBinary(_, op, lhs, rhs) -> emit_binary(e, op, lhs, rhs)
    | _ -> emit_expr(e, cond)
    }
    push(e, ")")
}

let emit_stmt_expr(e: *Emitter, expr: ast.Expr) = {
    match expr {
    | EBlock(_, _, _) -> {
        // Bare `{ ... }` at statement position is its own scope.
        // Reuse the branch-block emitter so defers declared inside
        // fire at this block's `}`, not at the enclosing
        // function's exit.
        emit_branch_as_statement(e, expr)
    }
    | EIf(_, cond, then_b, else_b) -> {
        push(e, "if ")
        emit_cond(e, cond)
        push(e, " ")
        emit_branch_as_statement(e, then_b)
        if !is_nil_expr(else_b) {
            push(e, " else ")
            emit_branch_as_statement(e, else_b)
        }
    }
    | EWhile(_, cond, body) -> {
        push(e, "while (")
        emit_expr(e, cond)
        push(e, ") ")
        emit_branch_as_statement(e, body)
    }
    | EFor(_, binding, binding2, iter, body) -> {
        emit_for_loop_one(e, binding, binding2, iter, body)
    }
    | EReturn(_, value) -> {
        if is_nil_expr(value) {
            push(e, "return;")
        } else {
            push(e, "return ")
            emit_value_with_hint(e, value, e.current_ret_te)
            push(e, ";")
        }
    }
    | _ -> {
        emit_expr(e, expr)
        push(e, "; ")
    }
    }
}

let emit_branch_as_statement(e: *Emitter, br: ast.Expr) = {
    match br {
    | EBlock(_, stmts, tail) -> {
        push(e, "{ ")
        var defers = collect_defers_in_stmts(stmts)
        var effective_tail = tail
        match tail {
        | EDefer(_, dbody) -> {
            vec.push(&defers, dbody)
            effective_tail = ENil(span_of_expr(tail))
        }
        | _ -> { }
        }
        for s in stmts {
            emit_stmt(e, s)
        }
        if !is_nil_expr(effective_tail) {
            let saved = open_statement_scope(e)
            emit_stmt_expr(e, effective_tail)
            close_statement_scope(e, saved)
        }
        emit_defers_reverse(e, defers)
        push(e, "} ")
    }
    | _ -> {
        let saved = open_statement_scope(e)
        emit_stmt_expr(e, br)
        close_statement_scope(e, saved)
    }
    }
}

let path_is(callee: ast.Expr, a: string, b: string): bool =
    match callee {
    | EPath(_, segs)        -> len(segs) == 2 && strings.eq_raw(segs[0], a) && strings.eq_raw(segs[1], b)
    | EField(_, base, name) -> strings.eq_raw(name, b) && ident_is(base, a)
    | _                     -> false
    }

let ident_is(ex: ast.Expr, name: string): bool =
    match ex {
    | EIdent(_, n) -> strings.eq_raw(n, name)
    | _            -> false
    }

let qualified_call_name(e: *Emitter, callee: ast.Expr): string = {
    match callee {
    | EField(_, base, method) -> {
        match base {
        | EIdent(_, pkg) -> {
            if map.contains(&e.packages, pkg) {
                return strings.cat(strings.cat(pkg, "_"), method)
            }
            ""
        }
        | _ -> ""
        }
    }
    | _ -> ""
    }
}

// Pick the C type for a match-as-expression result variable by inspecting
// the first arm's body. Falls back to int64_t when nothing more specific
// can be derived.
let match_result_ctype_with_hint(e: *Emitter, enum_name: string, arms: Vec<ast.MatchArm>): string = {
    if !is_unit_typeexpr(e.match_hint) { return c_type_for(e, e.match_hint) }
    match_result_ctype(e, enum_name, arms)
}

let match_result_ctype(e: *Emitter, enum_name: string, arms: Vec<ast.MatchArm>): string = {
    var all_void = true
    for arm in arms {
        bind_arm_locals(e, enum_name, arm.pat)
        let ct = arm_body_ctype(e, enum_name, arm.body)
        if !strings.eq_raw(ct, "void") { all_void = false }
        if !strings.eq_raw(ct, "int64_t") && !strings.eq_raw(ct, "void") { return ct }
    }
    if all_void { return "void" }
    "int64_t"
}

// Infer the arm body's C type with the surrounding match's enum_name in
// scope. If the body is a variant constructor of that same enum, prefer
// the mangled C type so the result variable matches the case-label type.
let arm_body_ctype(e: *Emitter, enum_name: string, body: ast.Expr): string = {
    match body {
    | EIdent(_, name) -> {
        match map.get(&e.variant_of, name) {
        | Some(en) -> {
            if same_enum_base(e, en, enum_name) {
                return strings.cat(strings.cat("qoz_", enum_name), "*")
            }
            strings.cat(strings.cat("qoz_", en), "*")
        }
        | None -> infer_expr_ctype(e, body)
        }
    }
    | ECall(_, callee, _, _) -> {
        match callee {
        | EIdent(_, name) -> {
            match map.get(&e.variant_of, name) {
            | Some(en) -> {
                if same_enum_base(e, en, enum_name) {
                    return strings.cat(strings.cat("qoz_", enum_name), "*")
                }
                strings.cat(strings.cat("qoz_", en), "*")
            }
            | None -> infer_expr_ctype(e, body)
            }
        }
        | _ -> infer_expr_ctype(e, body)
        }
    }
    | _ -> infer_expr_ctype(e, body)
    }
}

let same_enum_base(e: *Emitter, bare: string, maybe_mangled: string): bool = {
    if strings.eq_raw(bare, maybe_mangled) { return true }
    strings.eq_raw(strip_mangled(maybe_mangled), bare)
}

// Register the locals that a pattern brings into scope, by walking
// the pattern and recording each PatBind under its inferred TypeExpr.
// Used by the pre-pass type inference so the inner expressions of an
// arm body can resolve names that the pattern introduces. Recurses
// into nested PatVariant so deeply destructured bindings (for example
// the `v` in `Some(Some(v))`) are registered with the payload's
// TypeExpr at every depth.
let bind_arm_locals_at(e: *Emitter, pat: ast.Pattern, value_te: ast.TypeExpr) = {
    match pat {
    | PatBind(_, bname) -> {
        match map.get(&e.variant_of, bname) {
        | Some(_) -> { }
        | None    -> e.locals[bname] = value_te
        }
    }
    | PatVariant(sp, path, sub_pats) -> {
        if len(path) < 1 {
            let _ = emit_die(sp, "variant pattern has no name")
            return
        }
        let vname = path[len(path) - 1]
        let inner_enum = enum_name_of_te(e, value_te)
        if strings.eq_raw(inner_enum, "") {
            let _ = emit_die(sp, "nested variant pattern on a scrutinee whose type is not an enum")
            return
        }
        var i: i64 = 0
        for spat in sub_pats {
            let sub_te = variant_payload_typeexpr(e, inner_enum, vname, i)
            bind_arm_locals_at(e, spat, sub_te)
            i += 1
        }
    }
    | PatWild(_) | PatLitInt(_, _) | PatLitString(_, _) | PatLitBool(_, _) -> { }
    | PatTuple(sp, _) -> {
        let _ = emit_die(sp, "tuple patterns in match arms are not yet supported")
    }
    }
}

let bind_arm_locals(e: *Emitter, enum_name: string, pat: ast.Pattern) = {
    match pat {
    | PatVariant(_, path, sub_pats) -> {
        if len(path) < 1 { return }
        let vname = path[len(path) - 1]
        var i: i64 = 0
        for sp in sub_pats {
            let sub_te = variant_payload_typeexpr(e, enum_name, vname, i)
            bind_arm_locals_at(e, sp, sub_te)
            i += 1
        }
    }
    | PatBind(_, bname) -> {
        match map.get(&e.variant_of, bname) {
        | Some(_) -> { }
        | None    -> {
            let unit_sp = ast.Span { file: "", line: 0, col: 0 }
            e.locals[bname] = TEUnit(unit_sp)
        }
        }
    }
    | _ -> { }
    }
}

let default_value_for(ctype: string): string = {
    if strings.eq_raw(ctype, "qoz_string") { return "((qoz_string){ NULL, 0 })" }
    if strings.eq_raw(ctype, "bool") { return "false" }
    if strings.has_suffix(ctype, "*") { return "NULL" }
    if is_int_ctype(ctype) { return "0" }
    if strings.eq_raw(ctype, "double") || strings.eq_raw(ctype, "float") { return "0" }
    if strings.eq_raw(ctype, "char") { return "0" }
    // Struct-typed result: use a compound literal zero initializer.
    strings.cat(strings.cat("((", ctype), "){0})")
}

let is_int_ctype(ctype: string): bool = {
    if strings.eq_raw(ctype, "int8_t") { return true }
    if strings.eq_raw(ctype, "int16_t") { return true }
    if strings.eq_raw(ctype, "int32_t") { return true }
    if strings.eq_raw(ctype, "int64_t") { return true }
    if strings.eq_raw(ctype, "uint8_t") { return true }
    if strings.eq_raw(ctype, "uint16_t") { return true }
    if strings.eq_raw(ctype, "uint32_t") { return true }
    if strings.eq_raw(ctype, "uint64_t") { return true }
    false
}

// C requires `->` rather than `.` for field access on a pointer base.
let emit_field(e: *Emitter, base: ast.Expr, name: string) = {
    // `Enum.Variant` in value position: the base is a known enum and
    // the field is a variant of it. Emit the unit-payload variant
    // constructor `qoz_make_<Enum>_<Variant>()`. Variants that carry
    // payloads reach this path only through emit_call's variant
    // dispatch, which handles the argument list.
    match base {
    | EIdent(_, enum_name) -> {
        if map.contains(&e.enum_decls, enum_name) {
            match map.get(&e.variant_of, name) {
            | Some(_) -> {
                push(e, `qoz_make_{enum_name}_{name}()`)
                return
            }
            | None -> { }
            }
        }
    }
    | _ -> { }
    }
    // `EnumName.Variant` for a C-style enum: emit the variant's
    // integer literal cast to the underlying type so the value
    // carries the right C type at call sites. The base is either
    // the renamed enum name (`pkg_EnumShort`) or the package-
    // qualified form `pkg.EnumShort`.
    let enum_lookup = match base {
    | EIdent(_, enum_name) -> enum_name
    | EField(_, inner, enum_short) -> {
        match inner {
        | EIdent(_, pkg) -> strings.cat(strings.cat(pkg, "_"), enum_short)
        | _              -> ""
        }
    }
    | _ -> ""
    }
    if !strings.eq_raw(enum_lookup, "") {
        match map.get(&e.c_enum_decls, enum_lookup) {
        | Some(d) -> {
            match d {
            | DCEnum(_, _, underlying, variants) -> {
                var i: i64 = 0
                for v in variants {
                    if strings.eq_raw(v, name) {
                        let ct = c_type_for(e, underlying)
                        push(e, `(({ct}){int_to_string(i)})`)
                        return
                    }
                    i += 1
                }
            }
            // Only DCEnum is stored in c_enum_decls.
            | _ -> { }
            }
        }
        | None -> { }
        }
    }
    // `pkg.NAME` reading a top-level constant. The const is emitted
    // as a zero-arg function so its initializer can be any
    // expression. The read is a function call.
    match base {
    | EIdent(_, pkg) -> {
        if map.contains(&e.packages, pkg) {
            let qual = strings.cat(strings.cat(pkg, "_"), name)
            if map.contains(&e.consts, qual) {
                push(e, `qoz_{qual}()`)
                return
            }
        }
    }
    | _ -> { }
    }
    let op = field_access_op(e, base)
    emit_expr(e, base)
    push(e, `{op}{name}`)
}

// Pick `->` for a pointer-typed base, `.` for a value-typed base. The
// base's value type comes from the inference cache. Falling back to
// `.` for unknown values matches the C rule for struct-typed locals.
let field_access_op(e: *Emitter, base: ast.Expr): string = {
    let te = infer_value_te(e, base)
    match te {
    | TEPtr(_, _) -> "->"
    | _           -> "."
    }
}

// EAssign of m[k] = v with m of type Map<K,V> needs the map_set
// instantiation discovered ahead of body emission. The walk happens at
// discovery time without locals. Derive the LHS type from the lvalue
// shape by inspecting structurally.
let walk_assign_for_map_helpers(e: *Emitter, lhs: ast.Expr) = {
    match lhs {
    | EIndex(_, base, _) -> {
        let bte = base_type_for_walk(e, base)
        match bte {
        | TENamed(_, path, args) -> {
            if len(path) >= 1 && strings.eq_raw(path[len(path) - 1], "Map") && len(args) == 2 {
                register_map_helper(e, "map_set", args)
            }
        }
        | _ -> { }
        }
    }
    | _ -> { }
    }
}

// Best-effort TypeExpr for a base expression at discovery time, before
// locals are populated. Looks at field types on a known struct via the
// field name chain.
let base_type_for_walk(e: *Emitter, ex: ast.Expr): ast.TypeExpr = {
    match ex {
    | EIdent(sp, name) -> {
        match map.get(&e.locals, name) {
        | Some(te) -> te
        | None     -> TEUnit(sp)
        }
    }
    | EField(sp, b, name) -> {
        let bte = base_type_for_walk(e, b)
        field_typeexpr_for_no_die(e, bte, name, sp)
    }
    | EUnary(sp, op, rhs) -> {
        match op {
        | UOpDeref -> {
            let inner = base_type_for_walk(e, rhs)
            match inner {
            | TEPtr(_, t) -> t
            | _           -> TEUnit(sp)
            }
        }
        | UOpAddr -> TEPtr(sp, base_type_for_walk(e, rhs))
        | _       -> TEUnit(sp)
        }
    }
    | _ -> TEUnit(span_of_expr(ex))
    }
}

// Variant of field_typeexpr_for that returns TEUnit instead of dying.
// Used in the discovery walk where the result is a hint, not a guarantee.
let field_typeexpr_for_no_die(e: *Emitter, base_te: ast.TypeExpr, field: string, sp: ast.Span): ast.TypeExpr = {
    let unwrapped = match base_te {
        | TEPtr(_, inner) -> inner
        | _               -> base_te
    }
    match unwrapped {
    | TENamed(_, path, args) -> {
        if len(path) < 1 { return TEUnit(sp) }
        let lookup = type_lookup_key(e, path)
        let decl_opt = match map.get(&e.generic_decls, lookup) {
            | Some(d) -> Some(d)
            | None    -> map.get(&e.struct_decls, lookup)
        }
        match decl_opt {
        | Some(decl) -> {
            match decl {
            | DStruct(_, _, params, fields) -> {
                for f in fields {
                    if strings.eq_raw(f.name, field) {
                        if len(args) == len(params) {
                            return substitute_type(e, f.ty, params, args)
                        }
                        return f.ty
                    }
                }
                TEUnit(sp)
            }
            | _ -> TEUnit(sp)
            }
        }
        | None -> TEUnit(sp)
        }
    }
    | _ -> TEUnit(sp)
    }
}

let register_map_helper(e: *Emitter, name: string, args: Vec<ast.TypeExpr>) = {
    if !map.contains(&e.generic_fn_decls, name) { return }
    let mangled = mangle_inst(e, name, args)
    if map.contains(&e.fn_seen, mangled) { return }
    map.set(&e.fn_seen, mangled, true)
    vec.push(&e.fn_insts, Instantiation { name: name, args: args, mangled: mangled })
    match map.get(&e.generic_fn_decls, name) {
    | Some(d) -> walk_fn_body_with_subst(e, d, args)
    | None    -> { }
    }
}

// m[k] = v on a Map dispatches to qoz_map_set__<K>__<V>.
let emit_assign(e: *Emitter, lhs: ast.Expr, rhs: ast.Expr) = {
    match lhs {
    | EIndex(_, base, idx) -> {
        let te = infer_base_typeexpr(e, base)
        match te {
        | TENamed(_, path, args) -> {
            if len(path) >= 1 && strings.eq_raw(path[len(path) - 1], "Map") && len(args) == 2 {
                register_map_helper(e, "map_set", args)
                let k_m = mangle_type(e, args[0])
                let v_m = mangle_type(e, args[1])
                push(e, `qoz_map_set__{k_m}__{v_m}(&`)
                emit_expr(e, base)
                push(e, ", ")
                emit_expr(e, idx)
                push(e, ", ")
                emit_expr(e, rhs)
                push(e, ")")
                return
            }
        }
        | _ -> { }
        }
    }
    | _ -> { }
    }
    emit_expr(e, lhs)
    push(e, " = ")
    let hint = lvalue_hint(e, lhs)
    emit_value_with_hint(e, rhs, hint)
}

let lvalue_hint(e: *Emitter, lhs: ast.Expr): ast.TypeExpr = {
    let sp = ast.Span { file: "", line: 0, col: 0 }
    match lhs {
    | EField(_, base, name) -> {
        let bte = infer_base_typeexpr(e, base)
        field_typeexpr_for_no_die(e, bte, name, sp)
    }
    | EIndex(_, base, _) -> {
        let bte = infer_base_typeexpr(e, base)
        match bte {
        | TEPtr(_, inner) -> inner
        | TENamed(_, path, args) -> {
            if len(args) >= 1 && len(path) >= 1 && strings.eq_raw(path[len(path) - 1], "Vec") { return args[0] }
            TEUnit(sp)
        }
        | _ -> TEUnit(sp)
        }
    }
    | EIdent(_, name) -> {
        match map.get(&e.locals, name) {
        | Some(te) -> te
        | None     -> TEUnit(sp)
        }
    }
    | _ -> TEUnit(sp)
    }
}

// EIndex dispatches on the base's static type:
//   Vec<T>             -> base.data[i]
//   string             -> qoz_string_byte_at(base, i) (returns i64)
//   *T / array         -> base[i]
let emit_index(e: *Emitter, base: ast.Expr, idx: ast.Expr) = {
    let te = infer_base_typeexpr(e, base)
    match te {
    | TENamed(_, path, _) -> {
        if len(path) >= 1 {
            let n = path[len(path) - 1]
            if strings.eq_raw(n, "Vec") {
                let op = field_access_op(e, base)
                emit_expr(e, base)
                push(e, `{op}data[`)
                emit_expr(e, idx)
                push(e, "]")
                return
            }
            if strings.eq_raw(n, "string") {
                push(e, "qoz_string_byte_at(")
                emit_expr(e, base)
                push(e, ", ")
                emit_expr(e, idx)
                push(e, ")")
                return
            }
        }
    }
    | _ -> { }
    }
    emit_expr(e, base)
    push(e, "[")
    emit_expr(e, idx)
    push(e, "]")
}

// Built-in `hash(x)` dispatches by the operand's static type.
let emit_hash_builtin(e: *Emitter, arg: ast.Expr) = {
    let ct = infer_expr_ctype(e, arg)
    if strings.eq_raw(ct, "qoz_string") {
        push(e, "qoz_string_hash("); emit_expr(e, arg); push(e, ")")
        return
    }
    let record_name = record_struct_name_of_ctype(e, ct)
    if !strings.eq_raw(record_name, "") {
        push(e, `qoz_hash_{record_name}(`)
        emit_expr(e, arg)
        push(e, ")")
        return
    }
    push(e, "(uint64_t)("); emit_expr(e, arg); push(e, ")")
}

// Built-in `len(x)` dispatch based on the operand's static type.
let emit_len_builtin(e: *Emitter, arg: ast.Expr) = {
    // `len(&x)` reads `x.len`, not `&x->len`. `&x->len` parses in C
    // as `&(x->len)` because `->` binds tighter than unary `&`, which
    // yields a pointer to the int field instead of the length. Peel
    // off a leading address-of so the field access goes through the
    // value, and the resulting `(*p).len` becomes `p->len` only when
    // `p` is already a pointer that the user passed in directly.
    let unwrapped = peel_addr_of(arg)
    let ct = infer_expr_ctype(e, unwrapped)
    if strings.eq_raw(ct, "qoz_string") {
        push(e, "(")
        emit_expr(e, unwrapped)
        push(e, ").len")
        return
    }
    push(e, "(")
    let op = field_access_op(e, unwrapped)
    if strings.eq_raw(op, "->") {
        emit_expr(e, unwrapped)
        push(e, "->len")
    } else {
        emit_expr(e, unwrapped)
        push(e, ".len")
    }
    push(e, ")")
}

let peel_addr_of(e: ast.Expr): ast.Expr = {
    match e {
    | EUnary(_, op, inner) -> {
        match op { | UOpAddr -> inner | _ -> e }
    }
    | _ -> e
    }
}

let emit_call(e: *Emitter, callee: ast.Expr, type_args: Vec<ast.TypeExpr>, args: Vec<ast.Expr>) = {
    // Resolve `pkg.fn` to the loader-renamed C name `pkg_fn`.
    let qualified = qualified_call_name(e, callee)
    if !strings.eq_raw(qualified, "") {
        if len(type_args) > 0 && map.contains(&e.generic_fn_decls, qualified) {
            let mi = mangle_inst(e, qualified, type_args)
            push(e, `qoz_{mi}(`)
            var i: i64 = 0
            for a in args {
                if i > 0 { push(e, ", ") }
                emit_expr(e, a)
                i += 1
            }
            push(e, ")")
            return
        }
        let dispatch_name = match map.get(&e.externs, qualified) {
            | Some(sym) -> sym
            | None      -> user_fn_c_name(qualified)
        }
        push(e, `{dispatch_name}(`)
        var hints: Vec<ast.TypeExpr> = vec.make()
        match map.get(&e.fn_params, qualified) {
        | Some(pts) -> hints = pts
        | None      -> { }
        }
        var i: i64 = 0
        for a in args {
            if i > 0 { push(e, ", ") }
            if i < len(hints) {
                emit_value_with_hint(e, a, hints[i])
            } else {
                emit_expr(e, a)
            }
            i += 1
        }
        push(e, ")")
        return
    }
    match callee {
    | EIdent(_, name) -> {
        if strings.eq_raw(name, "size_of") && len(args) == 1 {
            push(e, "(int64_t)sizeof(int64_t)")
            return
        }
        if strings.eq_raw(name, "len") && len(args) == 1 {
            emit_len_builtin(e, args[0])
            return
        }
        if strings.eq_raw(name, "hash") && len(args) == 1 {
            emit_hash_builtin(e, args[0])
            return
        }
        // Interpolation intrinsics map 1:1 to runtime C functions:
        // the Qoz-side name has a `__` prefix to mark it as an
        // intrinsic. The C function is the same name with that prefix
        // stripped. No declaration is needed on the Qoz side because
        // the type checker recognises the prefix and types the call
        // directly.
        if strings.has_prefix(name, "__qoz_interp_") {
            // Non-primitive interpolation slot. Materialise the value
            // through a per-type auto-derived show fn so the runtime
            // sees a string. The show fn is registered for later
            // emission. Subsequent emits of the same type share it.
            if strings.eq_raw(name, "__qoz_interp_push_any") && len(args) == 2 {
                let val_te = infer_value_te(e, args[1])
                let mangled = mangle_type(e, val_te)
                if strings.eq_raw(mangled, "") {
                    let _ = emit_die(span_of_expr(args[1]), `cannot derive a show function for type {te_show_dbg(val_te)}`)
                }
                register_show_needed(e, mangled, val_te)
                push(e, "qoz_interp_push_str(")
                emit_expr(e, args[0])
                push(e, ", ")
                push(e, `qoz_show_{mangled}(`)
                emit_expr(e, args[1])
                push(e, "))")
                return
            }
            let c_name = strings.slice(name, 2, len(name))
            push(e, c_name)
            push(e, "(")
            var i: i64 = 0
            for a in args {
                if i > 0 { push(e, ", ") }
                emit_expr(e, a)
                i += 1
            }
            push(e, ")")
            return
        }
    }
    | _ -> { }
    }
    // Variant constructor call. Three callee shapes can reach this
    // point: bare `Variant(...)`, qualified `Enum.Variant(...)` parsed
    // as EField, and qualified `Enum.Variant(...)` parsed as EPath.
    // All three lower to `qoz_make_<Enum>_<Variant>(...)`.
    let variant_name = variant_callee_name(e, callee)
    if !strings.eq_raw(variant_name, "") {
        let enum_name = resolve_variant_enum(e, callee, variant_name)
        if !strings.eq_raw(enum_name, "") {
            push(e, `qoz_make_{enum_name}_{variant_name}(`)
            var i: i64 = 0
            for a in args {
                if i > 0 { push(e, ", ") }
                emit_expr(e, a)
                i += 1
            }
            push(e, ")")
            return
        }
    }
    // Generic function call: rewrite the callee to the mangled instantiation name.
    if len(type_args) > 0 {
        match callee {
        | EIdent(_, name) -> {
            if map.contains(&e.generic_fn_decls, name) {
                let mi = mangle_inst(e, name, type_args)
                push(e, `qoz_{mi}(`)
                var i: i64 = 0
                for a in args {
                    if i > 0 { push(e, ", ") }
                    emit_expr(e, a)
                    i += 1
                }
                push(e, ")")
                return
            }
        }
        | _ -> { }
        }
    }
    // Bare-name call to an external: dispatch to the C link symbol.
    // Argument emission uses the declared parameter types as hints so
    // string literals flowing into a `cstring` parameter lower to a
    // bare C string literal, not a qoz_string struct.
    match callee {
    | EIdent(_, name) -> {
        match map.get(&e.externs, name) {
        | Some(sym) -> {
            push(e, `{sym}(`)
            var hints: Vec<ast.TypeExpr> = vec.make()
            match map.get(&e.fn_params, name) {
            | Some(pts) -> hints = pts
            | None      -> { }
            }
            var i: i64 = 0
            for a in args {
                if i > 0 { push(e, ", ") }
                if i < len(hints) {
                    emit_value_with_hint(e, a, hints[i])
                } else {
                    emit_expr(e, a)
                }
                i += 1
            }
            push(e, ")")
            return
        }
        | None -> { }
        }
    }
    | _ -> { }
    }
    // Closure-value dispatch: when the callee is a local of function type,
    // route through the {env, fn} struct.
    let callee_te = callee_value_typeexpr(e, callee)
    match callee_te {
    | TEFn(_, fn_params_te, _) -> {
        push(e, "(")
        emit_expr(e, callee)
        push(e, ").fn((")
        emit_expr(e, callee)
        push(e, ").env")
        var i: i64 = 0
        for a in args {
            push(e, ", ")
            if i < len(fn_params_te) {
                emit_value_with_hint(e, a, fn_params_te[i])
            } else {
                emit_expr(e, a)
            }
            i += 1
        }
        push(e, ")")
        return
    }
    | _ -> { }
    }
    // A bare ident callee that names a top-level user function (in
    // fn_params, not an extern, not a local closure value) gets the
    // `qoz_` prefix at the call site to match the definition's
    // emitted name. Closure-typed locals and externs keep their
    // identifier as written.
    var emitted_callee = false
    match callee {
    | EIdent(_, cname) -> {
        if map.contains(&e.fn_params, cname)
                && !map.contains(&e.externs, cname)
                && !map.contains(&e.locals, cname) {
            push(e, user_fn_c_name(cname))
            emitted_callee = true
        }
    }
    | _ -> { }
    }
    if !emitted_callee { emit_expr(e, callee) }
    push(e, "(")
    var fallback_hints: Vec<ast.TypeExpr> = vec.make()
    match callee {
    | EIdent(_, cname) -> {
        match map.get(&e.fn_params, cname) {
        | Some(pts) -> fallback_hints = pts
        | None      -> { }
        }
    }
    | _ -> { }
    }
    var i: i64 = 0
    for a in args {
        if i > 0 {
            push(e, ", ")
        }
        if i < len(fallback_hints) {
            emit_value_with_hint(e, a, fallback_hints[i])
        } else {
            emit_expr(e, a)
        }
        i += 1
    }
    push(e, ")")
}

let callee_value_typeexpr(e: *Emitter, callee: ast.Expr): ast.TypeExpr = {
    match callee {
    | EIdent(sp, name) -> {
        if let Some(te) = map.get(&e.locals, name) {
            return te
        }
        TEUnit(sp)
    }
    | _ -> TEUnit(span_of_expr(callee))
    }
}

// `s == t` on qoz_string maps to qoz_string_eq, and `!=` is its negation.
// One forwarder per `@operator(...)` target. The user-written function
// takes `*T` arguments. The forwarder accepts both operands by value
// and passes their addresses through. Emitted at most once per
// `fn_name` per compilation.
// Same shape as ensure_byval_dispatch_helper but for unary operators.
// The user's `let neg(a: *T): T` is declared with a pointer receiver;
// the by-value forwarder accepts T by value so the operand can be
// address-taken inside the helper.
let ensure_unary_byval_dispatch_helper(e: *Emitter, fn_name: string, operand_ct: string, ret_ct: string) = {
    if map.contains(&e.byval_helpers_emitted, fn_name) { return }
    e.byval_helpers_emitted[fn_name] = true
    let call_name = user_fn_c_name(fn_name)
    var src = "static "
    src = strings.cat(src, ret_ct)
    src = strings.cat(src, " _qoz_byval_")
    src = strings.cat(src, fn_name)
    src = strings.cat(src, "(")
    src = strings.cat(src, operand_ct)
    src = strings.cat(src, " a) { return ")
    src = strings.cat(src, call_name)
    src = strings.cat(src, "(&a); }\n")
    var proto = "static "
    proto = strings.cat(proto, ret_ct)
    proto = strings.cat(proto, " _qoz_byval_")
    proto = strings.cat(proto, fn_name)
    proto = strings.cat(proto, "(")
    proto = strings.cat(proto, operand_ct)
    proto = strings.cat(proto, ");\n")
    vec.push(&e.synth_fn_decls, proto)
    vec.push(&e.synth_fn_defs, src)
}

let unary_op_text(op: ast.UnaryOp): string = {
    match op {
    | UOpNeg   -> "unary-"
    | UOpNot   -> "unary!"
    | UOpDeref -> ""
    | UOpAddr  -> ""
    }
}

let ensure_byval_dispatch_helper(e: *Emitter, fn_name: string, operand_ct: string, ret_ct: string) = {
    if map.contains(&e.byval_helpers_emitted, fn_name) { return }
    e.byval_helpers_emitted[fn_name] = true
    let call_name = user_fn_c_name(fn_name)
    var src = "static "
    src = strings.cat(src, ret_ct)
    src = strings.cat(src, " _qoz_byval_")
    src = strings.cat(src, fn_name)
    src = strings.cat(src, "(")
    src = strings.cat(src, operand_ct)
    src = strings.cat(src, " a, ")
    src = strings.cat(src, operand_ct)
    src = strings.cat(src, " b) { return ")
    src = strings.cat(src, call_name)
    var proto = "static "
    proto = strings.cat(proto, ret_ct)
    proto = strings.cat(proto, " _qoz_byval_")
    proto = strings.cat(proto, fn_name)
    proto = strings.cat(proto, "(")
    proto = strings.cat(proto, operand_ct)
    proto = strings.cat(proto, ", ")
    proto = strings.cat(proto, operand_ct)
    proto = strings.cat(proto, ");\n")
    vec.push(&e.synth_fn_decls, proto)
    src = strings.cat(src, "(&a, &b); }\n")
    vec.push(&e.synth_fn_defs, src)
}

// Surface-syntax spelling for each binary operator. Used as the key
// when looking up `@operator(...)` registrations on user types and as
// the C operator when no overload is found. Range operators have no
// surface spelling because they are only valid in for-loop iter
// position. An overload is not meaningful for them.
let binary_op_text(op: ast.BinaryOp): string = {
    match op {
    | BOpEq     -> "=="
    | BOpNe     -> "!="
    | BOpLt     -> "<"
    | BOpGt     -> ">"
    | BOpLe     -> "<="
    | BOpGe     -> ">="
    | BOpAdd    -> "+"
    | BOpSub    -> "-"
    | BOpMul    -> "*"
    | BOpDiv    -> "/"
    | BOpMod    -> "%"
    | BOpAnd    -> "&&"
    | BOpOr     -> "||"
    | BOpBitAnd -> "&"
    | BOpBitOr  -> "|"
    | BOpBitXor -> "^"
    | BOpShl    -> "<<"
    | BOpShr    -> ">>"
    | BOpRange | BOpRangeInclusive -> ""
    }
}

let record_struct_name_of_ctype(e: *Emitter, ct: string): string = {
    // The C type for a record value is `qoz_<MangledName>`. Pointers and
    // primitive types do not start that way, and ADTs come back with a `*`
    // trailing because they are heap-allocated.
    if len(ct) < 5 { return "" }
    let prefix = strings.slice(ct, 0, 4)
    if !strings.eq_raw(prefix, "qoz_") { return "" }
    let last = strings.byte_at(ct, len(ct) - 1)
    if last == 42 { return "" }
    let name = strings.slice(ct, 4, len(ct))
    if map.contains(&e.is_enum, name) { return "" }
    name
}

let emit_binary(e: *Emitter, op: ast.BinaryOp, lhs: ast.Expr, rhs: ast.Expr) = {
    let lct = infer_expr_ctype(e, lhs)
    if strings.eq_raw(lct, "qoz_string") {
        match op {
        | BOpEq -> {
            push(e, "qoz_string_eq(")
            emit_expr(e, lhs)
            push(e, ", ")
            emit_expr(e, rhs)
            push(e, ")")
            return
        }
        | BOpNe -> {
            push(e, "!qoz_string_eq(")
            emit_expr(e, lhs)
            push(e, ", ")
            emit_expr(e, rhs)
            push(e, ")")
            return
        }
        | _ -> { }
        }
    }
    let op_text = binary_op_text(op)
    if !strings.eq_raw(op_text, "") {
        let lhs_te = infer_value_te(e, lhs)
        let tname = operator_first_param_type_name(lhs_te)
        if !strings.eq_raw(tname, "") {
            let key = strings.cat(strings.cat(op_text, "::"), tname)
            if let Some(fn_name) = map.get(&e.op_dispatch, key) {
                let ct = c_type_for(e, lhs_te)
                let ret_te = match map.get(&e.fn_returns, fn_name) {
                | Some(t) -> t
                | None    -> {
                    let _ = emit_die(span_of_expr(lhs), `operator '{op_text}' for '{tname}' has no recorded return type`)
                    TEUnit(span_of_expr(lhs))
                }
                }
                let ret_ct = c_type_for(e, ret_te)
                ensure_byval_dispatch_helper(e, fn_name, ct, ret_ct)
                // The user wrote `lhs OP rhs`. The operator is defined as
                // a `let` taking `*T` parameters. Call the by-value
                // forwarder so each argument lands in a stable local of
                // the helper whose address can be passed through.
                push(e, `_qoz_byval_{fn_name}(`)
                emit_expr(e, lhs)
                push(e, ", ")
                emit_expr(e, rhs)
                push(e, ")")
                return
            }
        }
    }
    let record_name = record_struct_name_of_ctype(e, lct)
    if !strings.eq_raw(record_name, "") {
        match op {
        | BOpEq -> {
            push(e, `qoz_eq_{record_name}(`)
            emit_expr(e, lhs)
            push(e, ", ")
            emit_expr(e, rhs)
            push(e, ")")
            return
        }
        | BOpNe -> {
            push(e, `!qoz_eq_{record_name}(`)
            emit_expr(e, lhs)
            push(e, ", ")
            emit_expr(e, rhs)
            push(e, ")")
            return
        }
        | _ -> { }
        }
    }
    match op {
    | BOpRange | BOpRangeInclusive -> {
        let _ = emit_die(span_of_expr(lhs), "range expression is only valid in for-loop iter position")
    }
    | _ -> { }
    }
    let p = binary_prec(op)
    let needs_paren_child = is_logical_op(op)
    emit_binary_child(e, lhs, p, needs_paren_child)
    let bop = binary_c_op(op)
    push(e, ` {bop} `)
    emit_binary_child(e, rhs, p + 1, needs_paren_child)
}

// Clang's -Wlogical-op-parentheses rejects `a && b || c && d` even though
// C precedence makes the grouping unambiguous. Wrap every direct binary
// child of `&&` or `||` in explicit parentheses so the emitted output
// passes -pedantic -Werror unchanged.
let is_logical_op(op: ast.BinaryOp): bool = match op {
| BOpAnd -> true
| BOpOr  -> true
| _      -> false
}

let emit_binary_child(e: *Emitter, ex: ast.Expr, min_prec: i64, force_paren_if_binary: bool) = {
    match ex {
    | EBinary(_, _, _, _) -> {
        if force_paren_if_binary {
            push(e, "(")
            emit_expr(e, ex)
            push(e, ")")
        } else {
            emit_with_prec(e, ex, min_prec)
        }
    }
    | _ -> emit_with_prec(e, ex, min_prec)
    }
}

// C operator precedence (higher binds tighter).
let binary_prec(op: ast.BinaryOp): i64 = {
    match op {
    | BOpMul            -> 12
    | BOpDiv            -> 12
    | BOpMod            -> 12
    | BOpAdd            -> 11
    | BOpSub            -> 11
    | BOpShl            -> 10
    | BOpShr            -> 10
    | BOpLt             -> 8
    | BOpGt             -> 8
    | BOpLe             -> 8
    | BOpGe             -> 8
    | BOpRange          -> 8
    | BOpRangeInclusive -> 8
    | BOpEq             -> 7
    | BOpNe             -> 7
    | BOpBitAnd         -> 6
    | BOpBitXor         -> 5
    | BOpBitOr          -> 4
    | BOpAnd            -> 3
    | BOpOr             -> 2
    }
}

let emit_with_prec(e: *Emitter, ex: ast.Expr, min_prec: i64) = {
    match ex {
    | EBinary(_, op, _, _) -> {
        let p = binary_prec(op)
        if p < min_prec {
            push(e, "(")
            emit_expr(e, ex)
            push(e, ")")
        } else {
            emit_expr(e, ex)
        }
    }
    | _ -> emit_expr(e, ex)
    }
}

let binary_c_op(op: ast.BinaryOp): string = {
    match op {
    | BOpAdd            -> "+"
    | BOpSub            -> "-"
    | BOpMul            -> "*"
    | BOpDiv            -> "/"
    | BOpMod            -> "%"
    | BOpEq             -> "=="
    | BOpNe             -> "!="
    | BOpLt             -> "<"
    | BOpGt             -> ">"
    | BOpLe             -> "<="
    | BOpGe             -> ">="
    | BOpAnd            -> "&&"
    | BOpOr             -> "||"
    | BOpBitAnd         -> "&"
    | BOpBitOr          -> "|"
    | BOpBitXor         -> "^"
    | BOpShl            -> "<<"
    | BOpShr            -> ">>"
    | BOpRange          -> "<"
    | BOpRangeInclusive -> "<="
    }
}

let unary_c_op(op: ast.UnaryOp): string = {
    match op {
    | UOpNeg   -> "-"
    | UOpNot   -> "!"
    | UOpDeref -> "*"
    | UOpAddr  -> "&"
    }
}

let is_block(ex: ast.Expr): bool =
    match ex {
    | EBlock(_, _, _) -> true
    | _               -> false
    }

let is_nil_expr(ex: ast.Expr): bool =
    match ex {
    | ENil(_) -> true
    | _       -> false
    }

let emit_fn_body_block(e: *Emitter, body: ast.Expr, ret_hint: ast.TypeExpr) = {
    match body {
    | EBlock(_, stmts, tail) -> {
        var defers = collect_defers_in_stmts(stmts)
        var effective_tail = tail
        match tail {
        | EDefer(_, dbody) -> {
            vec.push(&defers, dbody)
            effective_tail = ENil(span_of_expr(tail))
        }
        | _ -> { }
        }
        for s in stmts {
            emit_stmt(e, s)
        }
        if is_nil_expr(effective_tail) {
            emit_defers_reverse(e, defers)
            push(e, "return;\n")
            return
        }
        if is_unit_typeexpr(ret_hint) {
            let saved = open_statement_scope(e)
            emit_stmt_expr(e, effective_tail)
            close_statement_scope(e, saved)
            emit_defers_reverse(e, defers)
            push(e, "\n    return;\n")
            return
        }
        match effective_tail {
        | EReturn(_, _) -> {
            emit_expr(e, effective_tail)
            push(e, ";\n")
            return
        }
        | _ -> { }
        }
        if len(defers) == 0 {
            let saved = open_statement_scope(e)
            push(e, e.current_return_restore)
            push(e, "return ")
            emit_value_with_hint(e, effective_tail, ret_hint)
            push(e, ";\n")
            close_statement_scope(e, saved)
        } else {
            e.closure_counter = e.closure_counter + 1
            let tmp = strings.cat("_qoz_ret_", `{e.closure_counter}`)
            let rt = c_type_for(e, ret_hint)
            push(e, `{rt} {tmp} = `)
            emit_value_with_hint(e, effective_tail, ret_hint)
            push(e, ";\n    ")
            emit_defers_reverse(e, defers)
            push(e, `\n    return {tmp};\n`)
        }
    }
    | _ -> { }
    }
}

let is_unit_typeexpr(te: ast.TypeExpr): bool = {
    match te {
    | TEUnit(_) -> true
    | TENamed(_, path, _) -> {
        if len(path) != 1 { return false }
        let n = path[0]
        strings.eq_raw(n, "unit") || strings.eq_raw(n, "void")
    }
    | _ -> false
    }
}

// User functions defined in the program are emitted with a `qoz_`
// prefix so they cannot collide with libc names like `div`, `index`,
// `time`. Names that already start with `qoz_` (notably mangled
// generic instantiations) keep their existing prefix.
let user_fn_c_name(name: string): string = {
    if strings.has_prefix(name, "qoz_") { return name }
    strings.cat("qoz_", name)
}

let emit_fn(e: *Emitter, name: string, params: Vec<ast.FnParam>, ret: ast.TypeExpr, body: ast.Expr) = {
    let ret_c = c_type_for(e, ret)
    let c_name = user_fn_c_name(name)
    push(e, `{ret_c} {c_name}`)
    if len(params) == 0 {
        push(e, "(void)")
    } else {
        push(e, "(")
        var i: i64 = 0
        for p in params {
            if i > 0 { push(e, ", ") }
            let pc = c_type_for(e, p.ty)
            let pn = p.name
            push(e, `{pc} {pn}`)
            i += 1
        }
        push(e, ")")
    }
    push(e, " {\n    int64_t _qoz_shadow_guard = qoz_gc_shadow_top();\n    ")
    // Push this function's name onto the runtime frame tracker so
    // qoz_panic produces a Qoz-level backtrace. The pop runs through
    // the return-restore path on every exit.
    push(e, "qoz_frame_push(\"")
    push(e, name)
    push(e, "\");\n    ")
    let saved_ret = e.current_return_restore
    e.current_return_restore = "qoz_frame_pop(); qoz_gc_shadow_set_top(_qoz_shadow_guard); "
    // Match-scrutinee names (_qoz_ms_N / _qoz_mv_N / _qoz_mm_N) live in
    // the C function's body scope. A per-function counter keeps the
    // names unique within that scope. The counter is restored after
    // the body so nested emits cannot poison an outer function.
    let saved_match_counter = e.match_counter
    e.match_counter = 0
    e.locals = map.make()
    for p in params {
        e.locals[p.name] = p.ty
        if c_type_is_pointer(c_type_for(e, p.ty)) {
            let pn = p.name
            push(e, `qoz_gc_push_root(&{pn});\n    `)
        }
    }
    e.current_ret_te = ret
    let is_b = is_block(body)
    if is_b {
        emit_fn_body_block(e, body, ret)
    } else {
        let saved = open_statement_scope(e)
        let crr = e.current_return_restore
        if is_unit_typeexpr(ret) {
            emit_expr(e, body)
            push(e, `;\n    {crr}return;\n`)
        } else {
            push(e, `{crr}return `)
            emit_value_with_hint(e, body, ret)
            push(e, ";\n")
        }
        close_statement_scope(e, saved)
    }
    e.current_return_restore = saved_ret
    e.match_counter = saved_match_counter
    e.locals = map.make()
    push(e, "}\n\n")
}

let c_type_is_pointer(ct: string): bool = {
    if len(ct) == 0 { return false }
    strings.byte_at(ct, len(ct) - 1) == 42
}

// Emit every struct definition (non-generic decl and generic instantiation)
// in dependency order, so by-value field types are defined before the
// struct that contains them.
let emit_records_topological(e: *Emitter, f: ast.File) = {
    var names: Vec<string> = vec.make()
    var field_lists: Vec<Vec<ast.StructField>> = vec.make()
    for d in f.decls {
        match d {
        | DStruct(_, name, params, fields) -> {
            if len(params) == 0 {
                vec.push(&names, name)
                vec.push(&field_lists, fields)
            }
        }
        | _ -> { }
        }
    }
    for inst in e.record_insts {
        match map.get(&e.generic_decls, inst.name) {
        | Some(decl) -> {
            match decl {
            | DStruct(_, _, params, fields) -> {
                var subst_fields: Vec<ast.StructField> = vec.make()
                for fld in fields {
                    vec.push(&subst_fields, ast.StructField {
                        name: fld.name,
                        ty:   substitute_type(e, fld.ty, params, inst.args),
                    })
                }
                vec.push(&names, inst.mangled)
                vec.push(&field_lists, subst_fields)
            }
            | _ -> { }
            }
        }
        | None -> { }
        }
    }
    var visited: Map<string, bool> = map.make()
    var i: i64 = 0
    while i < len(names) {
        emit_record_visit(e, names[i], names, field_lists, &visited)
        i += 1
    }
}

let emit_record_visit(e: *Emitter, name: string, names: Vec<string>, field_lists: Vec<Vec<ast.StructField>>, visited: *Map<string, bool>) = {
    if map.contains(visited, name) { return }
    map.set(visited, name, true)
    var i: i64 = 0
    while i < len(names) {
        if strings.eq_raw(names[i], name) {
            let fields = field_lists[i]
            for fld in fields {
                match value_field_dep(e, fld.ty) {
                | Some(dep) -> emit_record_visit(e, dep, names, field_lists, visited)
                | None      -> { }
                }
            }
            emit_struct(e, name, fields)
            return
        }
        i += 1
    }
}

// Return the C-side struct name a value-typed field depends on, or None
// when the field is a pointer, primitive, or ADT (ADTs are always
// pointers in the emitted C).
let value_field_dep(e: *Emitter, te: ast.TypeExpr): Option<string> = {
    match te {
    | TENamed(_, path, args) -> {
        if len(path) < 1 { return None }
        let n = path[len(path) - 1]
        if !strings.eq_raw(primitive_c_name(n), "") { return None }
        if map.contains(&e.is_enum, n) { return None }
        if len(args) > 0 { return Some(mangle_inst(e, n, args)) }
        Some(n)
    }
    | _ -> None
    }
}

let is_main(name: string): bool = strings.eq_raw(name, "main")

// Remove the cross-file #include directives so the inlined sources
// compile as a single translation unit.
let strip_runtime_includes(src: string): string = {
    var out = src
    out = strings.replace_all(out, "#include \"gc.h\"\n", "")
    out = strings.replace_all(out, "#include \"qoz_runtime.h\"\n", "")
    out
}

let emit_program(f: ast.File, expr_types: Map<i64, ast.TypeExpr>): string = {
    var e = make_emitter()
    e.expr_types = expr_types
    strings.sb_init(&e.out)
    register_variants(&e, f)
    register_generics(&e, f)
    collect_type_instantiations(&e, f)
    push(&e, "/* embedded runtime: gc.h */\n")
    push(&e, strip_runtime_includes(#load_string("runtime/gc.h")))
    push(&e, "\n/* embedded runtime: qoz_runtime.h */\n")
    push(&e, strip_runtime_includes(#load_string("runtime/qoz_runtime.h")))
    push(&e, "\n/* embedded runtime: gc.c */\n")
    push(&e, strip_runtime_includes(#load_string("runtime/gc.c")))
    push(&e, "\n/* embedded runtime: qoz_runtime.c */\n")
    push(&e, strip_runtime_includes(#load_string("runtime/qoz_runtime.c")))
    push(&e, "\n/* user code */\n")
    e.pos_fn_typedefs    = strings.sb_len(&e.out)
    e.pos_tuple_typedefs = strings.sb_len(&e.out)
    // Forward declare monomorphized records and enums first, then emit
    // the synth fn decls (byval forwarders, closure prototypes) which
    // can reference those typedefs by name.
    for inst in e.record_insts {
        push(&e, "typedef struct qoz_")
        push(&e, inst.mangled)
        push(&e, " qoz_")
        push(&e, inst.mangled)
        push(&e, ";\n")
    }
    for inst in e.enum_insts {
        push(&e, "typedef struct qoz_")
        push(&e, inst.mangled)
        push(&e, " qoz_")
        push(&e, inst.mangled)
        push(&e, ";\n")
        e.is_enum[inst.mangled] = true
    }
    push(&e, "\n")
    // Forward declarations: user-declared records and enums. Done
    // before SYNTH_FN_DECLS so the byval forwarders can reference
    // them by name in their signatures.
    for d in f.decls {
        match d {
        | DStruct(_, name, params, _) -> {
            if len(params) == 0 {
                push(&e, "typedef struct qoz_")
                push(&e, name)
                push(&e, " qoz_")
                push(&e, name)
                push(&e, ";\n")
            }
        }
        | DEnum(_, name, params, _) -> {
            if len(params) == 0 {
                push(&e, "typedef struct qoz_")
                push(&e, name)
                push(&e, " qoz_")
                push(&e, name)
                push(&e, ";\n")
            }
        }
        | _ -> { }
        }
    }
    push(&e, "\n")
    e.pos_synth_fn_decls = strings.sb_len(&e.out)
    emit_records_topological(&e, f)
    // Enum definitions (non-generic).
    for d in f.decls {
        match d {
        | DEnum(_, name, params, variants) -> {
            if len(params) == 0 {
                emit_enum(&e, name, variants)
            }
        }
        | _ -> { }
        }
    }
    // Generic enum instantiations.
    for inst in e.enum_insts {
        match map.get(&e.generic_decls, inst.name) {
        | Some(decl) -> {
            match decl {
            | DEnum(_, _, params, variants) -> {
                var subst_variants: Vec<ast.VariantDecl> = vec.make()
                for v in variants {
                    var new_pos: Vec<ast.TypeExpr> = vec.make()
                    for pt in v.pos { vec.push(&new_pos, substitute_type(&e, pt, params, inst.args)) }
                    var new_named: Vec<ast.StructField> = vec.make()
                    for nf in v.named { vec.push(&new_named, ast.StructField { name: nf.name, ty: substitute_type(&e, nf.ty, params, inst.args) }) }
                    vec.push(&subst_variants, ast.VariantDecl {
                        span:  v.span,
                        name:  v.name,
                        kind:  v.kind,
                        pos:   new_pos,
                        named: new_named,
                    })
                }
                emit_enum(&e, inst.mangled, subst_variants)
                for v in subst_variants {
                    emit_variant_ctor(&e, inst.mangled, v)
                }
            }
            | _ -> { }
            }
        }
        | None -> { }
        }
    }
    // Variant constructors (non-generic).
    for d in f.decls {
        match d {
        | DEnum(_, name, params, variants) -> {
            if len(params) == 0 {
                for v in variants {
                    emit_variant_ctor(&e, name, v)
                }
            }
        }
        | _ -> { }
        }
    }
    // Function prototypes (non-generic only. Generics emit their own).
    for d in f.decls {
        match d {
        | DFn(_, name, tparams, params, ret, _, _) -> {
            if !is_main(name) && len(tparams) == 0 {
                emit_fn_proto(&e, name, params, ret)
            }
        }
        | DExternal(_, _, symbol, params, ret) -> {
            emit_extern_proto(&e, symbol, params, ret)
        }
        | DConst(_, name, ty, value) -> {
            let resolved_ty = if is_unit_typeexpr(ty) { infer_value_te(&e, value) } else { ty }
            var empty: Vec<ast.FnParam> = vec.make()
            emit_fn_proto(&e, name, empty, resolved_ty)
        }
        // Type declarations (DStruct, DEnum, DTypeAlias) contribute
        // typedefs through walk_decl_for_types. DImport and DLink
        // have no prototype shape.
        | _ -> { }
        }
    }
    // Generic function instantiation prototypes.
    for inst in e.fn_insts {
        match map.get(&e.generic_fn_decls, inst.name) {
        | Some(decl) -> {
            match decl {
            | DFn(_, _, tparams, params, ret, _, _) -> {
                var subst_params: Vec<ast.FnParam> = vec.make()
                for pp in params {
                    vec.push(&subst_params, ast.FnParam {
                        name: pp.name,
                        ty:   substitute_type(&e, pp.ty, tparams, inst.args),
                    })
                }
                let subst_ret = substitute_type(&e, ret, tparams, inst.args)
                emit_fn_proto(&e, strings.cat("qoz_", inst.mangled), subst_params, subst_ret)
            }
            | _ -> { }
            }
        }
        | None -> { }
        }
    }
    push(&e, "\n")
    // Function bodies (non-generic only). Top-level constants emit
    // as zero-arg functions that return the declared value. The
    // package-qualified read path (`pkg.NAME`) lowers to a call.
    // Treating constants as functions sidesteps the C constraint
    // that global initializers be compile-time constant.
    for d in f.decls {
        match d {
        | DFn(_, name, tparams, params, ret, body, _) -> {
            if is_main(name) {
                emit_main(&e, ret, body)
            } elif len(tparams) == 0 {
                emit_fn(&e, name, params, ret, body)
            }
        }
        | DConst(_, name, ty, value) -> {
            let resolved_ty = if is_unit_typeexpr(ty) { infer_value_te(&e, value) } else { ty }
            var empty: Vec<ast.FnParam> = vec.make()
            emit_fn(&e, name, empty, resolved_ty, value)
        }
        // Other Decl kinds (DImport, DStruct, DEnum, DTypeAlias,
        // DExternal, DLink) emit no body here: types contribute to
        // typedef blocks elsewhere, externs declare without a body,
        // imports and link directives have no runtime form.
        | _ -> { }
        }
    }
    // Generic function instantiation bodies.
    for inst in e.fn_insts {
        match map.get(&e.generic_fn_decls, inst.name) {
        | Some(decl) -> {
            match decl {
            | DFn(_, _, tparams, params, ret, body, _) -> {
                var subst_params: Vec<ast.FnParam> = vec.make()
                for pp in params {
                    vec.push(&subst_params, ast.FnParam {
                        name: pp.name,
                        ty:   substitute_type(&e, pp.ty, tparams, inst.args),
                    })
                }
                let subst_ret = substitute_type(&e, ret, tparams, inst.args)
                let subst_body = substitute_expr(&e, body, tparams, inst.args)
                let saved_tparams = e.current_tparams
                let saved_targs   = e.current_targs
                e.current_tparams = tparams
                e.current_targs   = inst.args
                emit_fn(&e, strings.cat("qoz_", inst.mangled), subst_params, subst_ret, subst_body)
                e.current_tparams = saved_tparams
                e.current_targs   = saved_targs
            }
            | _ -> { }
            }
        }
        | None -> { }
        }
    }
    for s in e.synth_fn_defs {
        push(&e, s)
    }
    // Auto-derived show fns. Emitted after all user code so they can
    // call already-declared user helpers (struct field accesses, ADT
    // tag constants) without needing additional forward declarations.
    // The fns themselves are forward-declared inside synth_fn_decls at
    // register time.
    var si: i64 = 0
    while si < len(e.show_order) {
        let m = e.show_order[si]
        if !map.contains(&e.show_emitted, m) {
            e.show_emitted[m] = true
            match map.get(&e.show_pending, m) {
            | Some(te) -> {
                let body = render_show_fn(&e, m, te)
                push(&e, body)
            }
            | None -> { }
            }
        }
        si += 1
    }
    render(&e)
}

let emit_enum(e: *Emitter, name: string, variants: Vec<ast.VariantDecl>) = {
    push(e, "typedef enum {\n")
    var i: i64 = 0
    for v in variants {
        let vn = v.name
        push(e, `    qoz_{name}_{vn},\n`)
        i += 1
    }
    push(e, `}} qoz_{name}_tag;\n\n`)
    for v in variants {
        if variant_has_positional(v) {
            let vn = v.name
            push(e, "typedef struct {\n")
            var k: i64 = 0
            for pt in v.pos {
                let pc = c_type_for(e, pt)
                let ks = int_to_string(k)
                push(e, `    {pc} f{ks};\n`)
                k += 1
            }
            push(e, `}} qoz_{name}_{vn}_payload;\n\n`)
        }
    }
    push(e, `struct qoz_{name} {{\n    qoz_{name}_tag tag;\n`)
    var any_payload = false
    for v in variants {
        if variant_has_positional(v) { any_payload = true }
    }
    if any_payload {
        push(e, "    union {\n")
        for v in variants {
            if variant_has_positional(v) {
                let vn = v.name
                push(e, `        qoz_{name}_{vn}_payload {vn};\n`)
            }
        }
        push(e, "    } payload;\n")
    }
    push(e, "};\n\n")
    emit_adt_desc(e, name, variants)
}

let variant_has_positional(v: ast.VariantDecl): bool = len(v.pos) > 0

let int_to_string(n: i64): string = `{n}`

let emit_variant_ctor(e: *Emitter, enum_name: string, v: ast.VariantDecl) = {
    let vn = v.name
    push(e, `static qoz_{enum_name} *qoz_make_{enum_name}_{vn}`)
    if !variant_has_positional(v) {
        push(e, "(void) {\n")
    } else {
        push(e, "(")
        var k: i64 = 0
        for pt in v.pos {
            if k > 0 { push(e, ", ") }
            let pc = c_type_for(e, pt)
            let ks = int_to_string(k)
            push(e, `{pc} f{ks}`)
            k += 1
        }
        push(e, ") {\n")
    }
    push(e, `    qoz_{enum_name} *p = qoz_gc_alloc(sizeof(qoz_{enum_name}), &qoz_{enum_name}_desc);\n`)
    push(e, `    p->tag = qoz_{enum_name}_{vn};\n`)
    if variant_has_positional(v) {
        var j: i64 = 0
        for _ in v.pos {
            let js = int_to_string(j)
            push(e, `    p->payload.{vn}.f{js} = f{js};\n`)
            j += 1
        }
    }
    push(e, "    return p;\n}\n\n")
}

// True when a field of the given TypeExpr is a managed pointer in C.
// Step 2 minimal scope: direct pointer fields and ADT references. String,
// Vec, and Map fields will be added once those types' internal pointer
// offsets are wired in.
// Append to `out` one C constant-expression per managed-pointer slot
// stored within field `field` of the parent C aggregate identified by
// `parent` (a C type-name fragment usable inside `offsetof(parent, X)`).
// String fields contribute two slots (.data and .root). Vec and Map
// fields contribute one slot at the first pointer-sized word, since
// those structs hold their backing-buffer pointer first by convention.
// Non-generic user record fields recurse into their inner fields with
// composed offsets.
let collect_field_ptr_offsets(e: *Emitter, parent: string, field: string, te: ast.TypeExpr, out: *Vec<string>) = {
    let base = strings.cat("offsetof(", strings.cat(parent, strings.cat(", ", strings.cat(field, ")"))))
    match te {
    | TEPtr(_, _) -> {
        vec.push(out, strings.cat("(int32_t)", base))
    }
    | TENamed(_, path, args) -> {
        if len(path) >= 1 {
            let n = path[len(path) - 1]
            if map.contains(&e.is_enum, n) {
                vec.push(out, strings.cat("(int32_t)", base))
                return
            }
            if strings.eq_raw(n, "string") {
                vec.push(out, strings.cat("(int32_t)(", strings.cat(base, " + offsetof(qoz_string, data))")))
                vec.push(out, strings.cat("(int32_t)(", strings.cat(base, " + offsetof(qoz_string, root))")))
                return
            }
            if strings.eq_raw(n, "Vec") || strings.eq_raw(n, "Map") {
                vec.push(out, strings.cat("(int32_t)", base))
                return
            }
            // Non-generic user record: recurse into its fields and
            // compose offsetof expressions. Generic instantiations
            // (args != empty) are left opaque for now since computing
            // the mangled C struct name is non-trivial here.
            if len(args) == 0 {
                match map.get(&e.struct_decls, n) {
                | Some(d) -> {
                    match d {
                    | DStruct(_, _, params, fields) -> {
                        if len(params) == 0 {
                            let inner_parent = strings.cat("struct qoz_", n)
                            for sf in fields {
                                let composed_parent = inner_parent
                                let composed_field  = sf.name
                                // Build "(int32_t)(offsetof(parent, field) + offsetof(inner_parent, composed_field))"
                                // by capturing each inner offset, then prefixing with our base offset.
                                var inner_offsets: Vec<string> = vec.make()
                                collect_field_ptr_offsets(e, composed_parent, composed_field, sf.ty, &inner_offsets)
                                for inner in inner_offsets {
                                    // inner is "(int32_t)offsetof(...)" or "(int32_t)(offsetof(...) + ...)"
                                    // Reframe as the sum with `base`.
                                    let stripped = strings.slice(inner, 9, len(inner))   // drop "(int32_t)"
                                    vec.push(out, strings.cat("(int32_t)(", strings.cat(base, strings.cat(" + ", strings.cat(stripped, ")")))))
                                }
                            }
                            return
                        }
                    }
                    | _ -> { }
                    }
                }
                | None -> { }
                }
            }
        }
    }
    | _ -> { }
    }
}

let emit_record_desc(e: *Emitter, name: string, fields: Vec<ast.StructField>) = {
    let parent = strings.cat("struct qoz_", name)
    var offsets: Vec<string> = vec.make()
    for f in fields {
        collect_field_ptr_offsets(e, parent, f.name, f.ty, &offsets)
    }
    let nptrs = len(offsets)
    if nptrs > 0 {
        push(e, `static const int32_t qoz_{name}_offsets[] = {{ `)
        var i: i64 = 0
        for expr in offsets {
            if i > 0 { push(e, ", ") }
            push(e, expr)
            i += 1
        }
        push(e, " };\n")
    }
    if nptrs == 0 {
        push(e, `static const qoz_type_desc qoz_{name}_desc = {{ QOZ_DESC_LEAF, (int32_t)sizeof(struct qoz_{name}), 0, NULL, 0, 0, 0, NULL, \"{name}\" }};\n\n`)
    } else {
        let np = int_to_string(nptrs)
        push(e, `static const qoz_type_desc qoz_{name}_desc = {{ QOZ_DESC_OFFSETS, (int32_t)sizeof(struct qoz_{name}), {np}, qoz_{name}_offsets, 0, 0, 0, NULL, \"{name}\" }};\n\n`)
    }
}

// Collect the offset expressions for every managed-pointer slot inside
// one ADT variant's positional payload. Returns an empty Vec for
// variants with no payload, no positional fields, or no pointer slots.
let collect_variant_ptr_offsets(e: *Emitter, enum_name: string, v: ast.VariantDecl): Vec<string> = {
    var out: Vec<string> = vec.make()
    let parent = strings.cat("qoz_", strings.cat(enum_name, strings.cat("_", strings.cat(v.name, "_payload"))))
    if variant_has_positional(v) {
        var i: i64 = 0
        for pt in v.pos {
            let field = strings.cat("f", int_to_string(i))
            collect_field_ptr_offsets(e, parent, field, pt, &out)
            i += 1
        }
        return out
    }
    // Named-field variants emit the payload struct with the declared
    // field names, not f<n>.
    for sf in v.named {
        collect_field_ptr_offsets(e, parent, sf.name, sf.ty, &out)
    }
    out
}

// Emit an ADT descriptor with per-variant pointer-offset tables.
let emit_adt_desc(e: *Emitter, name: string, variants: Vec<ast.VariantDecl>) = {
    // Per-variant offset arrays for positional payloads. Named-field
    // payloads share the `f<n>` slot convention since the variant's
    // payload struct mirrors the declared field order. Named-field
    // ADTs still come later.
    for v in variants {
        let voffs = collect_variant_ptr_offsets(e, name, v)
        if len(voffs) > 0 {
            let vn = v.name
            push(e, `static const int32_t qoz_{name}_{vn}_offsets[] = {{ `)
            var j: i64 = 0
            for expr in voffs {
                if j > 0 { push(e, ", ") }
                push(e, expr)
                j += 1
            }
            push(e, " };\n")
        }
    }
    push(e, `static const qoz_variant_desc qoz_{name}_variants[] = {{\n`)
    for v in variants {
        let voffs = collect_variant_ptr_offsets(e, name, v)
        let nptrs = len(voffs)
        let vn = v.name
        let np = int_to_string(nptrs)
        if nptrs > 0 {
            push(e, `    {{ qoz_{name}_{vn}, {np}, qoz_{name}_{vn}_offsets }},\n`)
        } else {
            push(e, `    {{ qoz_{name}_{vn}, {np}, NULL }},\n`)
        }
    }
    push(e, "};\n")
    var any_payload2 = false
    for v in variants {
        if variant_has_positional(v) { any_payload2 = true }
    }
    let payload_off_expr = if any_payload2 {
        strings.cat("(int32_t)offsetof(struct qoz_", strings.cat(name, ", payload)"))
    } else {
        "0"
    }
    let nvar = int_to_string(len(variants))
    push(e, `static const qoz_type_desc qoz_{name}_desc = { QOZ_DESC_ADT, (int32_t)sizeof(struct qoz_{name}), 0, NULL, (int32_t)offsetof(struct qoz_{name}, tag), {payload_off_expr}, {nvar}, qoz_{name}_variants, \"{name}\" };\n\n`)
}

let emit_struct(e: *Emitter, name: string, fields: Vec<ast.StructField>) = {
    push(e, `struct qoz_{name} {{\n`)
    for f in fields {
        let ct = c_type_for(e, f.ty)
        let fname = f.name
        push(e, `    {ct} {fname};\n`)
    }
    push(e, "};\n\n")
    emit_record_eq(e, name, fields)
    emit_record_desc(e, name, fields)
}

let emit_record_eq(e: *Emitter, name: string, fields: Vec<ast.StructField>) = {
    push(e, `static bool qoz_eq_{name}(qoz_{name} a, qoz_{name} b) {{\n    return `)
    if len(fields) == 0 {
        push(e, "true")
    } else {
        var i: i64 = 0
        for f in fields {
            if i > 0 { push(e, " && ") }
            emit_field_eq_expr(e, f.ty, f.name)
            i += 1
        }
    }
    push(e, ";\n}\n\n")
    emit_record_hash(e, name, fields)
}

let emit_record_hash(e: *Emitter, name: string, fields: Vec<ast.StructField>) = {
    push(e, `static uint64_t qoz_hash_{name}(qoz_{name} v) {{\n    uint64_t h = 0;\n`)
    for f in fields {
        push(e, "    h = h * 31 + (uint64_t)(")
        emit_field_hash_expr(e, f.ty, f.name)
        push(e, ");\n")
    }
    push(e, "    return h;\n}\n\n")
}

let emit_field_hash_expr(e: *Emitter, te: ast.TypeExpr, fname: string) = {
    let ct = c_type_for(e, te)
    if strings.eq_raw(ct, "qoz_string") {
        push(e, `qoz_string_hash(v.{fname})`)
        return
    }
    match te {
    | TENamed(_, path, args) -> {
        if len(path) >= 1 {
            let n = path[len(path) - 1]
            // C-style enum is a typedefed integer at runtime;
            // hash and equality lower to the underlying scalar
            // ops rather than a generated helper.
            if map.contains(&e.c_enum_decls, n) {
                push(e, `(uint64_t)(v.{fname})`)
                return
            }
            if strings.eq_raw(primitive_c_name(n), "") {
                if !map.contains(&e.is_enum, n) {
                    let mangled = if len(args) > 0 { mangle_inst(e, n, args) } else { n }
                    push(e, `qoz_hash_{mangled}(v.{fname})`)
                    return
                }
            }
        }
    }
    | _ -> { }
    }
    push(e, `v.{fname}`)
}

let emit_field_eq_expr(e: *Emitter, te: ast.TypeExpr, fname: string) = {
    let ct = c_type_for(e, te)
    if strings.eq_raw(ct, "qoz_string") {
        push(e, `qoz_string_eq(a.{fname}, b.{fname})`)
        return
    }
    match te {
    | TENamed(_, path, args) -> {
        if len(path) >= 1 {
            let n = path[len(path) - 1]
            if map.contains(&e.c_enum_decls, n) {
                push(e, `a.{fname} == b.{fname}`)
                return
            }
            if strings.eq_raw(primitive_c_name(n), "") {
                if !map.contains(&e.is_enum, n) {
                    let mangled = if len(args) > 0 { mangle_inst(e, n, args) } else { n }
                    push(e, `qoz_eq_{mangled}(a.{fname}, b.{fname})`)
                    return
                }
            }
        }
    }
    | _ -> { }
    }
    push(e, `a.{fname} == b.{fname}`)
}

let emit_fn_proto(e: *Emitter, name: string, params: Vec<ast.FnParam>, ret: ast.TypeExpr) = {
    let rc = c_type_for(e, ret)
    let c_name = user_fn_c_name(name)
    push(e, `{rc} {c_name}`)
    if len(params) == 0 {
        push(e, "(void);\n")
        return
    }
    push(e, "(")
    var i: i64 = 0
    for p in params {
        if i > 0 { push(e, ", ") }
        let pc = c_type_for(e, p.ty)
        let pn = p.name
        push(e, `{pc} {pn}`)
        i += 1
    }
    push(e, ");\n")
}

let emit_extern_proto(e: *Emitter, symbol: string, params: Vec<ast.FnParam>, ret: ast.TypeExpr) = {
    let rc = c_type_for(e, ret)
    push(e, `extern {rc} {symbol}`)
    if len(params) == 0 {
        push(e, "(void);\n")
        return
    }
    push(e, "(")
    var i: i64 = 0
    for p in params {
        if i > 0 { push(e, ", ") }
        push(e, c_type_for(e, p.ty))
        i += 1
    }
    push(e, ");\n")
}

let is_range_op(op: ast.BinaryOp): bool =
    match op {
    | BOpRange          -> true
    | BOpRangeInclusive -> true
    | _                 -> false
    }

let range_cmp_op(op: ast.BinaryOp): string =
    match op {
    | BOpRangeInclusive -> "<="
    | _                 -> "<"
    }

// EWhile/EFor/EAssign in a block's tail position are statements with no
// value. Emit them as a C comma-expression `(expr_form, 0)` so the
// expression can appear inside a ternary or other expression context.
// EAssign already emits as an expression form (`lhs = rhs` without `;`),
// so it goes through directly. EFor/EWhile cannot appear as
// expressions in C. For those, hoist the loop to the enclosing
// statement's prologue and leave 0 in place.
let emit_block_tail_as_value(e: *Emitter, tail: ast.Expr) = {
    match tail {
    | EAssign(sp, op, lhs, rhs) -> {
        assert_plain_assign(op, sp)
        push(e, "(")
        emit_assign(e, lhs, rhs)
        push(e, ", 0)")
    }
    | EWhile(_, _, _) | EFor(_, _, _, _, _) | EDefer(_, _) -> {
        let start = strings.sb_len(&e.out)
        emit_stmt_expr(e, tail)
        hoist_to_prologue(e, start)
        push(e, "0")
    }
    | EIf(_, _, _, f) -> {
        // An `if` whose else branch is missing, or whose branches both
        // yield unit, has no value. Emit it as a C statement (hoisted to
        // the surrounding prologue) and leave 0 in the expression slot.
        let unit_if = is_nil_expr(f) || is_unit_typeexpr(infer_value_te(e, tail))
        if unit_if {
            let start = strings.sb_len(&e.out)
            emit_stmt_expr(e, tail)
            hoist_to_prologue(e, start)
            push(e, "0")
        } else {
            emit_expr(e, tail)
        }
    }
    | _ -> emit_expr(e, tail)
    }
}

// True when `hint` is the `cstring` type. A string literal flowing into
// a cstring-typed parameter lowers to a bare C string literal rather
// than a qoz_string struct value, matching what the FFI expects.
let hint_is_unsigned_int(hint: ast.TypeExpr): bool = {
    match hint {
    | TENamed(_, path, _) -> {
        if len(path) != 1 { return false }
        let n = path[0]
        strings.eq_raw(n, "u8") || strings.eq_raw(n, "u16")
            || strings.eq_raw(n, "u32") || strings.eq_raw(n, "u64")
    }
    | _ -> false
    }
}

let hint_is_cstring(hint: ast.TypeExpr): bool = {
    match hint {
    | TENamed(_, path, _) -> len(path) == 1 && strings.eq_raw(path[0], "cstring")
    | _ -> false
    }
}

let emit_value_with_hint(e: *Emitter, value: ast.Expr, hint: ast.TypeExpr) = {
    match value {
    | EString(_, raw) -> {
        if hint_is_cstring(hint) {
            push(e, raw)
        } else {
            push(e, `QOZ_STR_LIT({raw})`)
        }
        return
    }
    | EInt(_, text) -> {
        // An integer literal whose hint is an unsigned type gets the
        // `ULL` C suffix. Otherwise clang under -Werror flags any
        // literal that exceeds INT64_MAX as "implicitly unsigned".
        let cleaned = strip_numeric_underscores(text)
        if hint_is_unsigned_int(hint) {
            push(e, cleaned)
            push(e, "ULL")
        } else {
            push(e, cleaned)
        }
        return
    }
    | _ -> { }
    }
    match value {
    | ERecord(_, te, fields) -> emit_record_lit_with_hint(e, te, fields, hint)
    | ECall(_, callee, ta, args) -> emit_call_with_hint(e, callee, ta, args, hint)
    | EIdent(_, name) -> emit_ident_with_hint(e, name, hint)
    | EArrayLit(sp, elems) -> emit_array_lit_with_hint(e, sp, elems, hint)
    | EField(_, base, name) -> {
        // `Enum.Variant` in value position with a known type hint
        // (e.g. `let a: Option<i32> = Option.None`) emits the mangled
        // constructor so the result type matches the binding's type.
        let did_emit = emit_qualified_variant_with_hint(e, base, name, hint)
        if !did_emit { emit_field(e, base, name) }
    }
    | EBlock(sp, stmts, tail) -> {
        // A block with no statements is just its tail expression. Emit
        // it directly, without wrapping in a GNU statement expression.
        if len(stmts) == 0 {
            match tail {
            | EWhile(_, _, _) | EFor(_, _, _, _, _) | EAssign(_, _, _, _) -> {
                push(e, "((")
                emit_stmt_expr(e, tail)
                push(e, "), 0)")
            }
            | _ -> emit_value_with_hint(e, tail, hint)
            }
            return
        }
        // Hoist the block's statements into pending_prologue. Declare
        // a result temp at the enclosing scope, run the statements in a
        // fresh C compound so the block's locals stay scoped, and
        // assign the tail expression into the temp. The use site reads
        // the temp.
        e.closure_counter = e.closure_counter + 1
        let counter = e.closure_counter
        let tmp_res = strings.cat("_qoz_bv_", `{counter}`)
        let result_c = c_type_for(e, hint)
        let start = strings.sb_len(&e.out)
        push(e, `{result_c} {tmp_res};\n    {{\n        `)
        for s in stmts { emit_stmt(e, s) }
        match tail {
        | EWhile(_, _, _) | EFor(_, _, _, _, _) | EAssign(_, _, _, _) -> {
            let saved = open_statement_scope(e)
            emit_stmt_expr(e, tail)
            close_statement_scope(e, saved)
            push(e, `\n        {tmp_res} = 0;\n    `)
        }
        | _ -> {
            let saved = open_statement_scope(e)
            push(e, `{tmp_res} = `)
            emit_value_with_hint(e, tail, hint)
            push(e, ";\n    ")
            close_statement_scope(e, saved)
        }
        }
        push(e, "}\n    ")
        hoist_to_prologue(e, start)
        push(e, tmp_res)
    }
    | EIf(sp, c, t, f) -> {
        push(e, "(")
        emit_cond(e, c)
        push(e, " ? ")
        emit_value_with_hint(e, t, hint)
        push(e, " : ")
        emit_value_with_hint(e, f, hint)
        push(e, ")")
    }
    | EMatch(sp, scrut, arms) -> emit_match_as_expr_with_hint(e, sp, scrut, arms, hint)
    | _                      -> emit_expr(e, value)
    }
}

let emit_match_as_expr_with_hint(e: *Emitter, sp: ast.Span, scrut: ast.Expr, arms: Vec<ast.MatchArm>, hint: ast.TypeExpr) = {
    let saved_hint = e.match_hint
    e.match_hint = hint
    emit_match_as_expr(e, sp, scrut, arms)
    e.match_hint = saved_hint
}

// Returns true when `base.name` is `Enum.Variant` and the unit-payload
// constructor was emitted with the type hint folded into the mangled
// enum name. False otherwise. The caller falls back to the normal
// field-access emit.
let emit_qualified_variant_with_hint(e: *Emitter, base: ast.Expr, name: string, hint: ast.TypeExpr): bool = {
    match base {
    | EIdent(_, enum_name) -> {
        if !map.contains(&e.enum_decls, enum_name) { return false }
        match map.get(&e.variant_of, name) {
        | Some(_) -> {
            let hint_args = hint_args_for_enum(hint, enum_name)
            if len(hint_args) > 0 {
                let mangled = mangle_inst(e, enum_name, hint_args)
                push(e, `qoz_make_{mangled}_{name}()`)
            } else {
                push(e, `qoz_make_{enum_name}_{name}()`)
            }
            true
        }
        | None -> false
        }
    }
    | _ -> false
    }
}

let emit_ident_with_hint(e: *Emitter, name: string, hint: ast.TypeExpr) = {
    match map.get(&e.variant_of, name) {
    | Some(enum_name) -> {
        let hint_args = hint_args_for_enum(hint, enum_name)
        if len(hint_args) > 0 {
            let mangled = mangle_inst(e, enum_name, hint_args)
            push(e, `qoz_make_{mangled}_{name}()`)
            return
        }
        push(e, `qoz_make_{enum_name}_{name}()`)
    }
    | None -> {
        if map.contains(&e.consts, name) {
            push(e, `qoz_{name}()`)
            return
        }
        // Plain top-level function used as a fn-typed value: wrap with an
        // adapter thunk so the value matches the {env, fn} closure ABI.
        match hint {
        | TEFn(_, fn_ps, fn_ret) -> {
            if map.contains(&e.fn_params, name) {
                if !map.contains(&e.locals, name) {
                    let thunk = register_fn_thunk(e, name, fn_ps, fn_ret)
                    let clo_t = c_type_for(e, hint)
                    push(e, `(({clo_t}){{ .env = NULL, .fn = {thunk} }})`)
                    return
                }
            }
        }
        | _ -> { }
        }
        push(e, name)
    }
    }
}

let register_fn_thunk(e: *Emitter, fn_name: string, params: Vec<ast.TypeExpr>, ret: ast.TypeExpr): string = {
    var key = fn_name
    key = strings.cat(key, "__thunk")
    if map.contains(&e.fn_typedefs, key) {
        return key
    }
    // Reuse the typedef registry's `contains` map to avoid re-emitting. We
    // store an empty body since the actual implementation goes into the
    // synth-decls / synth-defs buffers below.
    e.fn_typedefs[key] = ""
    var sig = "static "
    sig = strings.cat(sig, c_type_for(e, ret))
    sig = strings.cat(sig, " ")
    sig = strings.cat(sig, key)
    sig = strings.cat(sig, "(void *_qoz_env")
    var pi: i64 = 0
    for p in params {
        sig = strings.cat(sig, ", ")
        sig = strings.cat(sig, c_type_for(e, p))
        sig = strings.cat(sig, " _p")
        sig = strings.cat(sig, int_to_string(pi))
        pi += 1
    }
    let sig_decl = strings.cat(sig, ");\n")
    vec.push(&e.synth_fn_decls, sig_decl)

    var def = sig
    def = strings.cat(def, ") {\n    (void)_qoz_env;\n    ")
    let call_name = user_fn_c_name(fn_name)
    if is_unit_typeexpr(ret) {
        def = strings.cat(def, call_name)
        def = strings.cat(def, "(")
        var pj: i64 = 0
        for _p in params {
            if pj > 0 { def = strings.cat(def, ", ") }
            def = strings.cat(def, "_p")
            def = strings.cat(def, int_to_string(pj))
            pj += 1
        }
        def = strings.cat(def, ");\n    return;\n")
    } else {
        def = strings.cat(def, "return ")
        def = strings.cat(def, call_name)
        def = strings.cat(def, "(")
        var pj: i64 = 0
        for _p in params {
            if pj > 0 { def = strings.cat(def, ", ") }
            def = strings.cat(def, "_p")
            def = strings.cat(def, int_to_string(pj))
            pj += 1
        }
        def = strings.cat(def, ");\n")
    }
    def = strings.cat(def, "}\n\n")
    vec.push(&e.synth_fn_defs, def)
    key
}

// When a call's result feeds into a typed context (a let binding, a fn
// return slot, or a record-literal field) and the callee is a generic
// variant constructor like Some/None, the hint supplies the type args
// the source did not write explicitly. Rewrite to the mangled ctor.
let emit_call_with_hint(e: *Emitter, callee: ast.Expr, type_args: Vec<ast.TypeExpr>, args: Vec<ast.Expr>, hint: ast.TypeExpr) = {
    if len(type_args) > 0 {
        emit_call(e, callee, type_args, args)
        return
    }
    // Variant constructor with a known enclosing-type hint: emit the
    // mangled `qoz_make_<Enum__T1__T2>_<Variant>` constructor so the
    // result type matches the surrounding binding's declared type.
    // Accepts bare `Variant(...)`, qualified EField `Enum.Variant(...)`,
    // and qualified EPath `Enum::Variant(...)`.
    let variant_name = variant_callee_name(e, callee)
    if !strings.eq_raw(variant_name, "") {
        let enum_name = resolve_variant_enum(e, callee, variant_name)
        if !strings.eq_raw(enum_name, "") {
            let hint_args = hint_args_for_enum(hint, enum_name)
            if len(hint_args) > 0 {
                let mangled = mangle_inst(e, enum_name, hint_args)
                push(e, `qoz_make_{mangled}_{variant_name}(`)
                // Substitute the enum's tparams with the hint's args so
                // each positional payload gets the right concrete type
                // hint propagated into its emission. Without this a
                // nested variant constructor like `Some(None)` in a
                // `Option<Option<i64>>` context loses the inner T and
                // falls back to the wrong instantiation.
                let payload_hints = variant_payload_hints(e, enum_name, variant_name, hint_args)
                var i: i64 = 0
                for a in args {
                    if i > 0 { push(e, ", ") }
                    if i < len(payload_hints) {
                        emit_value_with_hint(e, a, payload_hints[i])
                    } else {
                        emit_expr(e, a)
                    }
                    i += 1
                }
                push(e, ")")
                return
            }
        }
    }
    emit_call(e, callee, type_args, args)
}

// Resolve the positional payload TypeExprs of `variant` in `enum_name`,
// substituted with `hint_args` for the enum's tparams. Used to hand a
// concrete type hint to each argument of a nested variant
// constructor.
let variant_payload_hints(e: *Emitter, enum_name: string, variant: string, hint_args: Vec<ast.TypeExpr>): Vec<ast.TypeExpr> = {
    var out: Vec<ast.TypeExpr> = vec.make()
    match map.get(&e.enum_decls, enum_name) {
    | None    -> out
    | Some(d) -> {
        match d {
        | DEnum(_, _, tparams, variants) -> {
            for v in variants {
                if strings.eq_raw(v.name, variant) {
                    for pte in v.pos {
                        if len(tparams) > 0 && len(hint_args) == len(tparams) {
                            vec.push(&out, substitute_type(e, pte, tparams, hint_args))
                        } else {
                            vec.push(&out, pte)
                        }
                    }
                }
            }
            out
        }
        | _ -> out
        }
    }
    }
}

let hint_args_for_enum(hint: ast.TypeExpr, enum_name: string): Vec<ast.TypeExpr> = {
    match hint {
    | TENamed(_, path, args) -> {
        if len(path) >= 1 {
            let last = path[len(path) - 1]
            if strings.eq_raw(last, enum_name) { return args }
        }
        vec.make()
    }
    | _ -> vec.make()
    }
}

let emit_record_lit_with_hint(e: *Emitter, te: ast.TypeExpr, fields: Vec<ast.RecordFieldLit>, hint: ast.TypeExpr) = {
    let effective = pick_type_with_args(te, hint)
    let expanded = expand_record_spread_fields(e, effective, fields)
    let ec = c_type_for(e, effective)
    push(e, `(({ec}){{ `)
    var i: i64 = 0
    for f in expanded {
        if i > 0 { push(e, ", ") }
        let fn = f.name
        push(e, `.{fn} = `)
        let field_hint = field_type_hint(e, effective, f.name)
        emit_value_with_hint(e, f.value, field_hint)
        i += 1
    }
    push(e, " })")
}

// Replace a `..base` sentinel field with explicit `field: base.field`
// entries for every field of the struct that the user did not write
// explicitly. The struct's declared field list is looked up through
// e.struct_decls. When the type is not a known struct the emit dies
// rather than let the sentinel reach the C output as a literal `...`.
let expand_record_spread_fields(e: *Emitter, te: ast.TypeExpr, fields: Vec<ast.RecordFieldLit>): Vec<ast.RecordFieldLit> = {
    var has_spread = false
    var sp = ast.Span { file: "", line: 0, col: 0 }
    var spread_base: ast.Expr = ENil(sp)
    var listed: Map<string, bool> = map.make()
    var i: i64 = 0
    while i < len(fields) {
        let f = fields[i]
        if strings.eq_raw(f.name, "..") {
            has_spread = true
            spread_base = f.value
            sp = span_of_expr(f.value)
        } else {
            listed[f.name] = true
        }
        i += 1
    }
    if !has_spread { return fields }

    let decl_field_names = struct_field_names_from_te(e, te)
    if len(decl_field_names) == 0 {
        let _ = emit_die(sp, "record spread `..base` requires a known struct type")
        return fields
    }

    var out: Vec<ast.RecordFieldLit> = vec.make()
    var j: i64 = 0
    while j < len(fields) {
        let f = fields[j]
        if !strings.eq_raw(f.name, "..") {
            vec.push(&out, f)
        }
        j += 1
    }
    var k: i64 = 0
    while k < len(decl_field_names) {
        let fname = decl_field_names[k]
        if !map.contains(&listed, fname) {
            vec.push(&out, ast.RecordFieldLit {
                name:  fname,
                value: EField(sp, spread_base, fname),
            })
        }
        k += 1
    }
    out
}

let struct_decl_field_names(fields: Vec<ast.StructField>): Vec<string> = {
    var out: Vec<string> = vec.make()
    var i: i64 = 0
    while i < len(fields) {
        vec.push(&out, fields[i].name)
        i += 1
    }
    out
}

let struct_field_names_from_te(e: *Emitter, te: ast.TypeExpr): Vec<string> = {
    let empty: Vec<string> = vec.make()
    var path_segments: Vec<string> = vec.make()
    match te {
    | TENamed(_, path, _) -> path_segments = path
    | _ -> { return empty }
    }
    if len(path_segments) < 1 { return empty }
    let key = type_lookup_key(e, path_segments)
    // e.struct_decls holds every DStruct declared in the program,
    // generic or not. No second registry is needed.
    match map.get(&e.struct_decls, key) {
    | Some(decl) -> {
        match decl {
        | DStruct(_, _, _, fs) -> struct_decl_field_names(fs)
        | _ -> empty
        }
    }
    | None -> empty
    }
}

// For a TENamed referring to a struct/enum, return the registry key under
// which the decl is stored in generic_decls. For `Vec` this is just `Vec`;
// for `vec.Vec` it is `vec_Vec` when the loader prefixed the decl, or
// `Vec` as a fallback when struct decls are not yet package-renamed.
let type_lookup_key(e: *Emitter, path: Vec<string>): string = {
    if len(path) == 1 { return path[0] }
    if len(path) == 2 {
        let qualified = strings.cat(strings.cat(path[0], "_"), path[1])
        if map.contains(&e.generic_decls, qualified) { return qualified }
        return path[1]
    }
    path[len(path) - 1]
}

let field_type_hint(e: *Emitter, te: ast.TypeExpr, field_name: string): ast.TypeExpr = {
    match te {
    | TENamed(sp, path, args) -> {
        if len(path) < 1 { return te }
        let name: string = type_lookup_key(e, path)
        if !map.contains(&e.generic_decls, name) { return te }
        match map.get(&e.generic_decls, name) {
        | Some(decl) -> {
            match decl {
            | DStruct(_, _, params, fields) -> {
                for sf in fields {
                    if strings.eq_raw(sf.name, field_name) {
                        if len(args) == len(params) {
                            return substitute_type(e, sf.ty, params, args)
                        }
                        return sf.ty
                    }
                }
                te
            }
            | _ -> te
            }
        }
        | None -> te
        }
    }
    | _ -> te
    }
}

let pick_type_with_args(te: ast.TypeExpr, hint: ast.TypeExpr): ast.TypeExpr = {
    match te {
    | TENamed(_, te_path, te_args) -> {
        if len(te_args) > 0 { return te }
        match hint {
        | TENamed(_, h_path, h_args) -> {
            if len(h_args) == 0 { return te }
            if len(h_path) == 1 && len(te_path) == 1 && strings.eq_raw(h_path[0], te_path[0]) {
                return hint
            }
            te
        }
        | _ -> te
        }
    }
    | _ -> te
    }
}

let emit_for_loop_one(e: *Emitter, binding: string, binding2: string, iter: ast.Expr, body: ast.Expr) = {
    // Range: lo..<hi or lo..=hi -> classic C for loop with int counter.
    match iter {
    | EBinary(_, op, lo, hi) -> {
        if is_range_op(op) {
            push(e, `for (int64_t {binding} = `)
            emit_expr(e, lo)
            let cmp = range_cmp_op(op)
            push(e, `; {binding} {cmp} `)
            emit_expr(e, hi)
            push(e, `; {binding}++) `)
            emit_branch_as_statement(e, body)
            return
        }
    }
    | _ -> { }
    }
    // Container iter: a single binding picks the Vec shape. Two pick the Map shape.
    if strings.eq_raw(binding2, "") {
        emit_vec_for(e, binding, iter, body)
    } else {
        emit_map_for(e, binding, binding2, iter, body)
    }
}

let emit_vec_for(e: *Emitter, binding: string, iter: ast.Expr, body: ast.Expr) = {
    let elem_te = vec_element_typeexpr(e, iter)
    e.locals[binding] = elem_te
    let col_ct  = c_type_for(e, infer_base_typeexpr(e, iter))
    let elem_ct = c_type_for(e, elem_te)
    push(e, `{{ {col_ct} __col = `)
    emit_expr(e, iter)
    push(e, `; for (int64_t __i = 0; __i < __col.len; __i++) {{ {elem_ct} {binding} = __col.data[__i]; (void){binding}; `)
    emit_branch_body_inline(e, body)
    push(e, "} }")
}

let vec_element_typeexpr(e: *Emitter, iter: ast.Expr): ast.TypeExpr = {
    let te = infer_base_typeexpr(e, iter)
    match te {
    | TENamed(sp, path, args) -> {
        if len(args) >= 1 && len(path) >= 1 && strings.eq_raw(path[len(path) - 1], "Vec") { return args[0] }
        TEUnit(sp)
    }
    | TEPtr(_, inner) -> inner
    | _ -> TEUnit(span_of_expr(iter))
    }
}

let emit_map_for(e: *Emitter, binding: string, binding2: string, iter: ast.Expr, body: ast.Expr) = {
    let iter_te = infer_base_typeexpr(e, iter)
    let col_ct  = c_type_for(e, iter_te)
    let key_te  = map_key_typeexpr(e, iter_te)
    let val_te  = map_val_typeexpr(e, iter_te)
    let key_ct  = c_type_for(e, key_te)
    let val_ct  = c_type_for(e, val_te)
    push(e, `{{ {col_ct} __col = `)
    emit_expr(e, iter)
    push(e, `; for (int64_t __i = 0; __i < __col.cap; __i++) {{ if (!__col.slots[__i].occupied || __col.slots[__i].deleted) continue; {key_ct} {binding} = __col.slots[__i].key; {val_ct} {binding2} = __col.slots[__i].value; (void){binding}; (void){binding2}; `)
    emit_branch_body_inline(e, body)
    push(e, "} }")
}

let map_key_typeexpr(e: *Emitter, te: ast.TypeExpr): ast.TypeExpr = {
    match te {
    | TENamed(sp, path, args) -> {
        if len(args) >= 2 && len(path) >= 1 && strings.eq_raw(path[len(path) - 1], "Map") { return args[0] }
        TEUnit(sp)
    }
    | _ -> TEUnit(ast.Span { file: "", line: 0, col: 0 })
    }
}

let map_val_typeexpr(e: *Emitter, te: ast.TypeExpr): ast.TypeExpr = {
    match te {
    | TENamed(sp, path, args) -> {
        if len(args) >= 2 && len(path) >= 1 && strings.eq_raw(path[len(path) - 1], "Map") { return args[1] }
        TEUnit(sp)
    }
    | _ -> TEUnit(ast.Span { file: "", line: 0, col: 0 })
    }
}

let emit_branch_body_inline(e: *Emitter, body: ast.Expr) = {
    match body {
    | EBlock(_, stmts, tail) -> {
        var defers = collect_defers_in_stmts(stmts)
        var effective_tail = tail
        match tail {
        | EDefer(_, dbody) -> {
            vec.push(&defers, dbody)
            effective_tail = ENil(span_of_expr(tail))
        }
        | _ -> { }
        }
        for s in stmts {
            emit_stmt(e, s)
        }
        if !is_nil_expr(effective_tail) {
            let saved = open_statement_scope(e)
            emit_stmt_expr(e, effective_tail)
            close_statement_scope(e, saved)
        }
        emit_defers_reverse(e, defers)
    }
    | _ -> {
        let saved = open_statement_scope(e)
        emit_stmt_expr(e, body)
        close_statement_scope(e, saved)
    }
    }
}

let find_enum_from_arms(e: *Emitter, arms: Vec<ast.MatchArm>): string = {
    for arm in arms {
        let en = bare_enum_for_pat(e, arm.pat)
        if !strings.eq_raw(en, "") { return en }
    }
    ""
}

// Variant that prefers the scrutinee's enum when the arm pattern's
// variant name is shared across multiple enums. variant_of stores
// only the first-loaded registration, which picks the wrong enum
// under variant-name collisions.
let find_enum_from_arms_with_scrut(e: *Emitter, arms: Vec<ast.MatchArm>, scrut_te: ast.TypeExpr): string = {
    let scrut_enum = enum_name_of_te(e, scrut_te)
    if strings.eq_raw(scrut_enum, "") { return find_enum_from_arms(e, arms) }
    for arm in arms {
        let v = variant_name_of_pat(arm.pat)
        if !strings.eq_raw(v, "") {
            if variant_belongs_to_enum(e, v, scrut_enum) { return scrut_enum }
        }
    }
    find_enum_from_arms(e, arms)
}

let variant_name_of_pat(p: ast.Pattern): string = {
    match p {
    | PatVariant(_, path, _) -> if len(path) > 0 { path[len(path) - 1] } else { "" }
    | PatBind(_, name)       -> name
    | _                      -> ""
    }
}

// True when `enum_name` declares a variant called `variant`.
let variant_belongs_to_enum(e: *Emitter, variant: string, enum_name: string): bool = {
    match map.get(&e.enum_decls, enum_name) {
    | Some(d) -> {
        match d {
        | DEnum(_, _, _, variants) -> {
            for v in variants { if strings.eq_raw(v.name, variant) { return true } }
            false
        }
        | _ -> false
        }
    }
    | None -> false
    }
}

let any_arm_has_guard(arms: Vec<ast.MatchArm>): bool = {
    for a in arms { if a.has_guard { return true } }
    false
}

// A sub-pattern requires the if-chain emitter when it carries a
// literal equality test or when it is itself a variant pattern. The
// switch-based dispatch can only test the outer tag. Anything that
// constrains a payload must AND into the if condition.
let pat_needs_if_chain(p: ast.Pattern): bool = {
    match p {
    | PatLitInt(_, _) | PatLitString(_, _) | PatLitBool(_, _) -> true
    | PatVariant(_, _, _) -> true
    | _ -> false
    }
}

let any_arm_is_literal(arms: Vec<ast.MatchArm>): bool = {
    for a in arms {
        match a.pat {
        | PatLitInt(_, _) | PatLitString(_, _) | PatLitBool(_, _) -> return true
        | PatVariant(_, _, sub_pats) -> {
            for sp in sub_pats {
                if pat_needs_if_chain(sp) { return true }
            }
        }
        | _ -> { }
        }
    }
    false
}

let emit_match_as_expr(e: *Emitter, span: ast.Span, scrut: ast.Expr, arms: Vec<ast.MatchArm>) = {
    if any_arm_has_guard(arms) {
        emit_match_as_if_chain(e, span, scrut, arms)
        return
    }
    if any_arm_is_literal(arms) {
        emit_match_as_if_chain(e, span, scrut, arms)
        return
    }
    let scrut_te_for_dispatch = infer_value_te(e, scrut)
    let bare_enum: string = find_enum_from_arms_with_scrut(e, arms, scrut_te_for_dispatch)
    if strings.eq_raw(bare_enum, "") {
        emit_match_as_if_chain(e, span, scrut, arms)
        return
    }
    let enum_name: string = enum_lookup_name(e, scrut, bare_enum)
    e.match_counter = e.match_counter + 1
    let scrut_tmp = `_qoz_ms_{e.match_counter}`
    let res_tmp   = `_qoz_mv_{e.match_counter}`
    let res_ctype = match_result_ctype_with_hint(e, enum_name, arms)
    let is_void = strings.eq_raw(res_ctype, "void")

    // Build the switch into a fresh output buffer. The entire block
    // becomes a single prologue entry attached to the enclosing C
    // statement, and the expression position resolves to `res_tmp`
    // (or 0 for void-yielding matches).
    let start = strings.sb_len(&e.out)
    push(e, `qoz_{enum_name}* {scrut_tmp} = `)
    emit_expr(e, scrut)
    push(e, "; ")
    if !is_void {
        let dv = default_value_for(res_ctype)
        push(e, `{res_ctype} {res_tmp} = {dv}; `)
    }
    push(e, `switch ({scrut_tmp}->tag) {{ `)
    for arm in arms {
        emit_match_arm_with_kind(e, enum_name, scrut_tmp, res_tmp, arm, is_void)
    }
    push(e, "} ")
    hoist_to_prologue(e, start)
    if is_void {
        push(e, "0")
    } else {
        push(e, res_tmp)
    }
}

// Read the C-side enum name out of a TypeExpr. Used when descending
// into a nested variant pattern: the payload's TypeExpr names the
// inner enum, possibly with type arguments that get mangled.
let enum_name_of_te(e: *Emitter, te: ast.TypeExpr): string = {
    match te {
    | TENamed(_, path, args) -> {
        if len(path) >= 1 {
            let last = path[len(path) - 1]
            if len(args) > 0 { return mangle_inst(e, last, args) }
            return last
        }
        ""
    }
    | _ -> ""
    }
}

// Emit the conjunction of conditions that a value of static type
// value_te (denoted by C expression value_expr) must satisfy to match
// the pattern p. Each clause is prefixed with ` && ` so the caller
// can splice the result inside an `if (...)` condition that already
// has at least one term. Walks PatVariant subtrees recursively to
// emit tag tests and literal equalities at every depth.
let emit_pat_match_cond(e: *Emitter, p: ast.Pattern, value_expr: string, value_te: ast.TypeExpr) = {
    match p {
    | PatWild(_)         -> { }
    | PatBind(_, _)      -> { }
    | PatLitInt(_, text) -> {
        let tn = strip_numeric_underscores(text)
        push(e, ` && {value_expr} == {tn}`)
    }
    | PatLitBool(_, b) -> {
        if b { push(e, ` && {value_expr} == true`) }
        else { push(e, ` && {value_expr} == false`) }
    }
    | PatLitString(_, text) -> {
        push(e, ` && qoz_string_eq({value_expr}, QOZ_STR_LIT({text}))`)
    }
    | PatVariant(sp, path, sub_pats) -> {
        if len(path) == 0 {
            let _ = emit_die(sp, "variant pattern has no name")
            return
        }
        let vname = path[len(path) - 1]
        let inner_enum = enum_name_of_te(e, value_te)
        if strings.eq_raw(inner_enum, "") {
            let _ = emit_die(sp, "nested variant pattern on a scrutinee whose type is not an enum")
            return
        }
        push(e, ` && {value_expr}->tag == qoz_{inner_enum}_{vname}`)
        var i: i64 = 0
        for spat in sub_pats {
            let sub_te = variant_payload_typeexpr(e, inner_enum, vname, i)
            let is = int_to_string(i)
            let sub_expr = `{value_expr}->payload.{vname}.f{is}`
            emit_pat_match_cond(e, spat, sub_expr, sub_te)
            i += 1
        }
    }
    | PatTuple(sp, _) -> {
        let _ = emit_die(sp, "tuple patterns in match arms are not yet supported")
    }
    }
}

// Inside an arm body whose conditions have already passed, materialise
// the bindings that the pattern introduces. Recurses through nested
// PatVariant subtrees so a `Some(Some(v))` arm binds the deeply
// nested `v` to the inner payload.
let emit_pat_bindings(e: *Emitter, p: ast.Pattern, value_expr: string, value_te: ast.TypeExpr) = {
    match p {
    | PatBind(_, bname) -> {
        let ct = c_type_for(e, value_te)
        push(e, `{ct} {bname} = {value_expr}; (void){bname}; `)
        e.locals[bname] = value_te
    }
    | PatVariant(sp, path, sub_pats) -> {
        if len(path) == 0 {
            let _ = emit_die(sp, "variant pattern has no name")
            return
        }
        let vname = path[len(path) - 1]
        let inner_enum = enum_name_of_te(e, value_te)
        if strings.eq_raw(inner_enum, "") {
            let _ = emit_die(sp, "nested variant pattern on a scrutinee whose type is not an enum")
            return
        }
        var i: i64 = 0
        for spat in sub_pats {
            let sub_te = variant_payload_typeexpr(e, inner_enum, vname, i)
            let is = int_to_string(i)
            let sub_expr = `{value_expr}->payload.{vname}.f{is}`
            emit_pat_bindings(e, spat, sub_expr, sub_te)
            i += 1
        }
    }
    | PatWild(_) | PatLitInt(_, _) | PatLitString(_, _) | PatLitBool(_, _) -> { }
    | PatTuple(sp, _) -> {
        let _ = emit_die(sp, "tuple patterns in match arms are not yet supported")
    }
    }
}

let emit_match_as_if_chain(e: *Emitter, span: ast.Span, scrut: ast.Expr, arms: Vec<ast.MatchArm>) = {
    let scrut_te_for_dispatch = infer_value_te(e, scrut)
    let bare_enum: string = find_enum_from_arms_with_scrut(e, arms, scrut_te_for_dispatch)
    let is_enum_match = !strings.eq_raw(bare_enum, "")
    var enum_name = ""
    if is_enum_match { enum_name = enum_lookup_name(e, scrut, bare_enum) }
    let scrut_ctype = infer_expr_ctype(e, scrut)
    let scrut_te = infer_value_te(e, scrut)
    e.match_counter = e.match_counter + 1
    let scrut_tmp = `_qoz_ms_{e.match_counter}`
    let res_tmp   = `_qoz_mv_{e.match_counter}`
    let mflag     = `_qoz_mm_{e.match_counter}`
    let res_ctype = match_result_ctype_with_hint(e, enum_name, arms)
    let is_void = strings.eq_raw(res_ctype, "void")
    let start = strings.sb_len(&e.out)
    if is_enum_match {
        push(e, `qoz_{enum_name}* {scrut_tmp} = `)
    } else {
        push(e, `{scrut_ctype} {scrut_tmp} = `)
    }
    emit_expr(e, scrut)
    push(e, "; ")
    if !is_void {
        let dv = default_value_for(res_ctype)
        push(e, `{res_ctype} {res_tmp} = {dv}; `)
    }
    push(e, `bool {mflag} = false; `)
    for arm in arms {
        emit_arm_in_chain_with_te(e, enum_name, scrut_tmp, scrut_te, res_tmp, mflag, arm, is_void)
    }
    hoist_to_prologue(e, start)
    if is_void {
        push(e, "0")
    } else {
        push(e, res_tmp)
    }
}

let emit_arm_in_chain_with_te(e: *Emitter, enum_name: string, scrut_tmp: string, scrut_te: ast.TypeExpr, res_tmp: string, mflag: string, arm: ast.MatchArm, is_void: bool) = {
    let body_hint = match_body_hint(e, enum_name, arm.body)
    let is_enum_match = !strings.eq_raw(enum_name, "")
    push(e, "if (!")
    push(e, mflag)
    match arm.pat {
    | PatWild(_) -> push(e, ") { ")
    | PatBind(_, name) -> {
        if is_enum_match {
            if let Some(_) = map.get(&e.variant_of, name) {
                push(e, ` && {scrut_tmp}->tag == qoz_{enum_name}_{name}) {{ `)
            } else {
                // Catch-all bind on an enum scrutinee: name is bound
                // to the enum pointer so the arm body can inspect or
                // forward the entire value.
                push(e, `) {{ qoz_{enum_name}* {name} = {scrut_tmp}; (void){name}; `)
                e.locals[name] = scrut_te
            }
        } else {
            let sc = c_type_for(e, scrut_te)
            push(e, `) {{ {sc} {name} = {scrut_tmp}; (void){name}; `)
            e.locals[name] = scrut_te
        }
    }
    | PatLitInt(_, text) -> {
        let tn = strip_numeric_underscores(text)
        push(e, ` && {scrut_tmp} == {tn}) {{ `)
    }
    | PatLitBool(_, b) -> {
        if b { push(e, ` && {scrut_tmp} == true) {{ `) }
        else { push(e, ` && {scrut_tmp} == false) {{ `) }
    }
    | PatLitString(_, text) -> {
        push(e, ` && qoz_string_eq({scrut_tmp}, QOZ_STR_LIT({text}))) {{ `)
    }
    | PatVariant(psp, path, sub_pats) -> {
        if len(path) == 0 {
            let _ = emit_die(psp, "variant pattern has no name")
        }
        if len(path) > 0 {
            let vname = path[len(path) - 1]
            push(e, ` && {scrut_tmp}->tag == qoz_{enum_name}_{vname}`)
            var i: i64 = 0
            for sp in sub_pats {
                let sub_te = variant_payload_typeexpr(e, enum_name, vname, i)
                let is = int_to_string(i)
                let sub_expr = `{scrut_tmp}->payload.{vname}.f{is}`
                emit_pat_match_cond(e, sp, sub_expr, sub_te)
                i += 1
            }
            push(e, ") { ")
            var j: i64 = 0
            for sp in sub_pats {
                let sub_te = variant_payload_typeexpr(e, enum_name, vname, j)
                let js = int_to_string(j)
                let sub_expr = `{scrut_tmp}->payload.{vname}.f{js}`
                emit_pat_bindings(e, sp, sub_expr, sub_te)
                j += 1
            }
        } else {
            push(e, ") { ")
        }
    }
    | PatTuple(psp, _) -> {
        let _ = emit_die(psp, "tuple patterns in match arms are not yet supported")
    }
    }
    if arm.has_guard {
        push(e, "if (")
        emit_expr(e, arm.guard)
        push(e, ") { ")
    }
    // Sub-emits inside the arm body may hoist statements (a string
    // interpolation builder, a nested match-as-value, a closure
    // construction) into e.pending_prologue. Open a fresh scope so
    // those land inside this arm's `{ ... }` block where the
    // pattern-bound locals are in scope. Without the scope they
    // leak above the enclosing match and reference undeclared
    // names.
    let arm_scope = open_statement_scope(e)
    if is_void {
        emit_stmt_expr(e, arm.body)
    } else {
        push(e, res_tmp)
        push(e, " = (")
        emit_value_with_hint(e, arm.body, body_hint)
        push(e, "); ")
    }
    close_statement_scope(e, arm_scope)
    push(e, mflag)
    push(e, " = true; ")
    if arm.has_guard {
        push(e, "} ")
    }
    push(e, "} ")
}

// Dispatch arm body emission on whether the enclosing match yields a
// value (assigns into res_tmp) or is statement-position only.
let emit_arm_body_kind(e: *Emitter, is_void: bool, res_tmp: string, body: ast.Expr, body_hint: ast.TypeExpr) = {
    // Open a fresh statement scope around the arm body so that any
    // prologue it emits (a nested hoist for a block-as-value, a match
    // expression nested inside the arm, a closure-env construction)
    // lands inside the C `case` block rather than ahead of the enclosing
    // `switch`. The pattern-bound variables live in the case block. The
    // prologue must see them.
    let saved = open_statement_scope(e)
    if is_void {
        emit_stmt_expr(e, body)
    } else {
        emit_arm_body_with_hint(e, res_tmp, body, body_hint)
    }
    close_statement_scope(e, saved)
}

let emit_match_arm_with_kind(e: *Emitter, enum_name: string, scrut_tmp: string, res_tmp: string, arm: ast.MatchArm, is_void: bool) = {
    let body_hint = match_body_hint(e, enum_name, arm.body)
    match arm.pat {
    | PatWild(_) -> {
        push(e, "default: { ")
        emit_arm_body_kind(e, is_void, res_tmp, arm.body, body_hint)
        push(e, " break; } ")
    }
    | PatBind(_, name) -> {
        match map.get(&e.variant_of, name) {
        | Some(_) -> {
            push(e, `case qoz_{enum_name}_{name}: {{ `)
            if arm.has_guard {
                push(e, "if (")
                emit_expr(e, arm.guard)
                push(e, ") { ")
                emit_arm_body_kind(e, is_void, res_tmp, arm.body, body_hint)
                push(e, "} ")
            } else {
                emit_arm_body_kind(e, is_void, res_tmp, arm.body, body_hint)
            }
            push(e, " break; } ")
        }
        | None -> {
            // Catch-all bind on a switch-style enum match. Bind
            // `name` to the enum pointer so the body sees the whole
            // value rather than a placeholder zero. Register the
            // binding's TypeExpr so the inner code can call match,
            // field access, and the like on it.
            push(e, `default: {{ qoz_{enum_name}* {name} = {scrut_tmp}; (void){name}; `)
            let sp = ast.Span { file: "", line: 0, col: 0 }
            var segs: Vec<string> = vec.make()
            vec.push(&segs, enum_name)
            e.locals[name] = TENamed(sp, segs, vec.make())
            if arm.has_guard {
                push(e, "if (")
                emit_expr(e, arm.guard)
                push(e, ") { ")
                emit_arm_body_kind(e, is_void, res_tmp, arm.body, body_hint)
                push(e, "} ")
            } else {
                emit_arm_body_kind(e, is_void, res_tmp, arm.body, body_hint)
            }
            push(e, " break; } ")
        }
        }
    }
    | PatVariant(psp, path, sub_pats) -> {
        if len(path) == 0 {
            let _ = emit_die(psp, "variant pattern has no name")
            return
        }
        let vname = path[len(path) - 1]
        push(e, `case qoz_{enum_name}_{vname}: {{ `)
        var i: i64 = 0
        for spat in sub_pats {
            match spat {
            | PatBind(_, bname) -> {
                let pc = variant_payload_ctype(e, enum_name, vname, i)
                let is = int_to_string(i)
                push(e, `{pc} {bname} = {scrut_tmp}->payload.{vname}.f{is}; `)
                e.locals[bname] = variant_payload_typeexpr(e, enum_name, vname, i)
            }
            | PatWild(_) -> { }
            | _ -> {
                // pat_needs_if_chain routes any literal or nested
                // variant sub-pattern through the if-chain emitter;
                // reaching this arm means that routing missed a case
                // and the switch dispatch cannot encode the test.
                let _ = emit_die(psp, "switch-style match arm received a sub-pattern that requires a runtime test; pat_needs_if_chain is out of sync")
            }
            }
            i += 1
        }
        if arm.has_guard {
            push(e, "if (")
            emit_expr(e, arm.guard)
            push(e, ") { ")
            emit_arm_body_kind(e, is_void, res_tmp, arm.body, body_hint)
            push(e, "} ")
        } else {
            emit_arm_body_kind(e, is_void, res_tmp, arm.body, body_hint)
        }
        push(e, " break; } ")
    }
    | PatTuple(psp, _) -> {
        let _ = emit_die(psp, "tuple patterns in match arms are not yet supported")
    }
    | PatLitInt(psp, _) | PatLitString(psp, _) | PatLitBool(psp, _) -> {
        let _ = emit_die(psp, "literal pattern reached switch-style match dispatch; pat_needs_if_chain is out of sync")
    }
    }
}

// Choose the C-side enum name (possibly the mangled instantiation) by
// looking up the scrutinee's TypeExpr in the current locals environment.
// Falls back to the bare enum name when the type cannot be located.
let enum_lookup_name(e: *Emitter, scrut: ast.Expr, bare_enum: string): string = {
    let te = infer_base_typeexpr(e, scrut)
    enum_name_from_type(e, te, bare_enum)
}

let enum_name_from_type(e: *Emitter, te: ast.TypeExpr, bare_enum: string): string = {
    match te {
    | TENamed(_, path, args) -> {
        if len(args) > 0 && len(path) >= 1 {
            let last = path[len(path) - 1]
            if strings.eq_raw(last, bare_enum) {
                return mangle_inst(e, bare_enum, args)
            }
        }
        bare_enum
    }
    | _ -> bare_enum
    }
}

let variant_inst_args(e: *Emitter, enum_name: string, bare: string): Vec<ast.TypeExpr> = {
    for inst in e.enum_insts {
        if strings.eq_raw(inst.mangled, enum_name) {
            return inst.args
        }
    }
    mangled_args(e, enum_name, bare)
}

let variant_payload_typeexpr(e: *Emitter, enum_name: string, variant: string, pos: i64): ast.TypeExpr = {
    let bare = strip_mangled(enum_name)
    let unit_sp = ast.Span { file: "", line: 0, col: 0 }
    match map.get(&e.enum_decls, bare) {
    | None -> TEUnit(unit_sp)
    | Some(d) -> {
        match d {
        | DEnum(_, _, tparams, variants) -> {
            let inst_args = variant_inst_args(e, enum_name, bare)
            for v in variants {
                if strings.eq_raw(v.name, variant) {
                    if pos >= 0 && pos < len(v.pos) {
                        if len(tparams) > 0 && len(inst_args) == len(tparams) {
                            return substitute_type(e, v.pos[pos], tparams, inst_args)
                        }
                        return v.pos[pos]
                    }
                }
            }
            TEUnit(unit_sp)
        }
        | _ -> TEUnit(unit_sp)
        }
    }
    }
}

let variant_payload_ctype(e: *Emitter, enum_name: string, variant: string, pos: i64): string = {
    let bare = strip_mangled(enum_name)
    match map.get(&e.enum_decls, bare) {
    | None -> "int64_t"
    | Some(d) -> {
        match d {
        | DEnum(_, _, tparams, variants) -> {
            let inst_args = variant_inst_args(e, enum_name, bare)
            for v in variants {
                if strings.eq_raw(v.name, variant) {
                    if pos >= 0 && pos < len(v.pos) {
                        let subst = if len(tparams) > 0 && len(inst_args) == len(tparams) {
                            substitute_type(e, v.pos[pos], tparams, inst_args)
                        } else {
                            v.pos[pos]
                        }
                        return c_type_for(e, subst)
                    }
                }
            }
            "int64_t"
        }
        | _ -> "int64_t"
        }
    }
    }
}

// enum_name may be a mangled instantiation like "Option__int64_t". The
// base enum decl key is the prefix before "__". Returns the empty string
// or the bare name. Also extracts the type arguments from the mangled
// suffix when present.
let strip_mangled(name: string): string = {
    let idx = strings.index_byte(name, 95)
    if idx < 0 { return name }
    let n = len(name)
    var i: i64 = 0
    while i + 1 < n {
        if strings.byte_at(name, i) == 95 && strings.byte_at(name, i + 1) == 95 {
            return strings.slice(name, 0, i)
        }
        i += 1
    }
    name
}

let mangled_args(e: *Emitter, mangled: string, bare: string): Vec<ast.TypeExpr> = {
    var out: Vec<ast.TypeExpr> = vec.make()
    let bn = len(bare)
    let mn = len(mangled)
    if mn <= bn + 2 { return out }
    let sp = ast.Span { file: "", line: 0, col: 0 }
    let tail = strings.slice(mangled, bn + 2, mn)
    let n = len(tail)
    var start: i64 = 0
    var i: i64 = 0
    while i + 1 < n {
        if strings.byte_at(tail, i) == 95 && strings.byte_at(tail, i + 1) == 95 {
            vec.push(&out, type_expr_from_mangled_part(strings.slice(tail, start, i), sp))
            start = i + 2
            i += 2
        } else {
            i += 1
        }
    }
    if start < n {
        vec.push(&out, type_expr_from_mangled_part(strings.slice(tail, start, n), sp))
    }
    out
}

let type_expr_from_mangled_part(part: string, sp: ast.Span): ast.TypeExpr = {
    let unmapped = unmangle_primitive(part)
    var path: Vec<string> = vec.make()
    vec.push(&path, unmapped)
    TENamed(sp, path, vec.make())
}

let unmangle_primitive(s: string): string = {
    if strings.eq_raw(s, "int8_t")  { return "i8" }
    if strings.eq_raw(s, "int16_t") { return "i16" }
    if strings.eq_raw(s, "int32_t") { return "i32" }
    if strings.eq_raw(s, "int64_t") { return "i64" }
    if strings.eq_raw(s, "uint8_t")  { return "u8" }
    if strings.eq_raw(s, "uint16_t") { return "u16" }
    if strings.eq_raw(s, "uint32_t") { return "u32" }
    if strings.eq_raw(s, "uint64_t") { return "u64" }
    if strings.eq_raw(s, "float")    { return "f32" }
    if strings.eq_raw(s, "double")   { return "f64" }
    if strings.eq_raw(s, "qoz_string") { return "string" }
    if strings.eq_raw(s, "bool")     { return "bool" }
    if strings.eq_raw(s, "char")     { return "char" }
    if strings.has_prefix(s, "qoz_") {
        return strings.slice(s, 4, len(s))
    }
    s
}

// Emit the body of a value-yielding match arm. EReturn bypasses the
// result variable and emits the function's return directly so the
// surrounding statement-expression can elide the assignment.
let emit_arm_body_with_hint(e: *Emitter, res_tmp: string, body: ast.Expr, hint: ast.TypeExpr) = {
    match body {
    | EReturn(_, v) -> {
        if is_nil_expr(v) {
            push(e, "return; ")
        } else {
            push(e, "return ")
            emit_value_with_hint(e, v, e.current_ret_te)
            push(e, "; ")
        }
    }
    | _ -> {
        push(e, res_tmp)
        push(e, " = (")
        emit_value_with_hint(e, body, hint)
        push(e, "); ")
    }
    }
}

// Construct a TypeExpr hint for the match's expected result type. The
// arm body is typically a value of the same generic enum, so use the
// (possibly mangled) enum name with the resolved type arguments.
let match_body_hint(e: *Emitter, enum_name: string, body: ast.Expr): ast.TypeExpr = {
    if !is_unit_typeexpr(e.match_hint) { return e.match_hint }
    let sp = ast.Span { file: "", line: 0, col: 0 }
    let bare = strip_mangled(enum_name)
    let inst_args = mangled_args(e, enum_name, bare)
    var path: Vec<string> = vec.make()
    vec.push(&path, bare)
    TENamed(sp, path, inst_args)
}

let emit_main(e: *Emitter, ret: ast.TypeExpr, body: ast.Expr) = {
    let kind = main_return_kind(ret)
    push(e, "int main(int argc, char **argv) {\n    qoz_set_argv(argc, argv);\n    int qoz_stack_anchor;\n    qoz_init(&qoz_stack_anchor);\n    qoz_frame_push(\"main\");\n    ")
    match body {
    | EBlock(_, stmts, tail) -> {
        // Collect defers from the body's statements and from the
        // tail when the tail is itself an `EDefer`. The C `int main`
        // wrapper has its own shutdown trailer, so the deferred
        // statements must be emitted before that trailer rather
        // than relying on the regular function-exit machinery.
        var defers = collect_defers_in_stmts(stmts)
        var effective_tail: ast.Expr = tail
        match tail {
        | EDefer(_, dbody) -> {
            vec.push(&defers, dbody)
            effective_tail = ENil(span_of_expr(tail))
        }
        | _ -> { }
        }
        for s in stmts {
            emit_stmt(e, s)
        }
        if is_nil_expr(effective_tail) {
            emit_defers_reverse(e, defers)
            push(e, "\n    qoz_shutdown();\n    return 0;\n}\n")
            return
        }
        emit_main_tail(e, kind, ret, effective_tail, defers)
    }
    | _ -> emit_main_tail(e, kind, ret, body, vec.make())
    }
}

type MainRetKind =
    | MainRetUnit
    | MainRetInt(string)

let main_return_kind(ret: ast.TypeExpr): MainRetKind = {
    match ret {
    | TEUnit(_)                  -> MainRetUnit
    | TENamed(sp, path, _) -> {
        if len(path) != 1 {
            fmt.println(`{sp.file}:{sp.line}:{sp.col}: main return type must be a primitive integer or unit`)
            return MainRetInt("int64_t")
        }
        let n = path[0]
        if strings.eq_raw(n, "i8")   { return MainRetInt("int8_t") }
        if strings.eq_raw(n, "i16")  { return MainRetInt("int16_t") }
        if strings.eq_raw(n, "i32")  { return MainRetInt("int32_t") }
        if strings.eq_raw(n, "i64")  { return MainRetInt("int64_t") }
        if strings.eq_raw(n, "u8")   { return MainRetInt("uint8_t") }
        if strings.eq_raw(n, "u16")  { return MainRetInt("uint16_t") }
        if strings.eq_raw(n, "u32")  { return MainRetInt("uint32_t") }
        if strings.eq_raw(n, "u64")  { return MainRetInt("uint64_t") }
        if strings.eq_raw(n, "unit") { return MainRetUnit }
        if strings.eq_raw(n, "void") { return MainRetUnit }
        fmt.println(`{sp.file}:{sp.line}:{sp.col}: main may return only integer types or unit, got '{n}'`)
        MainRetInt("int64_t")
    }
    | _ -> {
        fmt.println("main return type must be a primitive integer or unit")
        MainRetInt("int64_t")
    }
    }
}

let emit_main_tail(e: *Emitter, kind: MainRetKind, ret: ast.TypeExpr, tail: ast.Expr, defers: Vec<ast.Expr>) = {
    match kind {
    | MainRetUnit -> {
        // For unit-returning main, control-flow tails (for/while/if-as-stmt)
        // must be emitted as statements so the loop body actually appears.
        // An `if` whose else branch is nil is statement-shaped here too:
        // ternary-emitting it would require a value type for the missing
        // arm.
        let is_unit_if = match tail {
        | EIf(_, _, _, f) -> is_nil_expr(f) || is_unit_typeexpr(infer_value_te(e, tail))
        | _               -> false
        }
        match tail {
        | EReturn(_, _) -> {
            // The user's explicit `return` already leaves main. The
            // shutdown trailer is emitted separately by the function
            // wrapper, so do not duplicate it here. Defers still fire
            // before the explicit return.
            emit_defers_reverse(e, defers)
            emit_expr(e, tail)
            push(e, ";\n")
            return
        }
        | EFor(_, _, _, _, _) | EWhile(_, _, _) | EAssign(_, _, _, _) | EDefer(_, _) -> {
            let saved = open_statement_scope(e)
            emit_stmt_expr(e, tail)
            emit_defers_reverse(e, defers)
            push(e, "\n    qoz_shutdown();\n    return 0;\n}\n")
            close_statement_scope(e, saved)
            return
        }
        | _ -> { }
        }
        if is_unit_if {
            let saved = open_statement_scope(e)
            emit_stmt_expr(e, tail)
            emit_defers_reverse(e, defers)
            push(e, "\n    qoz_shutdown();\n    return 0;\n}\n")
            close_statement_scope(e, saved)
            return
        }
        let saved = open_statement_scope(e)
        emit_expr(e, tail)
        push(e, ";\n")
        emit_defers_reverse(e, defers)
        push(e, "    qoz_shutdown();\n    return 0;\n}\n")
        close_statement_scope(e, saved)
    }
    | MainRetInt(ctype) -> {
        let saved = open_statement_scope(e)
        push(e, ctype)
        push(e, " qoz_main_result = ")
        emit_value_with_hint(e, tail, ret)
        push(e, ";\n")
        emit_defers_reverse(e, defers)
        push(e, "    qoz_shutdown();\n    return (int)qoz_main_result;\n}\n")
        close_statement_scope(e, saved)
    }
    }
}
