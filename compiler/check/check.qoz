// compiler/check: type checker.

import fmt
import vec
import map
import mem
import strings
import fs
import compiler/ast
import compiler/ty
import compiler/recur

type TypeError = {
    span:    ast.Span,
    message: string,
}

type ExpectedHint = {
    span: ast.Span,
    ty:   ty.Ty,
}

type TyContext = {
    enums:        Map<string, ast.Decl>,
    structs:      Map<string, ast.Decl>,
    aliases:      Map<string, ast.Decl>,
    // C-style integer enums keyed by composite `<home>.<name>`.
    // Distinct from the tagged-ADT enum map so the two never
    // collide at lookup time.
    c_enums:      Map<string, ast.Decl>,
    fns:          Map<string, ast.Decl>,
    externs:      Map<string, ast.Decl>,
    // Top-level constants keyed by the renamed C-style name
    // (`<pkg>_<name>`). Package-qualified reads (`pkg.NAME`)
    // resolve here.
    consts:       Map<string, ast.Decl>,
    packages:     Map<string, bool>,
    // First-home for each variant name. Single-home queries hit this
    // map. Ambiguity detection consults variant_homes.
    variant_of:   Map<string, string>,
    // Every enum that declares a given variant name. Length 1 is the
    // common case. Longer entries mean the bare name is ambiguous and
    // a qualified path (Enum.Variant) is required at the call site
    // unless context pins the enum.
    variant_homes: Map<string, Vec<string>>,
    // Same shape as variant_homes, for C-style enums. Maps the short
    // variant name to every C-enum (by renamed name) that declares
    // it. Used to resolve bare references like `Orthographic` to
    // `rl.CameraProjection.Orthographic`. Multi-entry values force
    // either expected-type disambiguation or a hard error.
    c_variant_homes: Map<string, Vec<string>>,
    // Every owning package of a given short type name. Empty string
    // in the vec means the prelude. Multiple entries mean two
    // packages declare the same short name. Lookups disambiguate via
    // the use-site package, the explicit qualifier, or the home
    // field of a Ty value.
    type_homes:    Map<string, Vec<string>>,
    // Owning package of every fn / extern, keyed by the renamed
    // C-style name. validate_signatures reads this when caching the
    // resolved param and return tys. Emit reads it through the same
    // map.
    fn_homes:      Map<string, string>,
    // Resolved parameter and return types of every declared fn /
    // extern. Populated once in validate_signatures and read by
    // synth_call_with_decl so call-site type-checking does not walk
    // the callee's TypeExprs again.
    fn_param_tys:  Map<string, Vec<ty.Ty>>,
    fn_ret_ty:     Map<string, ty.Ty>,
    // Set while resolving a record literal's head type, where omitted
    // type arguments are inferred from the field values. It suppresses
    // the arity error so `Pair { ... }` (no explicit <...>) is allowed
    // while a bare `Pair` in a type annotation is still rejected.
    record_head_resolve: bool,
    // @operator overloads, keyed "<op-symbol>::<TypeName>" -> fn name,
    // where TypeName is the head name of the operator's first parameter
    // type. synth_binary consults this so an overloaded operator on a
    // non-numeric type (a record or a pointer to one) type-checks
    // instead of being rejected by the built-in numeric rule. Mirrors
    // emit's op_dispatch.
    op_overloads:  Map<string, string>,
    // Maps each source file path to the package the file belongs
    // to. resolve_named reads this through the TypeExpr's span so a
    // bare reference is judged against the file the reference was
    // written in, regardless of which fn / synth context the
    // resolution happens to fire from.
    file_pkgs:     Map<string, string>,
    errors:       Vec<TypeError>,
    type_params:  Map<string, bool>,
    // Bidirectional expected-type hints recorded for every
    // expression visited by infer_calls_expr with a non-error
    // expected. Stored as a flat list so the LSP can find the
    // innermost expression at a cursor position with a single
    // pass. The checker itself does not consume this after the
    // rewrite pass.
    expected_hints: Vec<ExpectedHint>,
    // Return type of the function currently being checked. Used by
    // EReturn synth and by the tail-type check at end of body.
    // TyError means no surrounding function (top-level expression).
    current_ret_ty: ty.Ty,
}

let make_ctx(): TyContext = TyContext {
    enums:       [:],
    structs:     [:],
    aliases:     [:],
    c_enums:     [:],
    fns:         [:],
    externs:     [:],
    consts:      [:],
    packages:    [:],
    variant_of:  [:],
    variant_homes: [:],
    c_variant_homes: [:],
    type_homes:  [:],
    fn_homes:    [:],
    fn_param_tys: [:],
    fn_ret_ty:    [:],
    file_pkgs:    [:],
    errors:      [],
    type_params: [:],
    record_head_resolve: false,
    op_overloads: [:],
    expected_hints: [],
    current_ret_ty: ty.ty_error_(),
}

let record_error(tc: *TyContext, span: ast.Span, msg: string) = {
    vec.push(&tc.errors, TypeError { span: span, message: msg })
}

// Compose the registry key used by `tc.enums`, `tc.structs`, and
// `tc.aliases`. Two packages may declare the same short type name
// because each registers under a different key.
let type_key(home: string, name: string): string = {
    strings.cat(strings.cat(home, "."), name)
}

// Pick the matching home for a bare short type name. Returns the
// use-site package if it declares the name, otherwise the prelude
// ("") if it does, otherwise the first registered home.
let pick_type_home(tc: *TyContext, name: string, use_site: string): string = {
    match map.get(&tc.type_homes, name) {
    | None         -> ""
    | Some(homes)  -> {
        var found_use_site = false
        var found_prelude  = false
        for h in homes {
            if strings.eq_raw(h, use_site) { found_use_site = true }
            if strings.eq_raw(h, "")        { found_prelude = true }
        }
        if found_use_site { return use_site }
        if found_prelude  { return "" }
        if len(homes) > 0 { return homes[0] }
        ""
    }
    }
}

// True when at least one home declares this short name as an enum.
let has_enum_short(tc: *TyContext, name: string): bool = {
    match map.get(&tc.type_homes, name) {
    | None        -> false
    | Some(homes) -> {
        for h in homes {
            if map.contains(&tc.enums, type_key(h, name)) { return true }
        }
        false
    }
    }
}

// Similarly for structs and aliases. The reverse lookups are bare
// "does any package have this name?" queries, used in spots like
// is_qualified_variant_field where the home is not yet known.
let has_struct_short(tc: *TyContext, name: string): bool = {
    match map.get(&tc.type_homes, name) {
    | None        -> false
    | Some(homes) -> {
        for h in homes {
            if map.contains(&tc.structs, type_key(h, name)) { return true }
        }
        false
    }
    }
}

let has_alias_short(tc: *TyContext, name: string): bool = {
    match map.get(&tc.type_homes, name) {
    | None        -> false
    | Some(homes) -> {
        for h in homes {
            if map.contains(&tc.aliases, type_key(h, name)) { return true }
        }
        false
    }
    }
}

// Find an enum / struct / alias declaration by (home, name).
let find_enum(tc: *TyContext, home: string, name: string): Option<ast.Decl> = {
    map.get(&tc.enums, type_key(home, name))
}

let find_struct(tc: *TyContext, home: string, name: string): Option<ast.Decl> = {
    map.get(&tc.structs, type_key(home, name))
}

let find_alias(tc: *TyContext, home: string, name: string): Option<ast.Decl> = {
    map.get(&tc.aliases, type_key(home, name))
}

// Look up by short name, scanning every home that declares the
// name and returning the first registered decl. Used by call sites
// that have not yet been threaded with home context. When the same
// short name appears in two packages, the first registered one
// wins, which matches the pre-refactor behaviour for those sites.
let find_enum_short(tc: *TyContext, name: string): Option<ast.Decl> = {
    match map.get(&tc.type_homes, name) {
    | None        -> None
    | Some(homes) -> {
        for h in homes {
            match map.get(&tc.enums, type_key(h, name)) {
            | Some(d) -> return Some(d)
            | None    -> { }
            }
        }
        None
    }
    }
}

let find_struct_short(tc: *TyContext, name: string): Option<ast.Decl> = {
    match map.get(&tc.type_homes, name) {
    | None        -> None
    | Some(homes) -> {
        for h in homes {
            match map.get(&tc.structs, type_key(h, name)) {
            | Some(d) -> return Some(d)
            | None    -> { }
            }
        }
        None
    }
    }
}

// Append `home` to the list of homes recorded for `name`, if not
// already present.
let record_type_home(tc: *TyContext, name: string, home: string) = {
    var homes: Vec<string> = match map.get(&tc.type_homes, name) {
    | Some(v) -> v
    | None    -> []
    }
    var seen = false
    for h in homes { if strings.eq_raw(h, home) { seen = true } }
    if !seen {
        vec.push(&homes, home)
        map.set(&tc.type_homes, name, homes)
    }
}

let home_of_file(tc: *TyContext, file: string): string = {
    match map.get(&tc.file_pkgs, file) {
    | Some(h) -> h
    | None    -> ""
    }
}

let register_decl(tc: *TyContext, d: ast.Decl) = {
    match d {
    | DImport(_, path, alias)         -> {
        var name = alias
        if strings.eq_raw(name, "") {
            if len(path) > 0 {
                name = path[len(path) - 1]
            }
        }
        tc.packages[name] = true
    }
    | DEnum(sp, name, _, variants)     -> {
        let home = home_of_file(tc, sp.file)
        let key = type_key(home, name)
        if map.contains(&tc.enums, key) || map.contains(&tc.structs, key) || map.contains(&tc.aliases, key) {
            record_error(tc, sp, `type '{name}' is already declared in package '{home}'; pick a different name`)
        }
        tc.enums[key] = d
        record_type_home(tc, name, home)
        for v in variants {
            if !map.contains(&tc.variant_of, v.name) {
                tc.variant_of[v.name] = name
            }
            var homes: Vec<string> = match map.get(&tc.variant_homes, v.name) {
            | Some(h) -> h
            | None    -> []
            }
            var seen = false
            for h in homes { if strings.eq_raw(h, name) { seen = true } }
            if !seen {
                vec.push(&homes, name)
                tc.variant_homes[v.name] = homes
            }
        }
    }
    | DStruct(sp, name, _, _)          -> {
        let home = home_of_file(tc, sp.file)
        let key = type_key(home, name)
        if map.contains(&tc.enums, key) || map.contains(&tc.structs, key) || map.contains(&tc.aliases, key) {
            record_error(tc, sp, `type '{name}' is already declared in package '{home}'; pick a different name`)
        }
        tc.structs[key] = d
        record_type_home(tc, name, home)
    }
    | DTypeAlias(sp, name, _, _)       -> {
        let home = home_of_file(tc, sp.file)
        let key = type_key(home, name)
        if map.contains(&tc.enums, key) || map.contains(&tc.structs, key) || map.contains(&tc.aliases, key) {
            record_error(tc, sp, `type '{name}' is already declared in package '{home}'; pick a different name`)
        }
        tc.aliases[key] = d
        record_type_home(tc, name, home)
    }
    | DCEnum(sp, name, _, variants)    -> {
        let home = home_of_file(tc, sp.file)
        let key = type_key(home, name)
        if map.contains(&tc.enums, key) || map.contains(&tc.structs, key) || map.contains(&tc.aliases, key) || map.contains(&tc.c_enums, key) {
            record_error(tc, sp, `type '{name}' is already declared in package '{home}'; pick a different name`)
        }
        tc.c_enums[key] = d
        record_type_home(tc, name, home)
        for v in variants {
            var homes: Vec<string> = match map.get(&tc.c_variant_homes, v) {
            | Some(h) -> h
            | None    -> []
            }
            var seen = false
            for h in homes { if strings.eq_raw(h, name) { seen = true } }
            if !seen {
                vec.push(&homes, name)
                tc.c_variant_homes[v] = homes
            }
        }
    }
    | DFn(_, name, _, _, _, _, _)     -> { tc.fns[name] = d }
    | DExternal(_, name, _, _, _)     -> { tc.externs[name] = d }
    | DConst(_, name, _, _)           -> { tc.consts[name] = d }
    // DLink carries linker metadata, not symbols, so the type
    // context records nothing. DCompileIf is expanded by the
    // loader before check runs; a DCompileIf reaching this pass
    // would be a compiler bug, but skipping silently avoids
    // masking other diagnostics in the same file.
    | DLink(_, _, _)
    | DCompileIf(_, _, _)             -> { }
    }
}

let type_name_collides(tc: *TyContext, name: string): bool = {
    has_enum_short(tc, name) ||
    has_struct_short(tc, name) ||
    has_alias_short(tc, name)
}

let register_file(tc: *TyContext, f: ast.File) = {
    // Prelude packages are always in scope regardless of whether the
    // user's source contains an `import` for them. Register their
    // names so qualified calls (`vec.push`, `map.insert`) resolve
    // even when the user reaches them only through the bare
    // container builtins.
    tc.packages["vec"]    = true
    tc.packages["map"]    = true
    tc.packages["option"] = true
    tc.packages["result"] = true
    for d in f.decls {
        register_decl(tc, d)
    }
}

// Cache source contents keyed by file path so a multi-error report
// reads each file at most once.
type SrcCache = { files: Map<string, string> }

let src_cache_make(): SrcCache = SrcCache { files: [:] }

let src_cache_get(c: *SrcCache, path: string): string = {
    match map.get(&c.files, path) {
    | Some(text) -> text
    | None       -> {
        let text = fs.read_file(path)
        c.files[path] = text
        text
    }
    }
}

// Extract line `line` (1-based) from source text. Returns "" if the
// line is out of range or the file is empty.
let nth_line(src: string, line: i64): string = {
    if line < 1 { return "" }
    let n = len(src)
    var cur: i64 = 1
    var start: i64 = 0
    var i: i64 = 0
    while i < n {
        let c = strings.byte_at(src, i)
        if c == 10 {
            if cur == line { return strings.slice(src, start, i) }
            cur += 1
            start = i + 1
        }
        i += 1
    }
    if cur == line { return strings.slice(src, start, n) }
    ""
}

// Produce a caret string aligned with the col-th byte of `line`.
// Each leading byte that is a tab is preserved as a tab in the
// padding so the terminal's tab-expansion lines up with the caret;
// every other byte becomes a space. Without this, a source line that
// contains a tab renders wider than the pad and the caret drifts
// left of the offending token.
let caret_pad(line: string, col: i64): string = {
    var s = ""
    let n = len(line)
    var i: i64 = 1
    while i < col {
        let c = if i - 1 < n { strings.byte_at(line, i - 1) } else { 32 }
        if c == 9 { s = strings.cat(s, "\t") }
        else      { s = strings.cat(s, " ") }
        i += 1
    }
    strings.cat(s, "^")
}

let report(tc: *TyContext) = {
    var cache = src_cache_make()
    // The checker walks the program twice (once during infer_calls,
    // once during check_fn_bodies). The same diagnostic may be
    // recorded by both passes. Deduplicate on file:line:col:message
    // so the user sees each error once.
    var seen: Map<string, bool> = [:]
    for e in tc.errors {
        let key = strings.cat(
            strings.cat(strings.cat(e.span.file, ":"), strings.cat(i64_to_string_local(e.span.line), ":")),
            strings.cat(strings.cat(i64_to_string_local(e.span.col), ":"), e.message))
        if map.contains(&seen, key) { } else {
            seen[key] = true
            fmt.println(`{e.span.file}:{e.span.line}:{e.span.col}: {e.message}`)
            let src = src_cache_get(&cache, e.span.file)
            if len(src) > 0 {
                let line = nth_line(src, e.span.line)
                if len(line) > 0 {
                    fmt.println(`    {line}`)
                    fmt.println(`    {caret_pad(line, e.span.col)}`)
                }
            }
        }
    }
}

let i64_to_string_local(v: i64): string = {
    if v == 0 { return "0" }
    var s = ""
    var n = v
    var neg = false
    if n < 0 { neg = true; n = 0 - n }
    while n > 0 {
        let d = n % 10
        let digit = strings.slice("0123456789", d, d + 1)
        s = strings.cat(digit, s)
        n = n / 10
    }
    if neg { s = strings.cat("-", s) }
    s
}

let summary(tc: *TyContext) = {
    fmt.println(`enums:    {len(tc.enums)}`)
    fmt.println(`structs:  {len(tc.structs)}`)
    fmt.println(`aliases:  {len(tc.aliases)}`)
    fmt.println(`fns:      {len(tc.fns)}`)
    fmt.println(`externs:  {len(tc.externs)}`)
    fmt.println(`packages: {len(tc.packages)}`)
    fmt.println(`errors:   {len(tc.errors)}`)
}

// --- Type resolution ---

let resolve_type(tc: *TyContext, te: ast.TypeExpr): ty.Ty = {
    match te {
    | TEUnit(_)                  -> ty.ty_unit_()
    | TEPtr(_, inner)            -> ty.ty_ptr_(resolve_type(tc, *inner))
    | TETuple(_, elems)          -> {
        var resolved: Vec<ty.Ty> = []
        for el in elems { vec.push(&resolved, resolve_type(tc, el)) }
        ty.ty_tuple_(resolved)
    }
    | TENamed(span, path, args)  -> resolve_named(tc, span, path, args)
    | TEFn(_, params, ret)       -> {
        var resolved: Vec<ty.Ty> = []
        for p in params {
            vec.push(&resolved, resolve_type(tc, p))
        }
        ty.ty_fn_(resolved, resolve_type(tc, *ret))
    }
    }
}

let resolve_named(tc: *TyContext, span: ast.Span, path: Vec<string>, args: Vec<ast.TypeExpr>): ty.Ty = {
    if len(path) == 2 {
        let pkg  = path[0]
        let name = path[1]
        // Qualified access: pick the home that matches the qualifier
        // when one of the registered homes is exactly `pkg`. An
        // empty home (prelude or the user's entry package) is
        // accessible under any qualifier.
        var resolved_home = pkg
        var qualifier_ok = false
        match map.get(&tc.type_homes, name) {
        | None        -> { qualifier_ok = true }
        | Some(homes) -> {
            for h in homes {
                if strings.eq_raw(h, pkg) {
                    qualifier_ok = true
                    resolved_home = pkg
                }
            }
            if !qualifier_ok {
                for h in homes {
                    if strings.eq_raw(h, "") {
                        qualifier_ok = true
                        resolved_home = ""
                    }
                }
            }
            if !qualifier_ok {
                let first = if len(homes) > 0 { homes[0] } else { "" }
                record_error(tc, span, `type '{name}' lives in package '{first}', not '{pkg}'`)
                return ty.ty_error_()
            }
        }
        }
        return resolve_named_short(tc, span, resolved_home, name, args)
    }
    if len(path) != 1 {
        record_error(tc, span, "type paths must be a single name or 'pkg.Name'")
        return ty.ty_error_()
    }
    let name: string = path[0]
    // Prelude files legitimately have file_pkgs[file] = "", so a
    // missing entry is distinct from an empty entry. A missing entry
    // while the name is known means the TypeExpr reached
    // resolve_named without going through the loader.
    var use_site_pkg: string = ""
    var have_pkg = false
    match map.get(&tc.file_pkgs, span.file) {
    | Some(p) -> {
        use_site_pkg = p
        have_pkg = true
    }
    | None -> { }
    }
    if !have_pkg {
        match map.get(&tc.type_homes, name) {
        | Some(_) -> {
            record_error(tc, span, `internal: no package recorded for file '{span.file}' resolving type '{name}'`)
            return ty.ty_error_()
        }
        | None -> { }
        }
    }
    match map.get(&tc.type_homes, name) {
    | Some(homes) -> {
        var found_use_site = false
        var found_prelude  = false
        var other_home     = ""
        for h in homes {
            if strings.eq_raw(h, use_site_pkg) { found_use_site = true }
            elif strings.eq_raw(h, "")          { found_prelude  = true }
            else                                { other_home     = h }
        }
        if found_use_site {
            return resolve_named_short(tc, span, use_site_pkg, name, args)
        }
        if found_prelude {
            return resolve_named_short(tc, span, "", name, args)
        }
        record_error(tc, span, `type '{name}' is from package '{other_home}'; use '{other_home}.{name}'`)
        return ty.ty_error_()
    }
    | None -> { }
    }
    resolve_named_short(tc, span, "", name, args)
}

// Number of type parameters a type declaration takes.
let type_decl_param_count(d: ast.Decl): i64 = {
    match d {
    | DStruct(_, _, tps, _)    -> len(tps)
    | DEnum(_, _, tps, _)      -> len(tps)
    | DTypeAlias(_, _, tps, _) -> len(tps)
    // Other declarations are not types applied with arguments.
    | _                        -> 0
    }
}

// A generic type must be applied to exactly its declared number of type
// arguments. A bare `Tensor` for `type Tensor<T>` would otherwise reach
// emit as an un-monomorphised name.
let check_type_arity(tc: *TyContext, span: ast.Span, name: string, want: i64, got: i64) = {
    if tc.record_head_resolve { return }
    if want != got {
        record_error(tc, span, `type '{name}' takes {want} type argument(s) but {got} were given`)
    }
}

let resolve_named_short(tc: *TyContext, span: ast.Span, home: string, name: string, args: Vec<ast.TypeExpr>): ty.Ty = {
    if map.contains(&tc.type_params, name) {
        return ty.ty_var_(name)
    }
    if strings.eq_raw(name, "i8")     { return ty.ty_int_(8,  true) }
    if strings.eq_raw(name, "i16")    { return ty.ty_int_(16, true) }
    if strings.eq_raw(name, "i32")    { return ty.ty_int_(32, true) }
    if strings.eq_raw(name, "i64")    { return ty.ty_int_(64, true) }
    if strings.eq_raw(name, "u8")     { return ty.ty_int_(8,  false) }
    if strings.eq_raw(name, "u16")    { return ty.ty_int_(16, false) }
    if strings.eq_raw(name, "u32")    { return ty.ty_int_(32, false) }
    if strings.eq_raw(name, "u64")    { return ty.ty_int_(64, false) }
    if strings.eq_raw(name, "f32")    { return ty.ty_float_(32) }
    if strings.eq_raw(name, "f64")    { return ty.ty_float_(64) }
    if strings.eq_raw(name, "bool")   { return ty.ty_bool_() }
    if strings.eq_raw(name, "char")   { return ty.ty_char_() }
    if strings.eq_raw(name, "string") { return ty.ty_string_() }
    if strings.eq_raw(name, "cstring"){ return ty.ty_cstring_() }
    if strings.eq_raw(name, "unit")   { return ty.ty_unit_() }
    if strings.eq_raw(name, "void")   { return ty.ty_unit_() }
    var resolved_args: Vec<ty.Ty> = []
    for a in args {
        vec.push(&resolved_args, resolve_type(tc, a))
    }
    let key = type_key(home, name)
    if let Some(d) = map.get(&tc.enums, key) {
        check_type_arity(tc, span, name, type_decl_param_count(d), len(args))
        return ty.ty_adt_homed(home, name, resolved_args)
    }
    if let Some(d) = map.get(&tc.structs, key) {
        check_type_arity(tc, span, name, type_decl_param_count(d), len(args))
        return ty.ty_record_homed(home, name, resolved_args)
    }
    if let Some(d) = map.get(&tc.aliases, key) {
        check_type_arity(tc, span, name, type_decl_param_count(d), len(args))
        match d {
        | DTypeAlias(_, _, tparams, target) -> {
            return resolve_type_with_subst(tc, target, tparams, resolved_args)
        }
        // Only DTypeAlias is stored in tc.aliases; reaching here
        // would be an internal bug.
        | _ -> { }
        }
        return ty.ty_record_homed(home, name, resolved_args)
    }
    if map.contains(&tc.c_enums, key) {
        match map.get(&tc.c_enums, key) {
        | Some(d) -> {
            match d {
            | DCEnum(_, _, underlying, _) -> {
                return ty.ty_cenum_(home, name, resolve_type(tc, underlying))
            }
            | _ -> { }
            }
        }
        | None -> { }
        }
    }
    record_error(tc, span, `unknown type '{name}'`)
    ty.ty_error_()
}

// --- Environment for local bindings during expression checking ---

type Binding = { name: string, ty: ty.Ty, is_var: bool }

type Env = {
    bindings: Vec<Binding>,
}

let env_make(): Env = Env { bindings: [] }

let env_define(env: *Env, name: string, t: ty.Ty) = {
    vec.push(&env.bindings, Binding { name: name, ty: t, is_var: true })
}

// Variant of env_define that records whether the binding is mutable.
// SLet introduces immutable bindings. SVar, function parameters,
// and closure parameters introduce mutable bindings. `check_assign`
// consults this flag to reject assignment to a `let`.
let env_define_var(env: *Env, name: string, t: ty.Ty, is_var: bool) = {
    vec.push(&env.bindings, Binding { name: name, ty: t, is_var: is_var })
}

let env_lookup(env: *Env, name: string): ty.Ty = {
    var i: i64 = len(env.bindings) - 1
    while i >= 0 {
        let b = env.bindings[i]
        if strings.eq_raw(b.name, name) {
            return b.ty
        }
        i -= 1
    }
    ty.ty_error_()
}

let env_is_var(env: *Env, name: string): bool = {
    var i: i64 = len(env.bindings) - 1
    while i >= 0 {
        let b = env.bindings[i]
        if strings.eq_raw(b.name, name) {
            return b.is_var
        }
        i -= 1
    }
    // Unknown names default to mutable so we do not stack a spurious
    // immutability diagnostic on top of the undefined-name error.
    true
}

let env_has(env: *Env, name: string): bool = {
    var i: i64 = len(env.bindings) - 1
    while i >= 0 {
        let b = env.bindings[i]
        if strings.eq_raw(b.name, name) {
            return true
        }
        i -= 1
    }
    false
}

// --- Expression synthesis ---

// Find the innermost expected-type hint covering the cursor.
// Walks expected_hints and returns the hint whose span starts
// closest to but not after `(line, col)` in `file`. Returns
// None when no hint precedes the cursor.
let expected_at_cursor(tc: *TyContext, file: string, line: i64, col: i64): Option<ty.Ty> = {
    var best_line: i64 = -1
    var best_col: i64 = -1
    var found = false
    var result: ty.Ty = ty.ty_error_()
    for h in tc.expected_hints {
        let same_file   = strings.eq_raw(h.span.file, file)
        let before_line = h.span.line < line
        let same_line   = h.span.line == line
        let at_or_before_col = h.span.col <= col
        let in_range = same_file && (before_line || (same_line && at_or_before_col))
        if in_range {
            let later_line = h.span.line > best_line
            let later_col  = h.span.line == best_line && h.span.col > best_col
            if !found || later_line || later_col {
                best_line = h.span.line
                best_col = h.span.col
                result = h.ty
                found = true
            }
        }
    }
    if found { Some(result) } else { None }
}

let synth(tc: *TyContext, env: *Env, e: ast.Expr): ty.Ty = {
    synth_inner(tc, env, e)
}

let synth_inner(tc: *TyContext, env: *Env, e: ast.Expr): ty.Ty = {
    match e {
    | EInt(_, _)             -> ty.ty_int_untyped()
    | EFloat(_, _)           -> ty.ty_float_untyped()
    | EString(_, _)          -> ty.ty_string_()
    | EChar(_, _)            -> ty.ty_char_()
    | EBool(_, _)            -> ty.ty_bool_()
    | ENil(_)                -> ty.ty_nil_()
    | EIdent(span, name)     -> synth_ident(tc, env, span, name)
    | EPath(sp, segs)        -> synth_path(tc, sp, segs)
    | EUnary(sp, op, rhs)    -> synth_unary(tc, env, sp, op, *rhs)
    | EBinary(sp, op, l, r)  -> synth_binary(tc, env, sp, op, *l, *r)
    | EAssign(sp, _, l, v)   -> check_assign(tc, env, sp, *l, *v)
    | ECall(sp, callee, ta, args) -> synth_call_full(tc, env, sp, *callee, ta, args)
    | EField(sp, base, name) -> synth_field(tc, env, sp, *base, name)
    | EIndex(sp, base, idx)  -> synth_index(tc, env, sp, *base, *idx)
    | ECast(_, value, te)    -> { let _ = synth(tc, env, *value); resolve_type(tc, te) }
    | ETry(sp, v)            -> {
        // The `?` operator on the prelude's Result<T, E> evaluates to
        // T. Codegen handles the early-return on the Err branch. The
        // operand's home must be "" (the prelude). A user-declared
        // enum that happens to be named Result is rejected.
        let t = synth(tc, env, *v)
        if ty.ty_is_error(t) { return ty.ty_error_() }
        match t {
        | TyAdt(home, name, args) -> {
            if strings.eq_raw(home, "") && strings.eq_raw(name, "Result") && len(args) >= 1 {
                return args[0]
            }
            record_error(tc, sp, `the '?' operator requires the prelude Result<T, E>, got {ty.ty_show(t)}`)
            ty.ty_error_()
        }
        | _ -> {
            record_error(tc, sp, `the '?' operator requires the prelude Result<T, E>, got {ty.ty_show(t)}`)
            ty.ty_error_()
        }
        }
    }
    | ETuple(_, elems)       -> {
        var elem_tys: Vec<ty.Ty> = []
        for el in elems { vec.push(&elem_tys, synth(tc, env, el)) }
        ty.ty_tuple_(elem_tys)
    }
    | ERecord(sp, te, fields) -> synth_record(tc, env, sp, te, fields)
    | EClosure(sp, cps, ret, body) -> {
        var pty: Vec<ty.Ty> = []
        for cp in cps {
            let t = resolve_type(tc, cp.ty)
            vec.push(&pty, t)
            env_define(env, cp.name, t)
        }
        let ret_ty = resolve_type(tc, ret)
        let saved_ret = tc.current_ret_ty
        tc.current_ret_ty = ret_ty
        let body_ty = synth(tc, env, *body)
        tc.current_ret_ty = saved_ret
        // A closure with no explicit return annotation parses with a
        // TEUnit ret which resolves to TyUnit. In that case the return
        // type is the body's type. An explicit annotation is checked
        // against the body instead.
        if !ty.ty_is_unit(ret_ty) && !ty.ty_is_error(ret_ty) && !ty.ty_is_error(body_ty) {
            if !ty.ty_is_nil(body_ty) && !ty.ty_assignable(ret_ty, body_ty) {
                record_error(tc, sp, `closure body produces {ty.ty_show(body_ty)} but declared return type is {ty.ty_show(ret_ty)}`)
            }
        }
        let effective_ret = if ty.ty_is_unit(ret_ty) { body_ty } else { ret_ty }
        ty.ty_fn_(pty, effective_ret)
    }
    | EBlock(_, stmts, tail) -> synth_block(tc, env, stmts, *tail)
    | EIf(sp, c, t, f)       -> synth_if(tc, env, sp, *c, *t, *f)
    | EMatch(sp, scrut, arms) -> synth_match(tc, env, sp, *scrut, arms)
    | EWhile(sp, c, b)       -> {
        let ct = synth(tc, env, *c)
        if !ty.ty_is_error(ct) && !ty.ty_is_bool(ct) {
            record_error(tc, sp, `while condition must be bool, got {ty.ty_show(ct)}`)
        }
        let _ = synth(tc, env, *b)
        ty.ty_unit_()
    }
    | EFor(sp, b1, b2, it, b) -> {
        let it_ty = synth(tc, env, *it)
        if !ty.ty_is_error(it_ty) && !iterable_ty(it_ty, !strings.eq_raw(b2, "")) {
            let kind = if strings.eq_raw(b2, "") { "iterable" } else { "Map-like iterable producing key, value pairs" }
            record_error(tc, sp, `for loop expects {kind}, got {ty.ty_show(it_ty)}`)
        }
        let saved_len = len(env.bindings)
        bind_for_loop(env, b1, b2, it_ty)
        let _ = synth(tc, env, *b)
        env_truncate(env, saved_len)
        ty.ty_unit_()
    }
    | EReturn(sp, v)         -> {
        let vt = synth(tc, env, *v)
        let rt = tc.current_ret_ty
        // A unit-returning function accepts a bare `return` whose
        // value parses as nil. The discarded value never reaches
        // user code. Skip the type check on that arm. TyError on
        // either side also skips because a diagnostic was already
        // recorded upstream.
        let skip =
            ty.ty_is_error(vt) ||
            ty.ty_is_error(rt) ||
            ty.ty_is_unit(rt)
        if !skip && !ty.ty_assignable(rt, vt) {
            record_error(tc, sp, `return value of type {ty.ty_show(vt)} does not match function's declared return type {ty.ty_show(rt)}`)
        }
        ty.ty_unit_()
    }
    | EDefer(_, b)           -> { let _ = synth(tc, env, *b); ty.ty_unit_() }
    | ESizeOf(_, _)          -> ty.ty_int_(64, true)
    | EArrayLit(sp, elems, lit_te)   -> {
        // A `Vec<T>` annotation pins the element type; without one, the
        // first element's synth fixes it. Every element is then checked
        // against the expected type, so a mismatch is caught here
        // instead of reaching emit.
        var has_lit = false
        var lit_ty: ty.Ty = ty.ty_error_()
        var elem_expected: ty.Ty = ty.ty_error_()
        match lit_te {
        | TEUnit(_) -> { }
        | _         -> {
            has_lit = true
            lit_ty = resolve_type(tc, lit_te)
            if let TyRecord(_, _, args) = lit_ty {
                if len(args) >= 1 { elem_expected = args[0] }
            }
        }
        }
        if !has_lit {
            if len(elems) == 0 { return ty.ty_error_() }
            elem_expected = synth(tc, env, elems[0])
        }
        var idx: i64 = 0
        for el in elems {
            let et = synth(tc, env, el)
            if !ty.ty_is_error(elem_expected) && !ty.ty_is_error(et) {
                if !ty.ty_assignable(elem_expected, et) {
                    record_error(tc, ast.span_of_expr(el), `array element {idx} has type {ty.ty_show(et)}, expected {ty.ty_show(elem_expected)}`)
                }
            }
            idx += 1
        }
        if has_lit { return lit_ty }
        var args2: Vec<ty.Ty> = []
        vec.push(&args2, elem_expected)
        ty.ty_record_("Vec", args2)
    }
    | EMapLit(sp, keys, values, lit_te) -> {
        // A `Map<K, V>` annotation pins both element types; without one,
        // the first entry fixes them. Every key and value is checked
        // against the expected types.
        var has_lit = false
        var lit_ty: ty.Ty = ty.ty_error_()
        var key_expected: ty.Ty = ty.ty_error_()
        var val_expected: ty.Ty = ty.ty_error_()
        match lit_te {
        | TEUnit(_) -> { }
        | _         -> {
            has_lit = true
            lit_ty = resolve_type(tc, lit_te)
            if let TyRecord(_, _, args) = lit_ty {
                if len(args) >= 2 {
                    key_expected = args[0]
                    val_expected = args[1]
                }
            }
        }
        }
        if !has_lit {
            if len(keys) == 0 { return ty.ty_error_() }
            key_expected = synth(tc, env, keys[0])
            val_expected = synth(tc, env, values[0])
        }
        var ki: i64 = 0
        for k in keys {
            let kt = synth(tc, env, k)
            if !ty.ty_is_error(key_expected) && !ty.ty_is_error(kt) {
                if !ty.ty_assignable(key_expected, kt) {
                    record_error(tc, ast.span_of_expr(k), `map key {ki} has type {ty.ty_show(kt)}, expected {ty.ty_show(key_expected)}`)
                }
            }
            ki += 1
        }
        var vi: i64 = 0
        for v in values {
            let vt = synth(tc, env, v)
            if !ty.ty_is_error(val_expected) && !ty.ty_is_error(vt) {
                if !ty.ty_assignable(val_expected, vt) {
                    record_error(tc, ast.span_of_expr(v), `map value {vi} has type {ty.ty_show(vt)}, expected {ty.ty_show(val_expected)}`)
                }
            }
            vi += 1
        }
        if has_lit { return lit_ty }
        var margs: Vec<ty.Ty> = []
        vec.push(&margs, key_expected)
        vec.push(&margs, val_expected)
        ty.ty_record_("Map", margs)
    }
    | ENew(_, inner) -> ty.ty_ptr_(synth(tc, env, *inner))
    | ENewType(_, t) -> ty.ty_ptr_(resolve_type(tc, t))
    | ELoadString(_, _, _) -> ty.ty_string_()
    | EParen(_, inner) -> synth(tc, env, *inner)
    }
}

// An lvalue is an expression that can appear on the left-hand side
// of `=`. Variable references, field selections, index expressions,
// and pointer dereferences are the four shapes Qoz allows. The
// check stays syntactic. Whether an `EIdent` actually names a `var`
// binding is enforced by a future pass, not here.
// `is_lvalue_shape` performs the structural part of the lvalue check.
// `is_lvalue` adds a type-aware refinement: a field or index access
// whose base is a function call writes to a temporary unless the
// call returns a pointer. The tc context is consulted to resolve the
// base's type.
let is_lvalue_shape(e: ast.Expr): bool = {
    match e {
    | EIdent(_, _)         -> true
    | EField(_, _, _)      -> true
    | EIndex(_, _, _)      -> true
    | EUnary(_, op, _)     -> { match op { | UOpDeref -> true | _ -> false } }
    | _                    -> false
    }
}

let is_lvalue(tc: *TyContext, env: *Env, e: ast.Expr): bool = {
    if !is_lvalue_shape(e) { return false }
    match e {
    | EField(_, base, _) | EIndex(_, base, _) -> {
        match *base {
        | ECall(_, _, _, _) -> {
            // A call returns a value. Assigning through `call().f`
            // would write to a temporary. Only valid when the
            // call's return type is a pointer.
            let bt = synth(tc, env, *base)
            match bt { | TyPtr(_) -> true | _ -> false }
        }
        | _ -> true
        }
    }
    | _ -> true
    }
}

// Type-check an assignment. Reports an error if the lhs has an
// unassignable shape, and if the rhs type cannot flow into the lhs
// type. Returns unit. The assignment expression itself produces no
// value.
let check_assign(tc: *TyContext, env: *Env, sp: ast.Span, lhs: ast.Expr, rhs: ast.Expr): ty.Ty = {
    if !is_lvalue(tc, env, lhs) {
        record_error(tc, sp, "left-hand side of `=` is not assignable")
    }
    // Reject assignment to a let-bound identifier. Field, index, and
    // deref lvalues are still permitted because they write through a
    // reference. Only direct ident assignment needs the mutability
    // check.
    match lhs {
    | EIdent(_, name) -> {
        if env_has(env, name) && !env_is_var(env, name) {
            record_error(tc, sp, `cannot assign to 'let'-bound '{name}'; use 'var' to declare a mutable binding`)
        }
    }
    | _ -> { }
    }
    let lt = synth(tc, env, lhs)
    let rt = synth(tc, env, rhs)
    match lt { | TyError -> return ty.ty_unit_() | _ -> { } }
    match rt { | TyError -> return ty.ty_unit_() | _ -> { } }
    if !ty.ty_assignable(lt, rt) {
        let want = ty.ty_show(lt)
        let got  = ty.ty_show(rt)
        record_error(tc, sp, `cannot assign value of type {got} to lhs of type {want}`)
    }
    ty.ty_unit_()
}

let synth_unary(tc: *TyContext, env: *Env, sp: ast.Span, op: ast.UnaryOp, rhs: ast.Expr): ty.Ty = {
    let t = synth(tc, env, rhs)
    if ty.ty_is_error(t) { return ty.ty_error_() }
    match op {
    | UOpNeg   -> {
        if !ty.ty_is_numeric(t) {
            record_error(tc, sp, `unary '-' requires a numeric operand, got {ty.ty_show(t)}`)
            return ty.ty_error_()
        }
        t
    }
    | UOpNot   -> {
        if !ty.ty_is_bool(t) {
            record_error(tc, sp, `unary '!' requires a bool operand, got {ty.ty_show(t)}`)
            return ty.ty_error_()
        }
        ty.ty_bool_()
    }
    | UOpDeref -> {
        match t {
        | TyPtr(inner) -> *inner
        | _            -> {
            record_error(tc, sp, `cannot dereference value of type {ty.ty_show(t)}`)
            ty.ty_error_()
        }
        }
    }
    | UOpAddr  -> ty.ty_ptr_(t)
    }
}

// Find the home of a C-style enum with the given short name.
// Returns Some(home) when registered (home may be the empty
// string for entry/prelude declarations), None when no such
// enum exists. The Option wrapper distinguishes "registered at
// prelude" from "not found".
let c_enum_home_short(tc: *TyContext, name: string): Option<string> = {
    match map.get(&tc.type_homes, name) {
    | None        -> None
    | Some(homes) -> {
        for h in homes {
            if map.contains(&tc.c_enums, type_key(h, name)) { return Some(h) }
        }
        None
    }
    }
}

let find_c_enum_decl_short(tc: *TyContext, name: string): Option<ast.Decl> = {
    if let Some(h) = c_enum_home_short(tc, name) {
        return map.get(&tc.c_enums, type_key(h, name))
    }
    None
}

// True when `variant` is one of the C-enum's declared variants.
let c_enum_has_variant(d: ast.Decl, variant: string): bool = {
    match d {
    | DCEnum(_, _, _, variants) -> {
        for v in variants { if strings.eq_raw(v, variant) { return true } }
        false
    }
    | _ -> false
    }
}

// When `base.name` reads a C-enum variant, return the enum type.
// `Some(t)` indicates the field resolved; `None` lets the caller
// fall through to ordinary struct/record field resolution. The
// base is either a bare identifier (the enum's renamed name in
// the same package) or `pkg.EnumShort`, where the qualify pass
// has renamed the registered enum to `<pkg>_<EnumShort>`.
let c_enum_variant_ref(tc: *TyContext, base: ast.Expr, name: string): Option<ty.Ty> = {
    let base_name = match base {
    | EIdent(_, n) -> n
    | EField(_, inner, enum_short) -> {
        match *inner {
        | EIdent(_, pkg) -> strings.cat(strings.cat(pkg, "_"), enum_short)
        | _              -> ""
        }
    }
    | _ -> ""
    }
    if strings.eq_raw(base_name, "") { return None }
    if let Some(home) = c_enum_home_short(tc, base_name) {
        if let Some(d) = find_c_enum_decl_short(tc, base_name) {
            if c_enum_has_variant(d, name) {
                match d {
                | DCEnum(_, _, underlying, _) -> return Some(ty.ty_cenum_(home, base_name, resolve_type(tc, underlying)))
                // DCEnum is the only kind stored in tc.c_enums.
                // Other arms cannot occur; falling through to the
                // None return makes the dead path explicit.
                | _                           -> { }
                }
            }
        }
    }
    None
}

let synth_field(tc: *TyContext, env: *Env, sp: ast.Span, base: ast.Expr, name: string): ty.Ty = {
    if is_qualified_variant_field(tc, base, name) {
        return synth_variant_ctor(tc, name)
    }
    // `EnumName.Variant` for a C-style enum: yield the enum type.
    // The runtime value is the variant's integer; the type-checker
    // keeps the named identity so distinct enums do not unify.
    match c_enum_variant_ref(tc, base, name) {
    | Some(t) -> return t
    | None    -> { }
    }
    // Package-qualified read: `pkg.NAME` where `pkg` is a known
    // package and `<pkg>_<name>` names a top-level const. Resolve
    // to the const's declared type so the field expression carries
    // the right type into the surrounding context.
    match base {
    | EIdent(_, base_name) -> {
        if map.contains(&tc.packages, base_name) {
            let qual = strings.cat(strings.cat(base_name, "_"), name)
            match map.get(&tc.consts, qual) {
            | Some(d) -> {
                match d {
                | DConst(_, _, t, val) -> {
                    let annotated = resolve_type(tc, t)
                    if ty.ty_is_unit(annotated) {
                        var inner_env = env_make()
                        return synth(tc, &inner_env, val)
                    }
                    return annotated
                }
                | _ -> { }
                }
            }
            | None -> { }
            }
        }
    }
    | _ -> { }
    }
    let bt = synth(tc, env, base)
    if ty.ty_is_error(bt) { return ty.ty_error_() }
    // Allow `pkg.fn` qualified references through without a field
    // diagnostic: the path goes through call resolution, not field
    // synthesis. Detect by base being an EIdent whose name is a
    // registered package.
    match base {
    | EIdent(_, base_name) -> {
        if map.contains(&tc.packages, base_name) { return ty.ty_error_() }
    }
    | _ -> { }
    }
    let ft = field_type_of(tc, bt, name)
    if ty.ty_is_error(ft) {
        record_error(tc, sp, `type {ty.ty_show(bt)} has no field '{name}'`)
    }
    ft
}

// True when `base.name` is `EnumName.VariantName`: base is a known
// enum and the field name is one of its variants. Lets the bare
// variant constructor path handle the synth, identical in shape to
// what `Variant` alone produces.
let is_qualified_variant_field(tc: *TyContext, base: ast.Expr, name: string): bool = {
    match base {
    | EIdent(_, base_name) -> {
        if !has_enum_short(tc, base_name) { return false }
        match map.get(&tc.variant_of, name) {
        | Some(declared_enum) -> strings.eq_raw(declared_enum, base_name)
        | None                -> false
        }
    }
    | _ -> false
    }
}

let field_type_of(tc: *TyContext, bt: ty.Ty, name: string): ty.Ty = {
    match bt {
    | TyPtr(inner) -> field_type_of(tc, *inner, name)
    | TyRecord(home, struct_name, tyargs) -> lookup_field(tc, home, struct_name, tyargs, name)
    | TyTuple(elems) -> {
        // Tuple fields are named `_0`, `_1`, ...
        if len(name) >= 2 && strings.byte_at(name, 0) == 95 {
            let idx = strings.parse_int(strings.slice(name, 1, len(name)))
            if idx >= 0 && idx < len(elems) { return elems[idx] }
        }
        ty.ty_error_()
    }
    | _ -> ty.ty_error_()
    }
}

let lookup_field(tc: *TyContext, home: string, struct_name: string, tyargs: Vec<ty.Ty>, field: string): ty.Ty = {
    match find_struct(tc, home, struct_name) {
    | Some(d) -> {
        match d {
        | DStruct(_, _, params, fields) -> {
            for f in fields {
                if strings.eq_raw(f.name, field) {
                    if len(params) == len(tyargs) {
                        return resolve_type_with_subst(tc, f.ty, params, tyargs)
                    }
                    return resolve_type(tc, f.ty)
                }
            }
            ty.ty_error_()
        }
        | _ -> ty.ty_error_()
        }
    }
    | None -> ty.ty_error_()
    }
}

let resolve_type_with_subst(tc: *TyContext, te: ast.TypeExpr, params: Vec<string>, args: Vec<ty.Ty>): ty.Ty = {
    let saved = tc.type_params
    set_type_params(tc, params)
    let raw = resolve_type(tc, te)
    tc.type_params = saved
    apply_subst(raw, params, args)
}

let apply_subst(t: ty.Ty, params: Vec<string>, args: Vec<ty.Ty>): ty.Ty = {
    match t {
    | TyVar(_, name) -> {
        var i: i64 = 0
        for p in params {
            if strings.eq_raw(p, name) {
                if i < len(args) { return args[i] }
                return t
            }
            i += 1
        }
        t
    }
    | TyPtr(inner) -> ty.ty_ptr_(apply_subst(*inner, params, args))
    | TyAdt(h, n, a)  -> {
        var na: Vec<ty.Ty> = []
        for x in a { vec.push(&na, apply_subst(x, params, args)) }
        ty.ty_adt_homed(h, n, na)
    }
    | TyRecord(h, n, a) -> {
        var na: Vec<ty.Ty> = []
        for x in a { vec.push(&na, apply_subst(x, params, args)) }
        ty.ty_record_homed(h, n, na)
    }
    | TyFn(p, r) -> {
        var np: Vec<ty.Ty> = []
        for x in p { vec.push(&np, apply_subst(x, params, args)) }
        ty.ty_fn_(np, apply_subst(*r, params, args))
    }
    | _ -> t
    }
}

// Index expression. Three shapes are indexable: raw pointers (with
// an integer index), `Vec<T>` (integer index, returns T), and
// `Map<K, V>` (key must be assignable to K, returns V). Any other
// base, and any non-matching index type, raises a diagnostic.
let synth_index(tc: *TyContext, env: *Env, sp: ast.Span, base: ast.Expr, idx: ast.Expr): ty.Ty = {
    let bt = synth(tc, env, base)
    let it = synth(tc, env, idx)
    if ty.ty_is_error(bt) || ty.ty_is_error(it) { return ty.ty_error_() }
    // Vec and Map index the same whether the receiver is a value
    // or a pointer; unwrap_container_ty peels one `*`, so a
    // `*Vec<T>` / `*Map<K, V>` indexes like its value form.
    let info = unwrap_container_ty(bt)
    if strings.eq_raw(info.kind, "Vec") && len(info.args) >= 1 {
        if !ty.ty_is_int(it) {
            record_error(tc, sp, `Vec index must be an integer, got {ty.ty_show(it)}`)
        }
        return info.args[0]
    }
    if strings.eq_raw(info.kind, "Map") && len(info.args) >= 2 {
        if !ty.ty_assignable(info.args[0], it) {
            record_error(tc, sp, `Map key has type {ty.ty_show(info.args[0])}; cannot use index of type {ty.ty_show(it)}`)
        }
        return info.args[1]
    }
    match bt {
    | TyString -> {
        if !ty.ty_is_int(it) {
            record_error(tc, sp, `string index must be an integer, got {ty.ty_show(it)}`)
        }
        ty.ty_int_(64, true)
    }
    | TyPtr(inner) -> {
        if !ty.ty_is_int(it) {
            record_error(tc, sp, `pointer index must be an integer, got {ty.ty_show(it)}`)
        }
        *inner
    }
    | _ -> {
        record_error(tc, sp, `cannot index value of type {ty.ty_show(bt)}`)
        ty.ty_error_()
    }
    }
}

let is_strings_callee(callee: ast.Expr, method: string): bool = {
    match callee {
    | EField(_, base, m) -> {
        if !strings.eq_raw(m, method) { return false }
        match *base {
        | EIdent(_, name) -> strings.eq_raw(name, "strings")
        | _ -> false
        }
    }
    | _ -> false
    }
}

let sb_append_method_for(t: ty.Ty): string = {
    match t {
    | TyString  -> "sb_append"
    | TyBool    -> "sb_append_bool"
    | TyFloat(_) -> "sb_append_f64"
    | TyInt(_)  -> "sb_append_i64"
    | TyChar    -> "sb_append_i64"
    | _         -> "sb_append"
    }
}

// Per-type interpolation push name. The parser desugars every
// interpolation slot to a call to __qoz_interp_push_str. This routine
// retargets it to the matching typed variant once the slot's value
// type is known. Returning None signals that the slot's type is not a
// supported interpolation primitive. The caller must report that as
// an error.
let interp_push_method_for(t: ty.Ty): Option<string> = {
    match t {
    | TyString   -> Some("__qoz_interp_push_str")
    | TyBool     -> Some("__qoz_interp_push_bool")
    | TyFloat(_) -> Some("__qoz_interp_push_f64")
    | TyInt(_)   -> Some("__qoz_interp_push_i64")
    | TyChar     -> Some("__qoz_interp_push_char")
    | _          -> None
    }
}

let is_interp_intrinsic(name: string): bool = {
    strings.has_prefix(name, "__qoz_interp_")
}

let is_len_argument(t: ty.Ty): bool = {
    match t {
    | TyString | TyCstring -> true
    | TyRecord(_, name, _) -> strings.eq_raw(name, "Vec") || strings.eq_raw(name, "Map")
    | TyPtr(inner)         -> is_len_argument(*inner)
    | TyVar(_, _)          -> true
    | _                    -> false
    }
}

// Records reach this predicate via the @operator("hash") dispatch:
// the emit phase rewrites a bare `hash(rec)` into a call to the
// user's overload, so the check stage need not understand the
// concrete signature, only that an overload could exist.
let is_hash_argument(t: ty.Ty): bool = {
    match t {
    | TyString | TyCstring | TyChar | TyBool -> true
    | TyInt(_)        -> true
    | TyPtr(inner)    -> is_hash_argument(*inner)
    | TyVar(_, _)     -> true
    | TyRecord(_, _, _) -> true
    | _               -> false
    }
}

// True when `t` can be rendered to a string by the auto-derived show
// machinery. Records, ADTs, tuples, Vec, and Map are all printable
// because their structure is exposed to the compiler. Function values
// and the explicit error/unit sentinels are not.
let can_show_ty(t: ty.Ty): bool = {
    match t {
    | TyRecord(_, _, _) | TyAdt(_, _, _) | TyTuple(_) -> true
    | TyPtr(inner)                              -> can_show_ty(*inner)
    | _                                         -> false
    }
}

let resolve_callee_fn(tc: *TyContext, callee: ast.Expr): string = {
    match callee {
    | EIdent(_, name) -> name
    | EField(_, base, method) -> {
        match *base {
        | EIdent(_, pkg) -> {
            if map.contains(&tc.packages, pkg) {
                return strings.cat(strings.cat(pkg, "_"), method)
            }
            // `Enum.Variant(...)`: the base is a known enum and the
            // field is one of its variants. Return the bare variant
            // name so the variant constructor dispatch downstream
            // handles the call.
            if has_enum_short(tc, pkg) {
                if map.contains(&tc.variant_of, method) {
                    return method
                }
            }
            ""
        }
        | _ -> ""
        }
    }
    | _ -> ""
    }
}

let synth_call_full(tc: *TyContext, env: *Env, sp: ast.Span, callee: ast.Expr, type_args: Vec<ast.TypeExpr>, args: Vec<ast.Expr>): ty.Ty = {
    let fn_name: string = resolve_callee_fn(tc, callee)
    // size_of is parsed as ESizeOf directly, so it never reaches this
    // path. len and hash are bare-name primitives. len accepts a
    // string, Vec, Map, or a pointer to one of these (the &xs form
    // used elsewhere in the compiler). Anything else is rejected.
    // hash accepts a string, integer, or pointer to a value of those
    // types. User records that overload hash flow through the regular
    // operator-dispatch path and never reach here.
    if strings.eq_raw(fn_name, "len") {
        if len(args) != 1 {
            record_error(tc, sp, `len() takes exactly 1 argument, got {len(args)}`)
            return ty.ty_int_(64, true)
        }
        let t = synth(tc, env, args[0])
        if !ty.ty_is_error(t) && !is_len_argument(t) {
            record_error(tc, sp, `len() expects a string, Vec, or Map (or a pointer to one); got {ty.ty_show(t)}`)
        }
        return ty.ty_int_(64, true)
    }
    if strings.eq_raw(fn_name, "hash") {
        if len(args) != 1 {
            record_error(tc, sp, `hash() takes exactly 1 argument, got {len(args)}`)
            return ty.ty_int_(64, false)
        }
        let t = synth(tc, env, args[0])
        if !ty.ty_is_error(t) && !is_hash_argument(t) {
            record_error(tc, sp, `hash() expects a string, integer, char, bool, or pointer to one of these; got {ty.ty_show(t)}`)
        }
        return ty.ty_int_(64, false)
    }
    // Interpolation intrinsics. Implemented as bare-name runtime
    // primitives so the backtick-interpolation desugar has no
    // dependency on any user-importable module. The arguments are
    // synthesised so their types are recorded. Rewrite_call later
    // retargets the push call to the per-type variant.
    if is_interp_intrinsic(fn_name) {
        for a in args { let _ = synth(tc, env, a) }
        if strings.eq_raw(fn_name, "__qoz_interp_init")   { return ty.ty_ptr_(ty.ty_unit_()) }
        if strings.eq_raw(fn_name, "__qoz_interp_finish") { return ty.ty_string_() }
        return ty.ty_unit_()
    }
    // Auto-derived show. The check phase synthesises a per-type
    // __qoz_show_<MangledT>(v: T): string call whenever a non-primitive
    // interpolation slot is encountered. The emit phase generates the
    // function body. The argument type is checked elsewhere because
    // the rewriter constructs the call with a known concrete type.
    if strings.has_prefix(fn_name, "__qoz_show_") {
        for a in args { let _ = synth(tc, env, a) }
        return ty.ty_string_()
    }
    var arg_tys: Vec<ty.Ty> = []
    for a in args { vec.push(&arg_tys, synth(tc, env, a)) }
    if strings.eq_raw(fn_name, "") { return ty.ty_error_() }
    match map.get(&tc.fns, fn_name) {
    | Some(d) -> synth_call_with_decl(tc, sp, d, type_args, arg_tys)
    | None -> {
        match map.get(&tc.externs, fn_name) {
        | Some(d) -> synth_call_with_decl(tc, sp, d, type_args, arg_tys)
        | None    -> {
            // The name is not a fn or extern. It may still be a
            // variant constructor (bare or via Enum.Variant). When
            // it is not, the call is to an undefined name and that
            // needs a diagnostic. Previously the call returned
            // TyError silently.
            if map.contains(&tc.variant_of, fn_name) {
                // Arity check: each variant constructor takes exactly
                // its declared positional payload count. The qualified
                // callee form (Enum.Variant) pins the enum name even
                // when the bare variant is ambiguous.
                let qual_enum = explicit_enum_from_callee(callee)
                let enum_n = if strings.eq_raw(qual_enum, "") {
                    variant_enum_name(tc, fn_name)
                } else { qual_enum }
                let want = len(variant_positional_types(tc, enum_n, fn_name))
                let got  = len(arg_tys)
                if want != got {
                    record_error(tc, sp, `variant '{enum_n}::{fn_name}' takes {want} argument(s), got {got}`)
                }
                return synth_variant_ctor_with_args_in(tc, fn_name, enum_n, arg_tys)
            }
            // The name may refer to a fn-typed local binding (a
            // captured closure, a higher-order parameter). Look up
            // the environment and, if the binding is a TyFn, take
            // its return type as the call result.
            if env_has(env, fn_name) {
                let bt = env_lookup(env, fn_name)
                match bt {
                | TyFn(_, rt) -> return *rt
                | _ -> { }
                }
            }
            record_error(tc, sp, `call to undefined function '{fn_name}'`)
            ty.ty_error_()
        }
        }
    }
    }
}

// Synthesise a record literal's type, inferring the struct's type
// parameters from the field values when the annotation does not pin
// them. The unification matches each declared field's TypeExpr (which
// may name a tparam) against the synthesised value type and accumulates
// bindings.
let synth_record(tc: *TyContext, env: *Env, sp: ast.Span, te: ast.TypeExpr, fields: Vec<ast.RecordFieldLit>): ty.Ty = {
    // Resolve the literal's head type with arity checking suppressed:
    // a record literal may omit the type arguments and have them
    // inferred from the field values below.
    let saved_rhr = tc.record_head_resolve
    tc.record_head_resolve = true
    let bare_resolved = resolve_type(tc, te)
    tc.record_head_resolve = saved_rhr
    let struct_name = record_name_of(bare_resolved)
    if strings.eq_raw(struct_name, "") { return bare_resolved }
    let struct_home = record_home_of(bare_resolved)
    validate_record_fields(tc, sp, struct_home, struct_name, fields)
    let tparams = struct_tparams(tc, struct_home, struct_name)
    let pinned = len(tparams) > 0 && annotation_pins_type_args(te, tparams)
    var bindings: Map<string, ty.Ty> = [:]
    let saved = tc.type_params
    set_type_params(tc, tparams)
    // Check each provided field's value against its declared type, and
    // collect bindings for a generic struct so the tparams can be
    // inferred from the field values.
    var i: i64 = 0
    while i < len(fields) {
        let f = fields[i]
        if !strings.eq_raw(f.name, "..") {
            if let Some(dte) = struct_field_typeexpr(tc, struct_home, struct_name, f.name) {
                let p_ty = resolve_type(tc, dte)
                let v_ty = synth(tc, env, f.value)
                if !ty.ty_is_error(p_ty) && !ty.ty_is_error(v_ty) {
                    if len(tparams) > 0 {
                        if !unify(p_ty, v_ty, &bindings) {
                            record_error(tc, ast.span_of_expr(f.value), `field '{f.name}' has type {ty.ty_show(v_ty)}, expected {ty.ty_show(p_ty)}`)
                        }
                    } else {
                        if !ty.ty_assignable(p_ty, v_ty) {
                            record_error(tc, ast.span_of_expr(f.value), `field '{f.name}' has type {ty.ty_show(v_ty)}, expected {ty.ty_show(p_ty)}`)
                        }
                    }
                }
            }
        }
        i += 1
    }
    tc.type_params = saved
    if len(tparams) == 0 { return bare_resolved }
    if pinned { return bare_resolved }
    var args: Vec<ty.Ty> = []
    var ti: i64 = 0
    while ti < len(tparams) {
        let tp = tparams[ti]
        if let Some(t) = map.get(&bindings, tp) {
            vec.push(&args, t)
        } else {
            vec.push(&args, ty.ty_var_(tp))
        }
        ti += 1
    }
    let home = pick_type_home(tc, struct_name, home_of_file(tc, sp.file))
    ty.ty_record_homed(home, struct_name, args)
}

// Validate a record literal's field set against the struct declaration.
// Reports unknown field names. Does not enforce completeness because
// partial initialisation is part of the language (the user-controlled
// option to leave fields default-initialised).
let validate_record_fields(tc: *TyContext, sp: ast.Span, home: string, struct_name: string, fields: Vec<ast.RecordFieldLit>) = {
    match find_struct(tc, home, struct_name) {
    | Some(d) -> {
        match d {
        | DStruct(_, _, _, declared) -> {
            for f in fields {
                if strings.eq_raw(f.name, "..") { } else {
                    var found = false
                    for df in declared {
                        if strings.eq_raw(df.name, f.name) { found = true }
                    }
                    if !found {
                        record_error(tc, sp, `struct '{struct_name}' has no field '{f.name}'`)
                    }
                }
            }
        }
        | _ -> { }
        }
    }
    | None -> { }
    }
}

// Rewrite an ERecord's TypeExpr to include the type arguments inferred
// by synth_record. When the annotation already pins the args (or the
// struct has no tparams), the original te is returned unchanged so the
// AST node identity does not flip.
let inferred_record_te(tc: *TyContext, env: *Env, sp: ast.Span, te: ast.TypeExpr, fields: Vec<ast.RecordFieldLit>): ast.TypeExpr = {
    let orig_path = te_path_segments(te)
    let struct_name = if len(orig_path) >= 1 { orig_path[len(orig_path) - 1] } else { "" }
    if strings.eq_raw(struct_name, "") { return te }
    let struct_home = if len(orig_path) == 2 {
        orig_path[0]
    } else {
        pick_type_home(tc, struct_name, home_of_file(tc, sp.file))
    }
    let tparams = struct_tparams(tc, struct_home, struct_name)
    if len(tparams) == 0 { return te }
    if annotation_pins_type_args(te, tparams) { return te }
    let synth_ty = synth_record(tc, env, sp, te, fields)
    let args = ty_record_args(synth_ty)
    if len(args) != len(tparams) { return te }
    var te_args: Vec<ast.TypeExpr> = []
    var i: i64 = 0
    while i < len(args) {
        vec.push(&te_args, ty.ty_to_type_expr_at(args[i], sp))
        i += 1
    }
    TENamed(sp, orig_path, te_args)
}

let te_path_segments(te: ast.TypeExpr): Vec<string> = {
    let empty: Vec<string> = []
    match te {
    | TENamed(_, path, _) -> path
    | _                   -> empty
    }
}

// The declared field names, in order, of a named-payload variant. Empty
// for a positional or nullary variant, or an unknown name.
let variant_named_field_names(tc: *TyContext, variant_name: string): Vec<string> = {
    var out: Vec<string> = []
    match map.get(&tc.variant_of, variant_name) {
    | None     -> { }
    | Some(en) -> {
        match find_enum_short(tc, en) {
        | Some(d) -> {
            match d {
            | DEnum(_, _, _, variants) -> {
                for v in variants {
                    if strings.eq_raw(v.name, variant_name) {
                        for sf in v.named { vec.push(&out, sf.name) }
                    }
                }
            }
            | _ -> { }
            }
        }
        | None -> { }
        }
    }
    }
    out
}

// Reorder a named-payload variant pattern `V { a, b: p }` to the
// positional form the binder and emit expect, using the variant's
// declared field order. An omitted field becomes a wildcard. Recurses
// so nested patterns are reordered too. A positional pattern is
// returned unchanged except for its sub-patterns being desugared.
let desugar_pattern(tc: *TyContext, p: ast.Pattern): ast.Pattern = {
    match p {
    | PatVariant(sp, path, pats, names) -> {
        var dpats: Vec<ast.Pattern> = []
        for sub in pats { vec.push(&dpats, desugar_pattern(tc, sub)) }
        if len(names) == 0 {
            return PatVariant(sp, path, dpats, [])
        }
        let variant = path[len(path) - 1]
        let order = variant_named_field_names(tc, variant)
        var ordered: Vec<ast.Pattern> = []
        for fname in order {
            var idx: i64 = 0 - 1
            var k: i64 = 0
            for nm in names {
                if strings.eq_raw(nm, fname) { idx = k }
                k += 1
            }
            if idx >= 0 {
                vec.push(&ordered, dpats[idx])
            } else {
                vec.push(&ordered, PatWild(sp))
            }
        }
        PatVariant(sp, path, ordered, [])
    }
    | PatTuple(sp, subs) -> {
        var d: Vec<ast.Pattern> = []
        for s in subs { vec.push(&d, desugar_pattern(tc, s)) }
        PatTuple(sp, d)
    }
    // Other patterns hold no sub-patterns to reorder.
    | _ -> p
    }
}

let ty_record_args(t: ty.Ty): Vec<ty.Ty> = {
    let empty: Vec<ty.Ty> = []
    match t {
    | TyRecord(_, _, args) -> args
    | _                 -> empty
    }
}

// Verify a `let name: T = value` binding's declared type accepts the
// value's synthesised type. Skips the check when there is no
// annotation (te is TEUnit) since the value's type is used as the
// binding's type. Skips when either side is an error so that a
// single mismatch does not cascade.
let check_binding_compat(tc: *TyContext, sp: ast.Span, te: ast.TypeExpr, bound: ty.Ty, vt: ty.Ty) = {
    // No annotation = nothing to check. The binding's type is the
    // value's type by definition.
    if let TEUnit(_) = te { return }
    if !ty.ty_assignable(bound, vt) {
        let want = ty.ty_show(bound)
        let got  = ty.ty_show(vt)
        record_error(tc, sp, `binding type {want} cannot accept value of type {got}`)
    }
}

let annotation_pins_type_args(te: ast.TypeExpr, tparams: Vec<string>): bool = {
    match te {
    | TENamed(_, _, ann_args) -> len(ann_args) == len(tparams)
    | _                       -> false
    }
}

let struct_tparams(tc: *TyContext, home: string, name: string): Vec<string> = {
    let empty: Vec<string> = []
    match find_struct(tc, home, name) {
    | Some(d) -> {
        match d {
        | DStruct(_, _, tps, _) -> tps
        | _                     -> empty
        }
    }
    | None -> empty
    }
}

let struct_field_typeexpr(tc: *TyContext, home: string, name: string, field: string): Option<ast.TypeExpr> = {
    match find_struct(tc, home, name) {
    | Some(d) -> {
        match d {
        | DStruct(_, _, _, fields) -> {
            var i: i64 = 0
            while i < len(fields) {
                if strings.eq_raw(fields[i].name, field) {
                    return Some(fields[i].ty)
                }
                i += 1
            }
            None
        }
        | _ -> None
        }
    }
    | None -> None
    }
}

// `Enum::Variant` path expression. Two segments: the enum name and a
// variant of that enum. The result is the variant constructor type
// produced by synth_variant_ctor. Any other shape is reported.
let synth_path(tc: *TyContext, sp: ast.Span, segs: Vec<string>): ty.Ty = {
    if len(segs) != 2 {
        record_error(tc, sp, "path expression must have exactly two segments (Enum::Variant)")
        return ty.ty_error_()
    }
    let enum_name = segs[0]
    let variant   = segs[1]
    if !has_enum_short(tc, enum_name) {
        record_error(tc, sp, `unknown enum '{enum_name}'`)
        return ty.ty_error_()
    }
    match map.get(&tc.variant_of, variant) {
    | Some(declared_enum) -> {
        if !strings.eq_raw(declared_enum, enum_name) {
            record_error(tc, sp, `'{variant}' is not a variant of enum '{enum_name}'`)
            return ty.ty_error_()
        }
        synth_variant_ctor(tc, variant)
    }
    | None -> {
        record_error(tc, sp, `unknown variant '{enum_name}::{variant}'`)
        ty.ty_error_()
    }
    }
}

let synth_variant_ctor(tc: *TyContext, name: string): ty.Ty = {
    synth_variant_ctor_with_args(tc, name, [])
}

// Pull an explicit enum name out of a qualified variant callee. The
// EField form is what rewrite_call produces when it disambiguates a
// bare variant call. The EPath form is what the parser produces for
// `Enum::Variant` syntax. Returns "" for bare-identifier callees.
let explicit_enum_from_callee(callee: ast.Expr): string = {
    match callee {
    | EField(_, base, _) -> {
        match *base {
        | EIdent(_, en) -> en
        | _             -> ""
        }
    }
    | EPath(_, segs) -> {
        if len(segs) == 2 { segs[0] } else { "" }
    }
    | _ -> ""
    }
}

// Like synth_variant_ctor, but unifies the value-argument types against
// the variant's declared positional payload to bind the enum's type
// parameters. `Option.Some(42)` returns `Option<i64>` rather than the
// open `Option<T>`. Falls back to the open form when no args are
// available or unification leaves a tparam unbound.
let synth_variant_ctor_with_args(tc: *TyContext, name: string, arg_tys: Vec<ty.Ty>): ty.Ty = {
    synth_variant_ctor_with_args_in(tc, name, variant_enum_name(tc, name), arg_tys)
}

// Variant constructor synth with an explicit enum name. The enum
// argument is the one chosen by qualified-call resolution. For the
// unqualified path the caller passes variant_enum_name(tc, name) as
// the default.
let synth_variant_ctor_with_args_in(tc: *TyContext, name: string, enum_name: string, arg_tys: Vec<ty.Ty>): ty.Ty = {
    if strings.eq_raw(enum_name, "") { return ty.ty_error_() }
    let variant_pos = variant_positional_types(tc, enum_name, name)
    // Arity check. A diagnostic-bearing site that has a span (the
    // ECall surrounding this call) is preferred. Here we rely on the
    // caller (synth_call_full) having a span to anchor downstream
    // errors. Skip when len(arg_tys) == 0 because that allows
    // referencing the variant constructor as a value.
    if len(arg_tys) > 0 && len(arg_tys) != len(variant_pos) {
        // Use the first variant type's span as a fallback. The caller
        // should supply a better span via ECall. This path covers
        // bare path forms.
    }
    let tparams = enum_tparams(tc, enum_name)
    let home = pick_type_home(tc, enum_name, "")
    if len(tparams) == 0 { return ty.ty_adt_homed(home, enum_name, []) }
    var bindings: Map<string, ty.Ty> = [:]
    let saved = tc.type_params
    set_type_params(tc, tparams)
    var i: i64 = 0
    while i < len(variant_pos) {
        if i < len(arg_tys) {
            let pos_ty = resolve_type(tc, variant_pos[i])
            let _ = unify(pos_ty, arg_tys[i], &bindings)
        }
        i += 1
    }
    tc.type_params = saved
    var args: Vec<ty.Ty> = []
    var ti: i64 = 0
    while ti < len(tparams) {
        let tp = tparams[ti]
        if let Some(t) = map.get(&bindings, tp) {
            vec.push(&args, t)
        } else {
            vec.push(&args, ty.ty_var_(tp))
        }
        ti += 1
    }
    ty.ty_adt_homed(home, enum_name, args)
}

let record_name_of(t: ty.Ty): string = {
    match t {
    | TyRecord(_, name, _) -> name
    | _                 -> ""
    }
}

let record_home_of(t: ty.Ty): string = {
    match t {
    | TyRecord(home, _, _) -> home
    | _                    -> ""
    }
}

let variant_enum_name(tc: *TyContext, variant: string): string = {
    match map.get(&tc.variant_of, variant) {
    | Some(en) -> en
    | None     -> ""
    }
}

let enum_tparams(tc: *TyContext, enum_name: string): Vec<string> = {
    let empty: Vec<string> = []
    match find_enum_short(tc, enum_name) {
    | Some(d) -> {
        match d {
        | DEnum(_, _, tps, _) -> tps
        | _                   -> empty
        }
    }
    | None -> empty
    }
}

let variant_positional_types(tc: *TyContext, enum_name: string, variant: string): Vec<ast.TypeExpr> = {
    let empty: Vec<ast.TypeExpr> = []
    match find_enum_short(tc, enum_name) {
    | Some(d) -> {
        match d {
        | DEnum(_, _, _, variants) -> {
            var out: Vec<ast.TypeExpr> = []
            var found = false
            var i: i64 = 0
            while i < len(variants) {
                let v = variants[i]
                if !found {
                    if strings.eq_raw(v.name, variant) {
                        out = v.pos
                        found = true
                    }
                }
                i += 1
            }
            out
        }
        | _ -> empty
        }
    }
    | None -> empty
    }
}

let synth_call_with_decl(tc: *TyContext, sp: ast.Span, d: ast.Decl, type_args: Vec<ast.TypeExpr>, arg_tys: Vec<ty.Ty>): ty.Ty = {
    match d {
    | DFn(_, fn_name, tparams, params, ret, _, _) -> {
        if len(arg_tys) != len(params) {
            record_error(tc, sp, `function expects {len(params)} argument(s), got {len(arg_tys)}`)
        }
        // Look up the callee's resolved param and return types from
        // the cache populated by validate_signatures. Skips a walk
        // of the callee's TypeExprs on every call site.
        let param_tys: Vec<ty.Ty> = match map.get(&tc.fn_param_tys, fn_name) {
        | Some(ts) -> ts
        | None     -> []
        }
        let cached_ret: ty.Ty = match map.get(&tc.fn_ret_ty, fn_name) {
        | Some(t) -> t
        | None    -> ty.ty_error_()
        }
        if len(tparams) == 0 {
            var i: i64 = 0
            while i < len(param_tys) && i < len(arg_tys) {
                if !ty.ty_assignable(param_tys[i], arg_tys[i]) {
                    let want = ty.ty_show(param_tys[i])
                    let got  = ty.ty_show(arg_tys[i])
                    record_error(tc, sp, `expected {want}, got {got}`)
                }
                i += 1
            }
            return cached_ret
        }
        var tyarg_tys: Vec<ty.Ty> = []
        if len(type_args) == len(tparams) {
            for ta in type_args { vec.push(&tyarg_tys, resolve_type(tc, ta)) }
        } else {
            var subst_env: Map<string, ty.Ty> = [:]
            var ok = true
            var i: i64 = 0
            while i < len(arg_tys) && i < len(param_tys) {
                if !unify(param_tys[i], arg_tys[i], &subst_env) { ok = false }
                i += 1
            }
            if !ok {
                record_error(tc, sp, "could not infer generic type arguments at call site")
            }
            for tp in tparams {
                match map.get(&subst_env, tp) {
                | Some(t) -> vec.push(&tyarg_tys, t)
                | None    -> {
                    record_error(tc, sp, `type parameter '{tp}' is not constrained by any argument; add an explicit annotation`)
                    vec.push(&tyarg_tys, ty.ty_error_())
                }
                }
            }
        }
        let raw_ret = cached_ret
        apply_subst(raw_ret, tparams, tyarg_tys)
    }
    | DExternal(_, ex_name, _, _, _) -> {
        match map.get(&tc.fn_ret_ty, ex_name) {
        | Some(t) -> t
        | None    -> ty.ty_error_()
        }
    }
    | _ -> ty.ty_error_()
    }
}

let unify(pattern: ty.Ty, concrete: ty.Ty, env: *Map<string, ty.Ty>): bool = {
    match pattern {
    | TyVar(_, name) -> {
        match map.get(env, name) {
        | Some(prior) -> compatible_or_refine(env, name, prior, concrete)
        | None -> {
            map.set(env, name, concrete)
            true
        }
        }
    }
    | TyPtr(pi) -> {
        match concrete {
        | TyPtr(ci) -> unify(*pi, *ci, env)
        | TyNil     -> true
        | _         -> false
        }
    }
    | TyAdt(_, pn, pa) -> {
        match concrete {
        | TyAdt(_, cn, ca) -> strings.eq_raw(pn, cn) && unify_args(pa, ca, env)
        | _             -> false
        }
    }
    | TyRecord(_, pn, pa) -> {
        match concrete {
        | TyRecord(_, cn, ca) -> strings.eq_raw(pn, cn) && unify_args(pa, ca, env)
        | _                -> false
        }
    }
    | TyInt(pi) -> {
        match concrete {
        | TyInt(ci) -> ci.untyped || (pi.width == ci.width && pi.is_signed == ci.is_signed)
        | _         -> false
        }
    }
    | TyFloat(pf) -> {
        match concrete {
        | TyFloat(cf) -> cf.untyped || pf.width == cf.width
        | _           -> false
        }
    }
    | TyFn(pp, pr) -> {
        match concrete {
        | TyFn(cp, cr) -> unify_args(pp, cp, env) && unify(*pr, *cr, env)
        | _            -> false
        }
    }
    | _ -> ty.ty_eq(pattern, concrete)
    }
}

// Untyped numeric literals refine to the bound concrete type.
let compatible_or_refine(env: *Map<string, ty.Ty>, name: string, prior: ty.Ty, concrete: ty.Ty): bool = {
    if ty.ty_eq(prior, concrete) { return true }
    match prior {
    | TyInt(pi) -> {
        match concrete {
        | TyInt(ci) -> {
            if ci.untyped { return true }
            if pi.untyped {
                map.set(env, name, concrete)
                return true
            }
            false
        }
        | _ -> false
        }
    }
    | TyFloat(pf) -> {
        match concrete {
        | TyFloat(cf) -> {
            if cf.untyped { return true }
            if pf.untyped {
                map.set(env, name, concrete)
                return true
            }
            false
        }
        | _ -> false
        }
    }
    | _ -> false
    }
}

let unify_args(a: Vec<ty.Ty>, b: Vec<ty.Ty>, env: *Map<string, ty.Ty>): bool = {
    if len(a) != len(b) { return false }
    var i: i64 = 0
    while i < len(a) {
        if !unify(a[i], b[i], env) { return false }
        i += 1
    }
    true
}

let is_ty_error(t: ty.Ty): bool =
    match t {
    | TyError -> true
    | _       -> false
    }

let synth_ident(tc: *TyContext, env: *Env, span: ast.Span, name: string): ty.Ty = {
    if env_has(env, name) {
        return env_lookup(env, name)
    }
    // Bare references to top-level functions and externs are used as
    // function values. The type is the function's declared signature,
    // looked up from tc.fns / tc.externs.
    match map.get(&tc.fns, name) {
    | Some(decl) -> return fn_decl_value_type(tc, decl)
    | None -> { }
    }
    match map.get(&tc.externs, name) {
    | Some(decl) -> return fn_decl_value_type(tc, decl)
    | None -> { }
    }
    match map.get(&tc.variant_of, name) {
    | Some(enum_name) -> return synth_variant_ctor(tc, name)
    | None -> { }
    }
    match map.get(&tc.consts, name) {
    | Some(decl) -> {
        match decl {
        | DConst(_, _, t, val) -> {
            let annotated = resolve_type(tc, t)
            if ty.ty_is_unit(annotated) {
                var inner_env = env_make()
                return synth(tc, &inner_env, val)
            }
            return annotated
        }
        | _ -> { }
        }
    }
    | None -> { }
    }
    if let Some(homes) = map.get(&tc.c_variant_homes, name) {
        var list = ""
        var first = true
        for h in homes {
            if !first { list = strings.cat(list, ", ") }
            first = false
            list = strings.cat(list, denormalize_enum_name(h))
            list = strings.cat(list, ".")
            list = strings.cat(list, name)
        }
        record_error(tc, span, `ambiguous C-enum variant '{name}': could be {list}. Qualify with one of these to disambiguate.`)
        return ty.ty_error_()
    }
    record_error(tc, span, `undefined name '{name}'`)
    ty.ty_error_()
}

// Compute the value type of a function or extern decl as a `TyFn`.
// Used when a function is referenced bare (as a first-class value)
// rather than called.
let fn_decl_value_type(tc: *TyContext, d: ast.Decl): ty.Ty = {
    match d {
    | DFn(_, _, _, params, ret, _, _) | DExternal(_, _, _, params, ret) -> {
        var pts: Vec<ty.Ty> = []
        for p in params { vec.push(&pts, resolve_type(tc, p.ty)) }
        ty.ty_fn_(pts, resolve_type(tc, ret))
    }
    | _ -> ty.ty_error_()
    }
}

// Binary-operator type check. Each operator group has its own
// operand-type and result-type rules. Errors are recorded with a
// span pointing at the operator's expression. A propagated `TyError`
// on either side short-circuits without raising a new diagnostic so
// downstream noise stays low.
// Head name of an operator's first parameter type, used to key the
// overload registry. A pointer parameter (the common form, since an
// operator takes *T) reduces to the pointee's name. Mirrors emit's
// operator_first_param_type_name.
let operator_first_param_type_name(te: ast.TypeExpr): string = {
    match te {
    | TEPtr(_, inner) -> {
        match *inner {
        | TENamed(_, path, _) -> if len(path) > 0 { path[len(path) - 1] } else { "" }
        | _                   -> ""
        }
    }
    | TENamed(_, path, _) -> if len(path) > 0 { path[len(path) - 1] } else { "" }
    | _                   -> ""
    }
}

// Head name of an operand's resolved type, matching the keying used at
// registration. A pointer reduces to its pointee's name.
let ty_head_name(t: ty.Ty): string = {
    match t {
    | TyPtr(inner)          -> ty_head_name(*inner)
    | TyRecord(_, n, _)     -> n
    | TyAdt(_, n, _)        -> n
    | TyCEnum(_, n, _)      -> n
    | _                     -> ""
    }
}

// Source symbol for an overloadable binary operator. Empty for the
// operators that cannot be overloaded (logical, range).
let binop_symbol(op: ast.BinaryOp): string = {
    match op {
    | BOpAdd -> "+"  | BOpSub -> "-"  | BOpMul -> "*"  | BOpDiv -> "/"  | BOpMod -> "%"
    | BOpEq  -> "==" | BOpNe  -> "!=" | BOpLt  -> "<"  | BOpGt  -> ">"  | BOpLe  -> "<=" | BOpGe -> ">="
    // Logical, bitwise, shift, and range operators are not overloadable.
    | _      -> ""
    }
}

// Result type of an @operator overload for `op` on operand `lt`, when
// one is registered for the operand's type. The overload is checked
// like a call so a generic operator's return type is instantiated for
// the operands.
let operator_binary_result(tc: *TyContext, sp: ast.Span, op: ast.BinaryOp, lt: ty.Ty, rt: ty.Ty): Option<ty.Ty> = {
    let sym = binop_symbol(op)
    if strings.eq_raw(sym, "") { return None }
    let tn = ty_head_name(lt)
    if strings.eq_raw(tn, "") { return None }
    if let Some(fn) = map.get(&tc.op_overloads, strings.cat(strings.cat(sym, "::"), tn)) {
        if let Some(d) = map.get(&tc.fns, fn) {
            // The operator takes its operands by reference. A value
            // operand is addressed to match a pointer parameter (what
            // emit's by-value forwarder does); an operand that is
            // already a pointer matches directly.
            let params = match map.get(&tc.fn_param_tys, fn) {
            | Some(ps) -> ps
            | None     -> []
            }
            var arg_tys: Vec<ty.Ty> = []
            vec.push(&arg_tys, coerce_operand_to_param(lt, params, 0))
            vec.push(&arg_tys, coerce_operand_to_param(rt, params, 1))
            return Some(synth_call_with_decl(tc, sp, d, [], arg_tys))
        }
    }
    None
}

// Address a value operand when the operator parameter at `idx` is a
// pointer, leaving an already-pointer operand unchanged.
let coerce_operand_to_param(operand: ty.Ty, params: Vec<ty.Ty>, idx: i64): ty.Ty = {
    if idx >= len(params) { return operand }
    match params[idx] {
    | TyPtr(_) -> {
        match operand {
        | TyPtr(_) -> operand
        | _        -> ty.ty_ptr_(operand)
        }
    }
    | _ -> operand
    }
}

let synth_binary(tc: *TyContext, env: *Env, sp: ast.Span, op: ast.BinaryOp, l: ast.Expr, r: ast.Expr): ty.Ty = {
    let lt = synth(tc, env, l)
    let rt = synth(tc, env, r)
    if ty.ty_is_error(lt) || ty.ty_is_error(rt) { return binary_result_default(op) }
    // An @operator overload on the operand type takes precedence over
    // the built-in lowering, so an operator on a record or a pointer
    // type-checks instead of hitting the numeric / ordering rules.
    if let Some(res) = operator_binary_result(tc, sp, op, lt, rt) { return res }
    match op {
    | BOpEq | BOpNe -> {
        if !ty.ty_assignable(lt, rt) && !ty.ty_assignable(rt, lt) {
            record_error(tc, sp, `operands of '==' / '!=' have incompatible types: {ty.ty_show(lt)} vs {ty.ty_show(rt)}`)
        }
        ty.ty_bool_()
    }
    | BOpLt | BOpGt | BOpLe | BOpGe -> {
        if !ty.ty_is_numeric(lt) || !ty.ty_is_numeric(rt) {
            record_error(tc, sp, `ordering comparison requires numeric operands, got {ty.ty_show(lt)} and {ty.ty_show(rt)}`)
        }
        ty.ty_bool_()
    }
    | BOpAnd | BOpOr -> {
        if !ty.ty_is_bool(lt) || !ty.ty_is_bool(rt) {
            record_error(tc, sp, `logical operator requires bool operands, got {ty.ty_show(lt)} and {ty.ty_show(rt)}`)
        }
        ty.ty_bool_()
    }
    | BOpAdd | BOpSub | BOpMul | BOpDiv | BOpMod -> {
        if !ty.ty_is_numeric(lt) || !ty.ty_is_numeric(rt) {
            record_error(tc, sp, `arithmetic operator requires numeric operands, got {ty.ty_show(lt)} and {ty.ty_show(rt)}`)
            return ty.ty_error_()
        }
        if !ty.ty_assignable(lt, rt) && !ty.ty_assignable(rt, lt) {
            record_error(tc, sp, `arithmetic operands have incompatible numeric types: {ty.ty_show(lt)} vs {ty.ty_show(rt)}`)
        }
        lt
    }
    | BOpBitAnd | BOpBitOr | BOpBitXor | BOpShl | BOpShr -> {
        if !ty.ty_is_int(lt) || !ty.ty_is_int(rt) {
            record_error(tc, sp, `bitwise / shift operator requires integer operands, got {ty.ty_show(lt)} and {ty.ty_show(rt)}`)
            return ty.ty_error_()
        }
        lt
    }
    | BOpRange | BOpRangeInclusive -> {
        if !ty.ty_is_int(lt) || !ty.ty_is_int(rt) {
            record_error(tc, sp, `range bounds must be integers, got {ty.ty_show(lt)} and {ty.ty_show(rt)}`)
        }
        lt
    }
    }
}

let binary_result_default(op: ast.BinaryOp): ty.Ty = {
    match op {
    | BOpEq | BOpNe | BOpLt | BOpGt | BOpLe | BOpGe | BOpAnd | BOpOr -> ty.ty_bool_()
    | _ -> ty.ty_error_()
    }
}


let synth_block(tc: *TyContext, env: *Env, stmts: Vec<ast.Stmt>, tail: ast.Expr): ty.Ty = {
    for s in stmts {
        match s {
        | SLet(sp, name, te, val)  -> {
            let vt = synth(tc, env, val)
            let bound = match te { | TEUnit(_) -> vt | _ -> resolve_type(tc, te) }
            check_binding_compat(tc, sp, te, bound, vt)
            env_define_var(env, name, bound, false)
        }
        | SVar(sp, name, te, val)  -> {
            let vt = synth(tc, env, val)
            let bound = match te { | TEUnit(_) -> vt | _ -> resolve_type(tc, te) }
            check_binding_compat(tc, sp, te, bound, vt)
            env_define_var(env, name, bound, true)
        }
        | SLetTuple(_, _, _, _) -> { } // already desugared by infer_calls
        | SExpr(sp, ex)           -> {
            let t = synth(tc, env, ex)
            // A discarded Result<T, E> is almost always a bug because
            // the error case goes unhandled. Flag it. Other non-unit
            // values are conventionally discardable.
            if is_unhandled_result(t) {
                record_error(tc, sp, "discarded Result<T, E>; use `?`, `match`, or `let _ = ...` to acknowledge the value")
            }
        }
        }
    }
    synth(tc, env, tail)
}

// Conditional expression. The condition must be bool. The two
// branches must agree on a single result type modulo nil-vs-pointer
// flexibility, which is what `ty_assignable` already encodes. An
// if-without-else (parser-produced nil else) is treated as a
// statement-shaped construct: the value is whatever the then-branch
// produces, with nil flowing in cleanly.
let synth_if(tc: *TyContext, env: *Env, sp: ast.Span, c: ast.Expr, t: ast.Expr, f: ast.Expr): ty.Ty = {
    let ct = synth(tc, env, c)
    if !ty.ty_is_error(ct) && !ty.ty_is_bool(ct) {
        record_error(tc, sp, `if condition must be bool, got {ty.ty_show(ct)}`)
    }
    let tt = synth(tc, env, t)
    let ft = synth(tc, env, f)
    if ty.ty_is_error(tt) || ty.ty_is_error(ft) { return tt }
    // nil flows into any pointer / ADT type. Only flag mismatches
    // when both branches have a concrete non-nil type and neither
    // direction is assignable.
    if !ty.ty_is_nil(tt) && !ty.ty_is_nil(ft) {
        if !ty.ty_assignable(tt, ft) && !ty.ty_assignable(ft, tt) {
            record_error(tc, sp, `if branches have incompatible types: then is {ty.ty_show(tt)}, else is {ty.ty_show(ft)}`)
        }
    }
    tt
}

let synth_match(tc: *TyContext, env: *Env, sp: ast.Span, scrut: ast.Expr, arms: Vec<ast.MatchArm>): ty.Ty = {
    let scrut_ty = synth(tc, env, scrut)
    var result: ty.Ty = ty.ty_unit_()
    var first = true
    for arm in arms {
        let saved_len = len(env.bindings)
        bind_pattern(tc, env, arm.pat, scrut_ty)
        let armt = synth(tc, env, arm.body)
        env_truncate(env, saved_len)
        if first {
            result = armt
            first = false
        } else {
            if !ty.ty_is_error(result) && !ty.ty_is_error(armt) {
                if !ty.ty_is_nil(armt) && !ty.ty_is_nil(result) {
                    if !ty.ty_assignable(result, armt) && !ty.ty_assignable(armt, result) {
                        record_error(tc, sp, `match arms have incompatible types: earlier arm is {ty.ty_show(result)}, this arm is {ty.ty_show(armt)}`)
                    }
                }
            }
        }
    }
    check_match_exhaustiveness(tc, scrut, scrut_ty, arms)
    result
}

let check_match_exhaustiveness(tc: *TyContext, scrut: ast.Expr, scrut_ty: ty.Ty, arms: Vec<ast.MatchArm>) = {
    // Bool scrutinees: every match must cover both true and false (or
    // contain a catch-all). The check is light because bool has a
    // fixed two-element value set.
    if ty.ty_is_bool(scrut_ty) {
        check_bool_exhaustiveness(tc, scrut, arms)
        return
    }
    let enum_name = enum_name_of_ty(scrut_ty)
    if strings.eq_raw(enum_name, "") { return }
    match find_enum_short(tc, enum_name) {
    | Some(decl) -> {
        match decl {
        | DEnum(_, _, _, variants) -> {
            var vs: CoverSet = CoverSet { bound: [:] }
            for v in variants { vs.bound[v.name] = true }
            // Flag PatBind names that match a variant of a DIFFERENT
            // enum. Likely a typo (`Resul.Ok` written as plain `Ok`
            // matched on an Option scrutinee). The check runs once
            // per arm. It does not change exhaustiveness behaviour.
            for arm in arms {
                match arm.pat {
                | PatBind(psp, name) -> {
                    match map.get(&tc.variant_of, name) {
                    | Some(other_enum) -> {
                        if !strings.eq_raw(other_enum, enum_name) {
                            record_error(tc, psp, `binding '{name}' shadows a variant of enum '{other_enum}'; this arm is a catch-all bind, not a variant match. Use '{other_enum}.{name}' or rename the binding`)
                        }
                    }
                    | None -> { }
                    }
                }
                | _ -> { }
                }
            }
            if has_catch_all_with_variants(arms, &vs) { return }
            var cs: CoverSet = CoverSet { bound: [:] }
            collect_covered_variants(arms, &cs)
            var missing: Vec<string> = []
            for v in variants {
                if !map.contains(&cs.bound, v.name) {
                    vec.push(&missing, v.name)
                }
            }
            if len(missing) > 0 {
                var msg = "non-exhaustive match: missing"
                for m in missing {
                    msg = strings.cat(msg, " ")
                    msg = strings.cat(msg, m)
                }
                record_error(tc, scrut_span(scrut), msg)
            }
        }
        | _ -> { }
        }
    }
    | None -> { }
    }
}

let scrut_span(scrut: ast.Expr): ast.Span = {
    match scrut {
    | ENil(sp)
    | EInt(sp, _) | EFloat(sp, _) | EString(sp, _) | EChar(sp, _) | EBool(sp, _)
    | EIdent(sp, _) | EPath(sp, _) | EReturn(sp, _) | EDefer(sp, _) | ESizeOf(sp, _)
    | EArrayLit(sp, _, _) | EMapLit(sp, _, _, _) | ENew(sp, _) | ENewType(sp, _) | ELoadString(sp, _, _) | EParen(sp, _) | ETry(sp, _) | ETuple(sp, _)
    | EUnary(sp, _, _) | EField(sp, _, _) | EIndex(sp, _, _) | ECast(sp, _, _)
    | ERecord(sp, _, _) | EBlock(sp, _, _) | EWhile(sp, _, _) | EMatch(sp, _, _)
    | EBinary(sp, _, _, _) | EAssign(sp, _, _, _) | ECall(sp, _, _, _)
    | EIf(sp, _, _, _) | EClosure(sp, _, _, _)
    | EFor(sp, _, _, _, _) -> sp
    }
}

let enum_name_of_ty(t: ty.Ty): string = {
    match t {
    | TyAdt(_, name, _) -> name
    | _              -> ""
    }
}

let check_bool_exhaustiveness(tc: *TyContext, scrut: ast.Expr, arms: Vec<ast.MatchArm>) = {
    var has_true  = false
    var has_false = false
    var has_catch = false
    for arm in arms {
        if !arm.has_guard {
            match arm.pat {
            | PatWild(_) | PatBind(_, _) -> has_catch = true
            | PatLitBool(_, b) -> {
                if b { has_true = true } else { has_false = true }
            }
            | _ -> { }
            }
        }
    }
    if has_catch { return }
    if !has_true || !has_false {
        var msg = "non-exhaustive match on bool: missing"
        if !has_true  { msg = strings.cat(msg, " true") }
        if !has_false { msg = strings.cat(msg, " false") }
        record_error(tc, scrut_span(scrut), msg)
    }
}

let has_catch_all_with_variants(arms: Vec<ast.MatchArm>, variants: *CoverSet): bool = {
    for arm in arms {
        if !arm.has_guard {
            match arm.pat {
            | PatWild(_) -> return true
            | PatBind(_, name) -> {
                if !map.contains(&variants.bound, name) {
                    return true
                }
            }
            | _ -> { }
            }
        }
    }
    false
}

type CoverSet = { bound: Map<string, bool> }

let collect_covered_variants(arms: Vec<ast.MatchArm>, cs: *CoverSet) = {
    for arm in arms {
        if !arm.has_guard {
            match arm.pat {
            | PatVariant(_, path, _, _) -> {
                if len(path) > 0 {
                    let last = path[len(path) - 1]
                    cs.bound[last] = true
                }
            }
            | PatBind(_, name) -> {
                cs.bound[name] = true
            }
            | _ -> { }
            }
        }
    }
}

// True when `t` can drive a `for x in t` loop. With paired bindings
// (`for k, v in m`) only a two-argument Map is acceptable. With a
// single binding, the supported iterables are Vec, Map (yields keys),
// Range, and an integer (the `for i in 0..<n` range form, where the
// BOpRange operator returns its operand type). Pointers are not
// iterable because a raw pointer carries no length, so `for x in p`
// would have no termination condition.
let iterable_ty(t: ty.Ty, paired: bool): bool = {
    match t {
    | TyRecord(_, name, args) -> {
        if paired { return len(args) == 2 && strings.eq_raw(name, "Map") }
        strings.eq_raw(name, "Vec") || strings.eq_raw(name, "Map") || strings.eq_raw(name, "Range")
    }
    | TyInt(_) -> !paired
    | TyVar(_, _) -> true
    | TyAdt(_, name, _) -> strings.eq_raw(name, "Range")
    | _ -> false
    }
}

let bind_for_loop(env: *Env, b1: string, b2: string, it_ty: ty.Ty) = {
    if strings.eq_raw(b2, "") {
        match it_ty {
        | TyRecord(_, name, args) -> {
            if strings.eq_raw(name, "Vec") && len(args) >= 1 {
                env_define(env, b1, args[0])
                return
            }
        }
        | _ -> { }
        }
        env_define(env, b1, ty.ty_int_(64, true))
    } else {
        match it_ty {
        | TyRecord(_, _, args) -> {
            if len(args) == 2 {
                env_define(env, b1, args[0])
                env_define(env, b2, args[1])
                return
            }
        }
        | _ -> { }
        }
        env_define(env, b1, ty.ty_int_(64, true))
        env_define(env, b2, ty.ty_int_(64, true))
    }
}

let env_truncate(env: *Env, n: i64) = {
    env.bindings.len = n
}

let bind_pattern(tc: *TyContext, env: *Env, pat: ast.Pattern, scrut: ty.Ty) = {
    match pat {
    | PatWild(_) -> { }
    | PatLitInt(sp, _) -> {
        let bad = !ty.ty_is_error(scrut) && !ty.ty_is_int(scrut) && !ty.ty_is_numeric(scrut)
        if bad {
            record_error(tc, sp, `integer literal pattern cannot match scrutinee of type {ty.ty_show(scrut)}`)
        } else { }
    }
    | PatLitString(sp, _) -> {
        let bad = match scrut {
        | TyString | TyCstring | TyVar(_, _) | TyError -> false
        | _ -> true
        }
        if bad {
            record_error(tc, sp, `string literal pattern cannot match scrutinee of type {ty.ty_show(scrut)}`)
        } else { }
    }
    | PatLitBool(sp, _) -> {
        let bad = !ty.ty_is_error(scrut) && !ty.ty_is_bool(scrut)
        if bad {
            record_error(tc, sp, `bool literal pattern cannot match scrutinee of type {ty.ty_show(scrut)}`)
        } else { }
    }
    | PatTuple(sp, _) -> {
        record_error(tc, sp, "tuple patterns are not yet implemented")
    }
    | PatBind(_, name)               -> env_define(env, name, scrut)
    | PatVariant(sp, path, sub_pats, _) -> bind_variant_pattern(tc, env, sp, path, sub_pats, scrut)
    }
}

let bind_variant_pattern(tc: *TyContext, env: *Env, sp: ast.Span, path: Vec<string>, sub_pats: Vec<ast.Pattern>, scrut: ty.Ty) = {
    if len(path) < 1 { return }
    let variant = path[len(path) - 1]
    match map.get(&tc.variant_of, variant) {
    | None -> {
        record_error(tc, sp, `unknown variant '{variant}' in pattern`)
        return
    }
    | Some(declared_enum) -> {
        // When the variant name is shared across multiple enums,
        // pick the one matching the scrutinee's enum. variant_of
        // only records the first registration, which is unstable
        // under load order.
        let scrut_enum = enum_name_of_ty(scrut)
        var actual_enum = declared_enum
        if !strings.eq_raw(scrut_enum, "") {
            match map.get(&tc.variant_homes, variant) {
            | Some(homes) -> {
                for h in homes {
                    if strings.eq_raw(h, scrut_enum) { actual_enum = h }
                }
            }
            | None -> { }
            }
        }
        if !strings.eq_raw(scrut_enum, "") && !strings.eq_raw(scrut_enum, actual_enum) {
            record_error(tc, sp, `variant '{actual_enum}::{variant}' cannot match scrutinee of enum '{scrut_enum}'`)
            return
        }
        match find_enum_short(tc, actual_enum) {
        | Some(d) -> {
            match d {
            | DEnum(_, _, tparams, variants) -> {
                var tyargs: Vec<ty.Ty> = []
                match scrut {
                | TyAdt(_, _, args) -> tyargs = args
                | _              -> { }
                }
                for v in variants {
                    if strings.eq_raw(v.name, variant) {
                        if len(sub_pats) != len(v.pos) {
                            record_error(tc, sp, `variant '{variant}' takes {len(v.pos)} arguments but pattern provides {len(sub_pats)}`)
                        }
                        var i: i64 = 0
                        for pos_te in v.pos {
                            if i < len(sub_pats) {
                                let pos_ty = resolve_type_with_subst(tc, pos_te, tparams, tyargs)
                                bind_pattern(tc, env, sub_pats[i], pos_ty)
                            }
                            i += 1
                        }
                    }
                }
            }
            | _ -> { }
            }
        }
        | None -> { }
        }
    }
    }
}

// Returns a new File with type-args filled in at every generic call site.
let infer_calls(tc: *TyContext, f: ast.File): ast.File = {
    var new_decls: Vec<ast.Decl> = []
    for d in f.decls {
        vec.push(&new_decls, infer_calls_decl(tc, d))
    }
    ast.File { path: f.path, decls: new_decls }
}

let infer_calls_decl(tc: *TyContext, d: ast.Decl): ast.Decl = {
    match d {
    | DFn(sp, name, tparams, params, ret, body, attr) -> {
        set_type_params(tc, tparams)
        var env = env_make()
        for pp in params {
            env_define(&env, pp.name, resolve_type(tc, pp.ty))
        }
        let ret_ty = resolve_type(tc, ret)
        let new_body = infer_calls_expr(tc, &env, body, ret_ty)
        clear_type_params(tc)
        DFn(sp, name, tparams, params, ret, new_body, attr)
    }
    | DConst(sp, name, t, val) -> {
        var env = env_make()
        let expected = resolve_type(tc, t)
        let new_val = infer_calls_expr(tc, &env, val, expected)
        DConst(sp, name, t, new_val)
    }
    | _ -> d
    }
}

// Pick the renamed C-enum that owns a bare variant name. Returns
// Some(renamed_name) when exactly one enum claims the variant, or
// when expected is a TyCEnum whose enum declares it. Returns None
// when the bare reference is ambiguous (multiple homes, no
// expected) or when the name is not a C-enum variant at all. The
// caller decides whether to rewrite or emit a diagnostic.
// Convert a renamed enum identifier `<pkg>_<EnumShort>` back to the
// user-facing `pkg.EnumShort` form. Used only in diagnostics where
// the suggested qualified form should match the source syntax.
let denormalize_enum_name(renamed: string): string = {
    let n = len(renamed)
    var i: i64 = 0
    while i < n {
        if strings.byte_at(renamed, i) == 95 {
            let pkg = strings.slice(renamed, 0, i)
            let rest = strings.slice(renamed, i + 1, n)
            return strings.cat(strings.cat(pkg, "."), rest)
        }
        i += 1
    }
    renamed
}

let pick_c_enum_home(tc: *TyContext, name: string, expected: ty.Ty): Option<string> = {
    if let Some(homes) = map.get(&tc.c_variant_homes, name) {
        if let TyCEnum(_, enum_name, _) = expected {
            for h in homes { if strings.eq_raw(h, enum_name) { return Some(h) } }
        }
        if len(homes) == 1 { return Some(homes[0]) }
    }
    None
}

let infer_calls_expr(tc: *TyContext, env: *Env, e: ast.Expr, expected: ty.Ty): ast.Expr = {
    if !ty.ty_is_error(expected) {
        vec.push(&tc.expected_hints, ExpectedHint { span: ast.span_of_expr(e), ty: expected })
    }
    match e {
    | EInt(_, _)              -> e
    | EFloat(_, _)            -> e
    | EString(_, _)           -> e
    | EChar(_, _)             -> e
    | EBool(_, _)             -> e
    | ENil(_)                 -> e
    | EIdent(sp, name)        -> {
        if env_has(env, name) { return e }
        if map.contains(&tc.variant_of, name) { return e }
        match pick_c_enum_home(tc, name, expected) {
        | Some(enum_name) -> EField(sp, new_clone(EIdent(sp, enum_name)), name)
        | None            -> e
        }
    }
    | EPath(_, _)             -> e
    | EUnary(sp, op, rhs)     -> EUnary(sp, op, new_clone(infer_calls_expr(tc, env, *rhs, ty.ty_error_())))
    | EBinary(sp, op, l, r)   -> {
        let new_l = infer_calls_expr(tc, env, *l, ty.ty_error_())
        let new_r = infer_calls_expr(tc, env, *r, ty.ty_error_())
        // An overloaded operator whose operands are already pointers
        // lowers to a direct call on the operator function, so a generic
        // operator goes through the normal monomorphisation path. Value
        // operands keep the EBinary form, where emit's by-value
        // forwarder takes their address.
        let sym = binop_symbol(op)
        if !strings.eq_raw(sym, "") {
            if let TyPtr(_) = synth(tc, env, new_l) {
                let tn = ty_head_name(synth(tc, env, new_l))
                if !strings.eq_raw(tn, "") {
                    if let Some(fnname) = map.get(&tc.op_overloads, strings.cat(strings.cat(sym, "::"), tn)) {
                        var cargs: Vec<ast.Expr> = []
                        vec.push(&cargs, new_l)
                        vec.push(&cargs, new_r)
                        return rewrite_call(tc, env, sp, EIdent(sp, fnname), [], cargs, expected)
                    }
                }
            }
        }
        EBinary(sp, op, new_clone(new_l), new_clone(new_r))
    }
    | EAssign(sp, op, l, r)   -> {
        let new_l = infer_calls_expr(tc, env, *l, ty.ty_error_())
        let lhs_ty = synth(tc, env, *l)
        EAssign(sp, op, new_clone(new_l), new_clone(infer_calls_expr(tc, env, *r, lhs_ty)))
    }
    | ECall(sp, callee, ta, args) -> rewrite_call(tc, env, sp, *callee, ta, args, expected)
    | EField(sp, base, name)  -> EField(sp, new_clone(infer_calls_expr(tc, env, *base, ty.ty_error_())), name)
    | EIndex(sp, base, idx)   -> EIndex(sp, new_clone(infer_calls_expr(tc, env, *base, ty.ty_error_())), new_clone(infer_calls_expr(tc, env, *idx, ty.ty_error_())))
    | ECast(sp, value, t)     -> ECast(sp, new_clone(infer_calls_expr(tc, env, *value, ty.ty_error_())), t)
    | ETry(sp, v)             -> ETry(sp, new_clone(infer_calls_expr(tc, env, *v, expected)))
    | ETuple(sp, elems)       -> {
        var elem_hints: Vec<ty.Ty> = []
        if let TyTuple(hes) = expected {
            if len(hes) == len(elems) { elem_hints = hes }
        }
        var ne: Vec<ast.Expr> = []
        var i: i64 = 0
        for el in elems {
            let h = if len(elem_hints) > 0 { elem_hints[i] } else { ty.ty_error_() }
            vec.push(&ne, infer_calls_expr(tc, env, el, h))
            i += 1
        }
        ETuple(sp, ne)
    }
    | ERecord(sp, te, fields) -> {
        // `Variant { a: x, b: y }` constructs a named-payload variant.
        // Reorder the fields to the variant's declared order and rewrite
        // to a positional constructor call, which the rest of the
        // pipeline already handles.
        let head_segs = te_path_segments(te)
        if len(head_segs) >= 1 {
            let head = head_segs[len(head_segs) - 1]
            if map.contains(&tc.variant_of, head) {
                let order = variant_named_field_names(tc, head)
                var cargs: Vec<ast.Expr> = []
                for fname in order {
                    var found = false
                    for f in fields {
                        if strings.eq_raw(f.name, fname) {
                            vec.push(&cargs, f.value)
                            found = true
                        }
                    }
                    if !found {
                        record_error(tc, sp, `variant '{head}' is missing field '{fname}'`)
                    }
                }
                let callee: ast.Expr = if len(head_segs) == 2 {
                    EField(sp, new_clone(EIdent(sp, head_segs[0])), head)
                } else {
                    EIdent(sp, head)
                }
                return infer_calls_expr(tc, env, ECall(sp, new_clone(callee), [], cargs), expected)
            }
        }
        let effective_te = pick_record_type(tc, te, expected)
        var nf: Vec<ast.RecordFieldLit> = []
        for f in fields {
            let field_hint = record_field_hint(tc, effective_te, f.name)
            vec.push(&nf, ast.RecordFieldLit { name: f.name, value: infer_calls_expr(tc, env, f.value, field_hint) })
            // f.value is an Expr value (RecordFieldLit holds it by value), so no deref.
        }
        // Rebuild the TypeExpr with the inferred type arguments so the
        // emit walk picks up the right struct instantiation. Start from
        // effective_te so an enclosing annotation like `let b: Box<T>`
        // wins over re-inference from the field literals.
        let inferred_te = inferred_record_te(tc, env, sp, effective_te, nf)
        ERecord(sp, inferred_te, nf)
    }
    | EClosure(sp, cps, ret, body) -> {
        // Bind the closure parameters while rewriting the body so a synth
        // inside the rewrite (operator-overload lowering) can resolve
        // them. Restore the env afterwards.
        let saved_len = len(env.bindings)
        for cp in cps { env_define(env, cp.name, resolve_type(tc, cp.ty)) }
        let new_body = infer_calls_expr(tc, env, *body, resolve_type(tc, ret))
        env_truncate(env, saved_len)
        EClosure(sp, cps, ret, new_clone(new_body))
    }
    | EBlock(sp, stmts, tail) -> {
        var ns: Vec<ast.Stmt> = []
        for s in stmts {
            // Desugar `let (a, b, ...) = expr` here so downstream
            // phases only see the underlying SLet sequence.
            match s {
            | SLetTuple(ssp, names, value, is_var) -> {
                let new_value = infer_calls_expr(tc, env, value, ty.ty_error_())
                let tmp = `_qoz_tup_{len(ns)}`
                let value_ty = synth(tc, env, new_value)
                env_define(env, tmp, value_ty)
                vec.push(&ns, SLet(ssp, tmp, TEUnit(ssp), new_value))
                var bi: i64 = 0
                for bname in names {
                    if !strings.eq_raw(bname, "_") {
                        let field = `_{bi}`
                        let fld: ast.Expr = EField(ssp, new_clone(EIdent(ssp, tmp)), field)
                        let bty = synth(tc, env, fld)
                        env_define(env, bname, bty)
                        // `var (a, b) = ...` produces mutable bindings;
                        // `let (a, b) = ...` produces immutable ones.
                        if is_var {
                            vec.push(&ns, SVar(ssp, bname, TEUnit(ssp), fld))
                        } else {
                            vec.push(&ns, SLet(ssp, bname, TEUnit(ssp), fld))
                        }
                    }
                    bi += 1
                }
            }
            | _ -> vec.push(&ns, infer_calls_stmt(tc, env, s))
            }
        }
        EBlock(sp, ns, new_clone(infer_calls_expr(tc, env, *tail, expected)))
    }
    | EIf(sp, c, t, f) -> EIf(sp, new_clone(infer_calls_expr(tc, env, *c, ty.ty_error_())), new_clone(infer_calls_expr(tc, env, *t, expected)), new_clone(infer_calls_expr(tc, env, *f, expected)))
    | EMatch(sp, scrut, arms) -> {
        let new_scrut = infer_calls_expr(tc, env, *scrut, ty.ty_error_())
        // Synth on the rewritten scrutinee so a bare builtin call
        // (`match pop(&xs) { ... }`) has its container-dispatch
        // applied before its type is read by pattern binding.
        let scrut_ty = synth(tc, env, new_scrut)
        var na: Vec<ast.MatchArm> = []
        for a in arms {
            let saved_len = len(env.bindings)
            // Reorder a named-payload pattern to positional before
            // binding, so the binder and emit only see positional.
            let dpat = desugar_pattern(tc, a.pat)
            bind_pattern(tc, env, dpat, scrut_ty)
            vec.push(&na, ast.MatchArm { pat: dpat, body: infer_calls_expr(tc, env, a.body, expected), has_guard: a.has_guard, guard: a.guard })
            env_truncate(env, saved_len)
        }
        EMatch(sp, new_clone(new_scrut), na)
    }
    | EWhile(sp, c, b) -> EWhile(sp, new_clone(infer_calls_expr(tc, env, *c, ty.ty_error_())), new_clone(infer_calls_expr(tc, env, *b, ty.ty_error_())))
    | EFor(sp, b1, b2, it, body) -> {
        let new_it = infer_calls_expr(tc, env, *it, ty.ty_error_())
        let it_ty = synth(tc, env, *it)
        let saved_len = len(env.bindings)
        bind_for_loop(env, b1, b2, it_ty)
        let new_body = infer_calls_expr(tc, env, *body, ty.ty_error_())
        env_truncate(env, saved_len)
        EFor(sp, b1, b2, new_clone(new_it), new_clone(new_body))
    }
    | EReturn(sp, v)          -> EReturn(sp, new_clone(infer_calls_expr(tc, env, *v, expected)))
    | EDefer(sp, v)           -> EDefer(sp, new_clone(infer_calls_expr(tc, env, *v, ty.ty_error_())))
    | ESizeOf(_, _)           -> e
    | EArrayLit(sp, elems, _)    -> {
        var elem_expected = ty.ty_error_()
        if let TyRecord(_, nm, args) = expected {
            if strings.eq_raw(nm, "Vec") && len(args) >= 1 { elem_expected = args[0] }
        }
        var ne: Vec<ast.Expr> = []
        for el in elems { vec.push(&ne, infer_calls_expr(tc, env, el, elem_expected)) }
        // Store the resolved Vec type on the node itself so emit can
        // register the container helpers and resolve the element type,
        // including for an empty `[]`. Prefer the expected type; with no
        // expected type, synthesise it from the elements.
        var lit_te: ast.TypeExpr = TEUnit(sp)
        if !ty.ty_is_error(elem_expected) {
            lit_te = ty.ty_to_type_expr_at(expected, sp)
        } else {
            let synthed = synth(tc, env, EArrayLit(sp, ne, TEUnit(sp)))
            if !ty.ty_is_error(synthed) { lit_te = ty.ty_to_type_expr_at(synthed, sp) }
        }
        EArrayLit(sp, ne, lit_te)
    }
    | EMapLit(sp, keys, values, _) -> {
        var kexp = ty.ty_error_()
        var vexp = ty.ty_error_()
        var is_map = false
        if let TyRecord(_, nm, args) = expected {
            if strings.eq_raw(nm, "Map") && len(args) >= 2 {
                kexp = args[0]
                vexp = args[1]
                is_map = true
            }
        }
        var nk: Vec<ast.Expr> = []
        for k in keys { vec.push(&nk, infer_calls_expr(tc, env, k, kexp)) }
        var nv: Vec<ast.Expr> = []
        for v in values { vec.push(&nv, infer_calls_expr(tc, env, v, vexp)) }
        // Store the resolved Map type on the node itself so emit can
        // register the container helpers and resolve key/value types,
        // including for an empty `[:]`. Prefer the expected type; with no
        // expected type, synthesise it from the entries.
        var lit_te: ast.TypeExpr = TEUnit(sp)
        if is_map {
            lit_te = ty.ty_to_type_expr_at(expected, sp)
        } else {
            let synthed = synth(tc, env, EMapLit(sp, nk, nv, TEUnit(sp)))
            if !ty.ty_is_error(synthed) { lit_te = ty.ty_to_type_expr_at(synthed, sp) }
        }
        EMapLit(sp, nk, nv, lit_te)
    }
    | ENew(sp, inner) -> {
        // `new e` yields `*T`, so the inner expression's expected type is
        // the pointee of the surrounding expected type when known.
        var inner_expected = ty.ty_error_()
        if let TyPtr(it) = expected { inner_expected = *it }
        ENew(sp, new_clone(infer_calls_expr(tc, env, *inner, inner_expected)))
    }
    | ENewType(_, _) -> e
    | ELoadString(_, _, _) -> e
    | EParen(sp, inner) -> EParen(sp, new_clone(infer_calls_expr(tc, env, *inner, expected)))
    }
}

let infer_calls_stmt(tc: *TyContext, env: *Env, s: ast.Stmt): ast.Stmt = {
    match s {
    | SLet(sp, name, te, val) -> {
        let annotated = resolve_type(tc, te)
        let new_val = infer_calls_expr(tc, env, val, annotated)
        let binding_ty = if is_ty_unit_or_error(annotated) { synth(tc, env, new_val) } else { annotated }
        env_define(env, name, binding_ty)
        SLet(sp, name, te, new_val)
    }
    | SVar(sp, name, te, val) -> {
        let annotated = resolve_type(tc, te)
        let new_val = infer_calls_expr(tc, env, val, annotated)
        let binding_ty = if is_ty_unit_or_error(annotated) { synth(tc, env, new_val) } else { annotated }
        env_define(env, name, binding_ty)
        SVar(sp, name, te, new_val)
    }
    | SExpr(sp, x) -> SExpr(sp, infer_calls_expr(tc, env, x, ty.ty_error_()))
    // EBlock catches SLetTuple inline; reaching here means a stray
    // destructure outside a block, which is currently unsupported.
    | SLetTuple(sp, names, val, is_var) -> SLetTuple(sp, names, infer_calls_expr(tc, env, val, ty.ty_error_()), is_var)
    }
}

let pick_record_type(tc: *TyContext, te: ast.TypeExpr, expected: ty.Ty): ast.TypeExpr = {
    match te {
    | TENamed(sp, path, args) -> {
        if len(args) > 0 { return te }
        if len(path) != 1 { return te }
        match expected {
        | TyRecord(_, en, eargs) -> {
            if strings.eq_raw(path[0], en) && len(eargs) > 0 {
                var ta: Vec<ast.TypeExpr> = []
                for a in eargs { vec.push(&ta, ty.ty_to_type_expr_at(a, sp)) }
                return TENamed(sp, path, ta)
            }
            te
        }
        | _ -> te
        }
    }
    | _ -> te
    }
}

let record_field_hint(tc: *TyContext, te: ast.TypeExpr, field_name: string): ty.Ty = {
    match te {
    | TENamed(sp, path, args) -> {
        if len(path) < 1 { return ty.ty_error_() }
        let name = path[len(path) - 1]
        let home = if len(path) == 2 {
            path[0]
        } else {
            pick_type_home(tc, name, home_of_file(tc, sp.file))
        }
        match find_struct(tc, home, name) {
        | None    -> ty.ty_error_()
        | Some(d) -> {
            match d {
            | DStruct(_, _, params, fields) -> {
                let saved = tc.type_params
                set_type_params(tc, params)
                var arg_tys: Vec<ty.Ty> = []
                for a in args { vec.push(&arg_tys, resolve_type(tc, a)) }
                var result: ty.Ty = ty.ty_error_()
                for f in fields {
                    if strings.eq_raw(f.name, field_name) {
                        let raw = resolve_type(tc, f.ty)
                        result = if len(arg_tys) == len(params) && len(params) > 0 {
                            apply_subst(raw, params, arg_tys)
                        } else {
                            raw
                        }
                    }
                }
                tc.type_params = saved
                result
            }
            | _ -> ty.ty_error_()
            }
        }
        }
    }
    | _ -> ty.ty_error_()
    }
}

let collect_arg_hints(tc: *TyContext, callee: ast.Expr, n: i64, out: *Vec<ty.Ty>) = {
    let name = resolve_callee_fn(tc, callee)
    if !strings.eq_raw(name, "") {
        match map.get(&tc.fns, name) {
        | Some(d) -> { fill_fn_param_hints(tc, d, out); return }
        | None    -> { }
        }
        match map.get(&tc.externs, name) {
        | Some(d) -> { fill_fn_param_hints(tc, d, out); return }
        | None    -> { }
        }
    }
    // Variant ctor hints are added only when the enum has no tparams.
    // A generic-enum hint would carry TyVar. Threading those through
    // the inference pipeline has destabilised the conservative GC.
    match callee {
    | EIdent(_, vname) -> {
        match map.get(&tc.variant_of, vname) {
        | Some(enum_name) -> {
            match find_enum_short(tc, enum_name) {
            | Some(d) -> {
                match d {
                | DEnum(_, _, tparams, _) -> {
                    if len(tparams) == 0 { fill_variant_pos_hints(tc, d, vname, out) }
                }
                | _ -> { }
                }
            }
            | None    -> { }
            }
        }
        | None -> { }
        }
    }
    | _ -> { }
    }
}


let fill_fn_param_hints(tc: *TyContext, d: ast.Decl, out: *Vec<ty.Ty>) = {
    match d {
    | DFn(_, _, tparams, params, _, _, _) -> {
        let saved = tc.type_params
        set_type_params(tc, tparams)
        for pp in params {
            vec.push(out, resolve_type(tc, pp.ty))
        }
        tc.type_params = saved
    }
    | DExternal(_, _, _, params, _) -> {
        for pp in params {
            vec.push(out, resolve_type(tc, pp.ty))
        }
    }
    | _ -> { }
    }
}

let fill_variant_pos_hints(tc: *TyContext, d: ast.Decl, variant_name: string, out: *Vec<ty.Ty>) = {
    match d {
    | DEnum(_, _, tparams, variants) -> {
        let saved = tc.type_params
        set_type_params(tc, tparams)
        for v in variants {
            if strings.eq_raw(v.name, variant_name) {
                for pt in v.pos {
                    vec.push(out, resolve_type(tc, pt))
                }
            }
        }
        tc.type_params = saved
    }
    | _ -> { }
    }
}

let is_ty_unit_or_error(t: ty.Ty): bool = {
    match t {
    | TyUnit  -> true
    | TyError -> true
    | _       -> false
    }
}

// Pick the enum-home for an unqualified variant call. Returns the
// enum the call should resolve against, or `""` when none of the
// candidates matches the expected type.
//
// The expected type is the bidirectional hint: a let-binding's
// annotation, a function parameter's declared type, or the
// scrutinee type at a match site. When the hint pins exactly one
// of the candidates, that enum wins. When the hint is open or
// unrelated, the call site is ambiguous and the caller reports an
// error with the candidate list.
let pick_variant_home(tc: *TyContext, homes: Vec<string>, expected: ty.Ty, sp: ast.Span): string = {
    // The expected type pins the enum when it is a concrete ADT.
    match expected {
    | TyAdt(_, name, _) -> {
        for h in homes { if strings.eq_raw(h, name) { return h } }
    }
    | _ -> { }
    }
    // Each variant belongs to exactly one enum. When two enums
    // happen to declare the same short variant name, the bare-name
    // lookup loses the enum scope. Recover it by selecting the
    // enum that lives in the same package as the call site.
    let use_site = home_of_file(tc, sp.file)
    for h in homes {
        match map.get(&tc.type_homes, h) {
        | Some(enum_homes) -> {
            for eh in enum_homes {
                if strings.eq_raw(eh, use_site) { return h }
            }
        }
        | None -> { }
        }
    }
    ""
}

// True for any of the bare builtin verbs that target a prelude
// container type. The recogniser is intentionally a closed list. An
// open extension model would defeat the reserved-name property the
// spec promises.
let is_container_builtin(name: string): bool = {
    strings.eq_raw(name, "push")     ||
    strings.eq_raw(name, "pop")      ||
    strings.eq_raw(name, "clear")    ||
    strings.eq_raw(name, "insert")   ||
    strings.eq_raw(name, "contains") ||
    strings.eq_raw(name, "delete")
}

type ContainerInfo = {
    kind: string,         // "Vec", "Map", or "" when not a container
    args: Vec<ty.Ty>,
}

// Look through one layer of `*` to find a container type. The
// receiver-style builtins (push, insert, ...) always pass `&xs`, so
// the actual recv type is a pointer to the container.
let unwrap_container_ty(t: ty.Ty): ContainerInfo = {
    let inner = match t {
    | TyPtr(x) -> *x
    | _        -> t
    }
    match inner {
    | TyRecord(_, name, args) -> {
        if strings.eq_raw(name, "Vec") || strings.eq_raw(name, "Map") {
            return ContainerInfo { kind: name, args: args }
        }
        ContainerInfo { kind: "", args: [] }
    }
    | _ -> ContainerInfo { kind: "", args: [] }
    }
}

// Convert a Ty back into a TypeExpr for use as an explicit type
// argument on the rewritten qualified call. Names that participate
// here are limited to those produced by container dispatch (the
// prelude container element / key / value types), so we only need
// the cases relevant to that path.
// Convert a Ty back into a TypeExpr, restoring the package qualifier

let ty_to_type_expr_at(t: ty.Ty, sp: ast.Span): ast.TypeExpr = {
    match t {
    | TyInt(i) -> {
        let w = if i.width == 8 { "8" }
                else { if i.width == 16 { "16" }
                else { if i.width == 32 { "32" }
                else { "64" } } }
        let n = strings.cat(if i.is_signed { "i" } else { "u" }, w)
        var path: Vec<string> = []
        vec.push(&path, n)
        TENamed(sp, path, [])
    }
    | TyFloat(f) -> {
        let n = if f.width == 32 { "f32" } else { "f64" }
        var path: Vec<string> = []
        vec.push(&path, n)
        TENamed(sp, path, [])
    }
    | TyBool   -> single_te(sp, "bool")
    | TyChar   -> single_te(sp, "char")
    | TyString -> single_te(sp, "string")
    | TyCstring-> single_te(sp, "cstring")
    | TyUnit   -> single_te(sp, "unit")
    | TyNil    -> single_te(sp, "void")
    | TyError  -> single_te(sp, "i64")
    | TyVar(_, n) -> single_te(sp, n)
    | TyPtr(inner) -> TEPtr(sp, new_clone(ty_to_type_expr_at(*inner, sp)))
    | TyAdt(_, n, args) | TyRecord(_, n, args) -> {
        var path: Vec<string> = []
        vec.push(&path, n)
        var te_args: Vec<ast.TypeExpr> = []
        for a in args { vec.push(&te_args, ty_to_type_expr_at(a, sp)) }
        TENamed(sp, path, te_args)
    }
    | TyCEnum(_, n, _) -> single_te(sp, n)
    | TyFn(_, _)  -> single_te(sp, "i64")
    | TyTuple(elems) -> {
        var es: Vec<ast.TypeExpr> = []
        for e in elems { vec.push(&es, ty_to_type_expr_at(e, sp)) }
        TETuple(sp, es)
    }
    }
}

let single_te(sp: ast.Span, name: string): ast.TypeExpr = {
    var path: Vec<string> = []
    vec.push(&path, name)
    TENamed(sp, path, [])
}

// Dispatch a container builtin call to the underlying qualified
// package function. The rewriter returns Some(rewritten_call) on
// success and None when the dispatch cannot be performed (in which
// case rewrite_call falls through and the user gets the standard
// "undefined name" diagnostic).
let rewrite_container_builtin(tc: *TyContext, env: *Env, sp: ast.Span, name: string, type_args: Vec<ast.TypeExpr>, args: Vec<ast.Expr>, expected: ty.Ty): Option<ast.Expr> = {
    if len(args) == 0 {
        record_error(tc, sp, `'{name}' needs a container as its first argument`)
        return Some(ECall(sp, new_clone(EIdent(sp, name)), type_args, args))
    }
    let recv_ty = synth(tc, env, args[0])
    let info = unwrap_container_ty(recv_ty)
    if strings.eq_raw(info.kind, "") {
        record_error(tc, sp, `'{name}' expects a Vec or Map as its first argument; got {ty.ty_show(recv_ty)}`)
        return Some(ECall(sp, new_clone(EIdent(sp, name)), type_args, args))
    }
    let is_vec = strings.eq_raw(info.kind, "Vec")
    let is_map = strings.eq_raw(info.kind, "Map")
    // Verb-by-package dispatch. Verbs that apply to exactly one
    // container produce a clear "wrong container" diagnostic when
    // misapplied rather than a downstream unresolved-function error.
    let target_pkg = match_builtin_pkg(name, is_vec, is_map)
    if strings.eq_raw(target_pkg, "") {
        let needed = if is_vec { "Map" } else { "Vec" }
        let got    = if is_vec { "Vec" } else { "Map" }
        record_error(tc, sp, `'{name}' is a {needed} operation; got {got}`)
        return Some(ECall(sp, new_clone(EIdent(sp, name)), type_args, args))
    }
    let new_callee: ast.Expr = EField(sp, new_clone(EIdent(sp, target_pkg)), name)
    var new_ta: Vec<ast.TypeExpr> = []
    for a in info.args { vec.push(&new_ta, ty_to_type_expr_at(a, sp)) }
    Some(rewrite_call(tc, env, sp, new_callee, new_ta, args, expected))
}

let match_builtin_pkg(name: string, is_vec: bool, is_map: bool): string = {
    if strings.eq_raw(name, "push") || strings.eq_raw(name, "pop") {
        if is_vec { return "vec" } else { return "" }
    }
    if strings.eq_raw(name, "insert") || strings.eq_raw(name, "contains") || strings.eq_raw(name, "delete") {
        if is_map { return "map" } else { return "" }
    }
    if strings.eq_raw(name, "clear") {
        if is_vec { return "vec" }
        if is_map { return "map" }
        return ""
    }
    ""
}

let rewrite_call(tc: *TyContext, env: *Env, sp: ast.Span, callee: ast.Expr, type_args: Vec<ast.TypeExpr>, args: Vec<ast.Expr>, expected: ty.Ty): ast.Expr = {
    // The interpolation desugar emits every slot as a call to
    // __qoz_interp_push_str. Once the slot's value type is known,
    // retarget the call to the matching typed push intrinsic so the
    // runtime gets the value in its native representation rather than
    // going through a string conversion at the call site.
    let bare_name = match callee {
    | EIdent(_, n) -> n
    | _            -> ""
    }
    // Variant-name ambiguity. When two or more enums declare the same
    // variant name, an unqualified call must be pinned by the
    // expected type. Otherwise the call site is reported with the
    // candidate list so the user can switch to Enum.Variant(...).
    if !strings.eq_raw(bare_name, "") {
        match map.get(&tc.variant_homes, bare_name) {
        | Some(homes) -> {
            if len(homes) > 1 {
                let chosen = pick_variant_home(tc, homes, expected, sp)
                if strings.eq_raw(chosen, "") {
                    var msg = `variant '{bare_name}' is declared in `
                    var i: i64 = 0
                    for h in homes {
                        if i > 0 { msg = strings.cat(msg, ", ") }
                        msg = strings.cat(msg, h)
                        i += 1
                    }
                    msg = strings.cat(msg, `; qualify the call as Enum.{bare_name}(...) or add a type annotation`)
                    record_error(tc, sp, msg)
                } else {
                    let qualified: ast.Expr = EField(sp, new_clone(EIdent(sp, chosen)), bare_name)
                    return rewrite_call(tc, env, sp, qualified, type_args, args, expected)
                }
            }
        }
        | None -> { }
        }
    }
    // Container builtins. A small fixed set of bare names dispatches to
    // the Vec / Map runtime helpers based on the receiver's type so the
    // user surface reads uniformly with the prelude container types.
    // Vec-only verbs (push, pop) and Map-only verbs (insert, contains,
    // delete) pin the package by argument-type inspection. Make and
    // clear are polymorphic between Vec and Map and dispatch off the
    // receiver type or the expected return type.
    if is_container_builtin(bare_name) {
        let rewritten = rewrite_container_builtin(tc, env, sp, bare_name, type_args, args, expected)
        match rewritten {
        | Some(e) -> return e
        | None    -> { }
        }
    }
    if strings.eq_raw(bare_name, "__qoz_interp_push_str") && len(args) == 2 {
        // Rewrite the slot expression first so any container-builtin
        // call inside it gets dispatched to the qualified package
        // form before synth runs. synth on a bare `contains(...)`
        // would otherwise fail to resolve and the slot would appear
        // as TyError.
        let rewritten_arg = infer_calls_expr(tc, env, args[1], ty.ty_error_())
        let rewritten_sb  = infer_calls_expr(tc, env, args[0], ty.ty_error_())
        let val_ty = synth(tc, env, rewritten_arg)
        match interp_push_method_for(val_ty) {
        | Some(method) -> {
            if !strings.eq_raw(method, "__qoz_interp_push_str") {
                let new_callee2: ast.Expr = EIdent(sp, method)
                var new_args: Vec<ast.Expr> = []
                vec.push(&new_args, rewritten_sb)
                vec.push(&new_args, rewritten_arg)
                return ECall(sp, new_clone(new_callee2), type_args, new_args)
            }
            // method == "__qoz_interp_push_str": keep the call but
            // use the already-rewritten args so nested builtins are
            // not lost.
            var new_args: Vec<ast.Expr> = []
            vec.push(&new_args, rewritten_sb)
            vec.push(&new_args, rewritten_arg)
            return ECall(sp, new_clone(callee), type_args, new_args)
        }
        | None -> {
            if can_show_ty(val_ty) {
                let new_callee2: ast.Expr = EIdent(sp, "__qoz_interp_push_any")
                var new_args: Vec<ast.Expr> = []
                vec.push(&new_args, rewritten_sb)
                vec.push(&new_args, rewritten_arg)
                return ECall(sp, new_clone(new_callee2), type_args, new_args)
            }
            record_error(tc, sp, `interpolation slot type {ty.ty_show(val_ty)} cannot be rendered as a string`)
        }
        }
    }
    if is_interp_intrinsic(bare_name) {
        var new_args: Vec<ast.Expr> = []
        for a in args {
            vec.push(&new_args, infer_calls_expr(tc, env, a, ty.ty_error_()))
        }
        return ECall(sp, new_clone(callee), type_args, new_args)
    }
    // strings.sb_append accepts a string. The same retargeting trick as
    // above applies for user code that calls the Strbuf surface
    // directly: an integer or boolean argument routes to the typed
    // appender so the call type-checks without an explicit conversion.
    if is_strings_callee(callee, "sb_append") && len(args) == 2 {
        let val_ty = synth(tc, env, args[1])
        let method = sb_append_method_for(val_ty)
        if !strings.eq_raw(method, "sb_append") {
            let new_callee2: ast.Expr = EField(sp, new_clone(EIdent(sp, "strings")), method)
            var new_args: Vec<ast.Expr> = []
            vec.push(&new_args, infer_calls_expr(tc, env, args[0], ty.ty_error_()))
            vec.push(&new_args, infer_calls_expr(tc, env, args[1], val_ty))
            return ECall(sp, new_clone(new_callee2), type_args, new_args)
        }
    }
    let new_callee = infer_calls_expr(tc, env, callee, ty.ty_error_())
    // Argument expected types come from the callee's parameter list.
    var new_args: Vec<ast.Expr> = []
    var arg_hints: Vec<ty.Ty> = []
    collect_arg_hints(tc, callee, len(args), &arg_hints)
    var ai: i64 = 0
    for a in args {
        let hint = if ai < len(arg_hints) { arg_hints[ai] } else { ty.ty_error_() }
        vec.push(&new_args, infer_calls_expr(tc, env, a, hint))
        ai += 1
    }
    if len(type_args) > 0 {
        return ECall(sp, new_clone(new_callee), type_args, new_args)
    }
    let fn_name: string = resolve_callee_fn(tc, callee)
    if strings.eq_raw(fn_name, "") {
        return ECall(sp, new_clone(new_callee), type_args, new_args)
    }
    match map.get(&tc.fns, fn_name) {
    | Some(d) -> {
        match d {
        | DFn(_, _, tparams, params, ret, _, _) -> {
            if len(tparams) == 0 {
                return ECall(sp, new_clone(new_callee), type_args, new_args)
            }
            var arg_tys: Vec<ty.Ty> = []
            for a in args { vec.push(&arg_tys, synth(tc, env, a)) }
            let saved_c = tc.type_params
            set_type_params(tc, tparams)
            var param_tys: Vec<ty.Ty> = []
            for pp in params { vec.push(&param_tys, resolve_type(tc, pp.ty)) }
            let ret_pattern = resolve_type(tc, ret)
            tc.type_params = saved_c
            var subst_env: Map<string, ty.Ty> = [:]
            var i: i64 = 0
            var ok = true
            while i < len(arg_tys) && i < len(param_tys) {
                if !unify(param_tys[i], arg_tys[i], &subst_env) { ok = false }
                i += 1
            }
            if !is_ty_error(expected) {
                let _ = unify(ret_pattern, expected, &subst_env)
            }
            if !ok {
                record_error(tc, sp, `could not unify argument types with generic parameters of '{fn_name}'`)
                return ECall(sp, new_clone(new_callee), type_args, new_args)
            }
            var inferred: Vec<ast.TypeExpr> = []
            for tp in tparams {
                match map.get(&subst_env, tp) {
                | Some(t) -> vec.push(&inferred, ty.ty_to_type_expr_at(t, sp))
                | None    -> {
                    record_error(tc, sp, `type parameter '{tp}' of '{fn_name}' is not constrained; add an explicit annotation`)
                    vec.push(&inferred, ty.ty_to_type_expr_at(ty.ty_error_(), sp))
                }
                }
            }
            ECall(sp, new_clone(new_callee), inferred, new_args)
        }
        | _ -> ECall(sp, new_clone(new_callee), type_args, new_args)
        }
    }
    | None -> ECall(sp, new_clone(new_callee), type_args, new_args)
    }
}

// True when `t` is `Result<T, E>` and would be silently dropped if
// the surrounding expression is used as a statement.
let is_unhandled_result(t: ty.Ty): bool = {
    match t {
    | TyAdt(_, name, _) -> strings.eq_raw(name, "Result")
    | _ -> false
    }
}

// True when `e` contains an `EReturn` anywhere in its sub-tree.
// Used by check_fn_bodies to suppress the body-tail-type check when
// the user controls exit paths explicitly. The walk goes through all
// sub-expressions. Statement-level returns inside blocks are caught
// via the EBlock arm.
let expr_has_return(e: ast.Expr): bool = {
    match e {
    | EReturn(_, _) -> true
    | EUnary(_, _, rhs) -> expr_has_return(*rhs)
    | EBinary(_, _, l, r) -> expr_has_return(*l) || expr_has_return(*r)
    | EAssign(_, _, l, r) -> expr_has_return(*l) || expr_has_return(*r)
    | ECall(_, callee, _, args) -> {
        if expr_has_return(*callee) { return true }
        for a in args { if expr_has_return(a) { return true } }
        false
    }
    | EField(_, base, _) -> expr_has_return(*base)
    | EIndex(_, base, idx) -> expr_has_return(*base) || expr_has_return(*idx)
    | ECast(_, value, _) -> expr_has_return(*value)
    | ETry(_, v) -> expr_has_return(*v)
    | ETuple(_, elems) -> { for el in elems { if expr_has_return(el) { return true } } false }
    | ERecord(_, _, fields) -> { for f in fields { if expr_has_return(f.value) { return true } } false }
    | EClosure(_, _, _, _) -> false
    | EBlock(_, stmts, tail) -> {
        for s in stmts { if stmt_has_return(s) { return true } }
        expr_has_return(*tail)
    }
    | EIf(_, c, t, f) -> expr_has_return(*c) || expr_has_return(*t) || expr_has_return(*f)
    | EMatch(_, scrut, arms) -> {
        if expr_has_return(*scrut) { return true }
        for a in arms { if expr_has_return(a.body) { return true } }
        false
    }
    | EWhile(_, c, b) -> expr_has_return(*c) || expr_has_return(*b)
    | EFor(_, _, _, it, b) -> expr_has_return(*it) || expr_has_return(*b)
    | EDefer(_, b) -> expr_has_return(*b)
    | EArrayLit(_, elems, _) -> { for el in elems { if expr_has_return(el) { return true } } false }
    | EMapLit(_, keys, values, _) -> {
        for k in keys { if expr_has_return(k) { return true } }
        for v in values { if expr_has_return(v) { return true } }
        false
    }
    | ENew(_, inner) -> expr_has_return(*inner)
    | _ -> false
    }
}

let stmt_has_return(s: ast.Stmt): bool = {
    match s {
    | SLet(_, _, _, v) | SVar(_, _, _, v) | SExpr(_, v) | SLetTuple(_, _, v, _) -> expr_has_return(v)
    }
}

let check_fn_bodies(tc: *TyContext, f: ast.File) = {
    for d in f.decls {
        match d {
        | DFn(sp, name, tparams, params, ret, body, _) -> {
            set_type_params(tc, tparams)
            var env = env_make()
            for pp in params {
                env_define(&env, pp.name, resolve_type(tc, pp.ty))
            }
            let declared_ret = resolve_type(tc, ret)
            let saved_ret = tc.current_ret_ty
            tc.current_ret_ty = declared_ret
            let body_ty = synth(tc, &env, body)
            tc.current_ret_ty = saved_ret
            // Body-tail-type check. Only enforced when the body has
            // no explicit `return` anywhere. The presence of `return`
            // indicates the user controls exit paths. The tail may
            // be unreachable. Unit-returning functions also skip
            // because a statement-shaped tail produces unit by
            // definition.
            let skip =
                ty.ty_is_error(body_ty) ||
                ty.ty_is_error(declared_ret) ||
                ty.ty_is_unit(declared_ret) ||
                expr_has_return(body)
            if !skip {
                if !ty.ty_assignable(declared_ret, body_ty) {
                    record_error(tc, sp, `function body produces {ty.ty_show(body_ty)} but declared return type is {ty.ty_show(declared_ret)}`)
                }
            }
            clear_type_params(tc)
        }
        | DConst(_, _, _, val) -> {
            var env = env_make()
            let _ = synth(tc, &env, val)
        }
        // The remaining decl kinds carry no function body. Imports
        // and links are pure metadata, struct/enum/c-enum/alias and
        // externals declare types or signatures already validated
        // upstream, and DCompileIf was lowered before check ran.
        | DImport(_, _, _)
        | DStruct(_, _, _, _)
        | DEnum(_, _, _, _)
        | DCEnum(_, _, _, _)
        | DTypeAlias(_, _, _, _)
        | DExternal(_, _, _, _, _)
        | DLink(_, _, _)
        | DCompileIf(_, _, _)          -> { }
        }
    }
}

// --- Symbol kind sanity check ---

let set_type_params(tc: *TyContext, params: Vec<string>) = {
    tc.type_params = [:]
    for p in params { tc.type_params[p] = true }
}

let clear_type_params(tc: *TyContext) = {
    tc.type_params = [:]
}

let validate_signatures(tc: *TyContext, f: ast.File) = {
    for d in f.decls {
        match d {
        | DFn(_, name, tparams, params, ret, _, attr) -> {
            set_type_params(tc, tparams)
            var p_tys: Vec<ty.Ty> = []
            for pp in params {
                vec.push(&p_tys, resolve_type(tc, pp.ty))
            }
            let r_ty = resolve_type(tc, ret)
            map.set(&tc.fn_param_tys, name, p_tys)
            map.set(&tc.fn_ret_ty, name, r_ty)
            clear_type_params(tc)
            // Register an @operator overload by its symbol and the head
            // name of its first parameter type, mirroring emit.
            if !strings.eq_raw(attr, "") {
                if len(params) > 0 {
                    let tn = operator_first_param_type_name(params[0].ty)
                    if !strings.eq_raw(tn, "") {
                        map.set(&tc.op_overloads, strings.cat(strings.cat(attr, "::"), tn), name)
                    }
                }
            }
        }
        | DExternal(_, name, _, params, ret) -> {
            var p_tys: Vec<ty.Ty> = []
            for pp in params {
                vec.push(&p_tys, resolve_type(tc, pp.ty))
            }
            let r_ty = resolve_type(tc, ret)
            map.set(&tc.fn_param_tys, name, p_tys)
            map.set(&tc.fn_ret_ty, name, r_ty)
        }
        | DStruct(_, name, tparams, fields) -> {
            set_type_params(tc, tparams)
            for fld in fields {
                let _ = resolve_type(tc, fld.ty)
            }
            clear_type_params(tc)
        }
        | DEnum(_, name, tparams, variants) -> {
            set_type_params(tc, tparams)
            for v in variants {
                for pp in v.pos {
                    let _ = resolve_type(tc, pp)
                }
                for nf in v.named {
                    let _ = resolve_type(tc, nf.ty)
                }
            }
            clear_type_params(tc)
        }
        | DTypeAlias(_, name, tparams, target) -> {
            set_type_params(tc, tparams)
            let _ = resolve_type(tc, target)
            clear_type_params(tc)
        }
        | DCEnum(sp, _, underlying, _) -> {
            let ut = resolve_type(tc, underlying)
            if !ty.ty_is_int(ut) {
                record_error(tc, sp, "C-style enum underlying type must be an integer primitive")
            }
        }
        | DConst(_, _, ty, _) -> {
            let _ = resolve_type(tc, ty)
        }
        // Imports and links contribute no type signature. DCompileIf
        // was expanded during load and never reaches this pass.
        | DImport(_, _, _)
        | DLink(_, _, _)
        | DCompileIf(_, _, _)          -> { }
        }
    }
    check_value_recursion(tc, f)
}

// A value type cannot contain itself: the inline C struct would be
// infinite. Recursion must pass through a pointer (`*T`), a Vec, or a
// Map, all of which hold their contents behind a heap indirection.
let check_value_recursion(tc: *TyContext, f: ast.File) = {
    let recs = recur.value_recursive_adts(f)
    for d in f.decls {
        match d {
        | DEnum(sp, name, _, _) -> {
            if map.contains(&recs, name) {
                record_error(tc, sp, `recursive type '{name}' contains itself by value. Break the cycle with a pointer field such as '*{name}', or with a Vec or Map`)
            }
        }
        | DStruct(sp, name, _, _) -> {
            if map.contains(&recs, name) {
                record_error(tc, sp, `recursive type '{name}' contains itself by value. Break the cycle with a pointer field such as '*{name}', or with a Vec or Map`)
            }
        }
        // Only enums and structs hold by-value payloads that can recur.
        | _ -> { }
        }
    }
}
