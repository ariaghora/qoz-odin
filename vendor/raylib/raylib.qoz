// Qoz bindings for raylib 5.5.
//
// The C side of raylib lives next to this file as `libraylib.a` and
// `raylib.h`. The link directives below pull in the static library
// and the macOS system frameworks raylib's static build depends on.
// Importing this package is enough. User programs do not need to
// repeat the link directives at their entry point.
//
// Covers the parts of raylib that map cleanly to Qoz: window and
// drawing, input, collision, Camera2D / Camera3D, textures and
// images, fonts, render targets, shaders, audio, and the 3D
// drawing primitives. Mesh and Model bindings are not included
// yet because their C structs carry fixed-size float arrays that
// the Qoz field syntax cannot mirror without a manual layout
// shim.

#link_path("vendor/raylib")
#link_library("raylib")

#if target_os == "darwin" {
    #link_framework("CoreVideo")
    #link_framework("IOKit")
    #link_framework("Cocoa")
    #link_framework("OpenGL")
} #elif target_os == "linux" {
    #link_library("GL")
    #link_library("m")
    #link_library("pthread")
    #link_library("dl")
    #link_library("rt")
    #link_library("X11")
} #elif target_os == "windows" {
    #link_library("opengl32")
    #link_library("gdi32")
    #link_library("winmm")
}

// --- Types ----------------------------------------------------------

/// 2D point or vector with single-precision components.
type Vector2 = {
    x: f32,
    y: f32,
}

/// 3D point or vector with single-precision components.
type Vector3 = {
    x: f32,
    y: f32,
    z: f32,
}

/// 4-component vector. Used for colours in floating-point form,
/// quaternions, and shader uniforms.
type Vector4 = {
    x: f32,
    y: f32,
    z: f32,
    w: f32,
}

/// Axis-aligned rectangle in screen space.
type Rectangle = {
    x:      f32,
    y:      f32,
    width:  f32,
    height: f32,
}

/// RGBA colour, one byte per channel.
type Color = {
    r: u8,
    g: u8,
    b: u8,
    a: u8,
}

/// 2D camera with offset, target, rotation, and zoom. Use with
/// `begin_mode_2d` / `end_mode_2d` to apply a transform to all
/// drawing in that scope.
type Camera2D = {
    offset:   Vector2,
    target:   Vector2,
    rotation: f32,
    zoom:     f32,
}

/// 3D camera with eye position, focus target, up axis, vertical
/// field of view in degrees, and projection mode (perspective or
/// orthographic). Use with `begin_mode_3d` / `end_mode_3d`.
type Camera3D = {
    position:   Vector3,
    target:     Vector3,
    up:         Vector3,
    fovy:       f32,
    projection: i32,
}

/// 4x4 column-major matrix laid out as 16 floats. The unusual
/// field order matches raylib's: m0,m4,m8,m12 form the first row,
/// then m1,m5,m9,m13, then m2,m6,m10,m14, then m3,m7,m11,m15.
type Matrix = {
    m0:  f32, m4:  f32, m8:  f32, m12: f32,
    m1:  f32, m5:  f32, m9:  f32, m13: f32,
    m2:  f32, m6:  f32, m10: f32, m14: f32,
    m3:  f32, m7:  f32, m11: f32, m15: f32,
}

/// GPU texture handle plus dimensions and pixel format. Construct
/// one with `load_texture` or `load_texture_from_image`. Texture2D
/// is an alias of this type in C; Qoz mirrors raylib's typedef.
type Texture = {
    id:      u32,
    width:   i32,
    height:  i32,
    mipmaps: i32,
    format:  i32,
}

/// Same memory layout as `Texture`. Re-declared for clarity at
/// call sites that want the 2D-specific name.
type Texture2D = {
    id:      u32,
    width:   i32,
    height:  i32,
    mipmaps: i32,
    format:  i32,
}

/// CPU-side pixel buffer with width, height, mipmap count, and
/// pixel format identifier. Use `load_image` to read one from
/// disk or the `gen_image_*` helpers to construct one
/// procedurally. Convert to a `Texture` via `load_texture_from_image`.
type Image = {
    data:    *void,
    width:   i32,
    height:  i32,
    mipmaps: i32,
    format:  i32,
}

/// Off-screen render target. The `texture` field is the color
/// buffer the rest of the program samples from; `depth` is the
/// depth buffer raylib attaches automatically.
type RenderTexture = {
    id:      u32,
    texture: Texture,
    depth:   Texture,
}

type RenderTexture2D = {
    id:      u32,
    texture: Texture,
    depth:   Texture,
}

/// Per-glyph layout info baked into a font atlas. `image` is the
/// glyph's pixel data. Most user code accesses these via a `Font`
/// rather than building them directly.
type GlyphInfo = {
    value:    i32,
    offset_x: i32,
    offset_y: i32,
    advance_x: i32,
    image:    Image,
}

/// Bitmap font atlas, glyph rectangles, and per-glyph layout
/// info. `base_size` is the font's design size in pixels;
/// `glyph_count` is the size of the `recs` and `glyphs` arrays.
type Font = {
    base_size:     i32,
    glyph_count:   i32,
    glyph_padding: i32,
    texture:       Texture2D,
    recs:          *Rectangle,
    glyphs:        *GlyphInfo,
}

/// Compiled GPU shader plus a pointer to its uniform location
/// table (one i32 per known engine-defined location slot).
type Shader = {
    id:   u32,
    locs: *i32,
}

/// Streaming audio handle. `buffer` and `processor` are opaque
/// engine-internal pointers and should be left as raylib returns
/// them.
type AudioStream = {
    buffer:      *void,
    processor:   *void,
    sample_rate: u32,
    sample_size: u32,
    channels:    u32,
}

/// Decoded audio data sitting in RAM. The `data` pointer holds
/// `frame_count * channels * (sample_size / 8)` bytes.
type Wave = {
    frame_count: u32,
    sample_rate: u32,
    sample_size: u32,
    channels:    u32,
    data:        *void,
}

/// Loaded sound effect backed by an AudioStream. Pass to
/// `play_sound`, `stop_sound`, and so on.
type Sound = {
    stream:      AudioStream,
    frame_count: u32,
}

/// Streaming music handle (mp3, ogg, flac, xm, mod). Call
/// `update_music_stream` every frame to keep the buffer fed.
type Music = {
    stream:      AudioStream,
    frame_count: u32,
    looping:     bool,
    ctx_type:    i32,
    ctx_data:    *void,
}

// --- Named colours --------------------------------------------------

let LIGHTGRAY  = Color { r: 200, g: 200, b: 200, a: 255 }
let GRAY       = Color { r: 130, g: 130, b: 130, a: 255 }
let DARKGRAY   = Color { r: 80,  g: 80,  b: 80,  a: 255 }
let YELLOW     = Color { r: 253, g: 249, b: 0,   a: 255 }
let GOLD       = Color { r: 255, g: 203, b: 0,   a: 255 }
let ORANGE     = Color { r: 255, g: 161, b: 0,   a: 255 }
let PINK       = Color { r: 255, g: 109, b: 194, a: 255 }
let RED        = Color { r: 230, g: 41,  b: 55,  a: 255 }
let MAROON     = Color { r: 190, g: 33,  b: 55,  a: 255 }
let GREEN      = Color { r: 0,   g: 228, b: 48,  a: 255 }
let LIME       = Color { r: 0,   g: 158, b: 47,  a: 255 }
let DARKGREEN  = Color { r: 0,   g: 117, b: 44,  a: 255 }
let SKYBLUE    = Color { r: 102, g: 191, b: 255, a: 255 }
let BLUE       = Color { r: 0,   g: 121, b: 241, a: 255 }
let DARKBLUE   = Color { r: 0,   g: 82,  b: 172, a: 255 }
let PURPLE     = Color { r: 200, g: 122, b: 255, a: 255 }
let VIOLET     = Color { r: 135, g: 60,  b: 190, a: 255 }
let DARKPURPLE = Color { r: 112, g: 31,  b: 126, a: 255 }
let BEIGE      = Color { r: 211, g: 176, b: 131, a: 255 }
let BROWN      = Color { r: 127, g: 106, b: 79,  a: 255 }
let DARKBROWN  = Color { r: 76,  g: 63,  b: 47,  a: 255 }
let WHITE      = Color { r: 255, g: 255, b: 255, a: 255 }
let BLACK      = Color { r: 0,   g: 0,   b: 0,   a: 255 }
let BLANK      = Color { r: 0,   g: 0,   b: 0,   a: 0   }
let MAGENTA    = Color { r: 255, g: 0,   b: 255, a: 255 }
let RAYWHITE   = Color { r: 245, g: 245, b: 245, a: 255 }

// --- Window ---------------------------------------------------------

/// Initialise the window and OpenGL context.
@link_name("InitWindow")
external let init_window(width: i32, height: i32, title: cstring)

/// Close the window and free its OpenGL context.
@link_name("CloseWindow")
external let close_window()

/// True when the user clicks the close button or presses Escape.
@link_name("WindowShouldClose")
external let window_should_close(): bool

/// True when the window has been initialised successfully.
@link_name("IsWindowReady")
external let is_window_ready(): bool

@link_name("IsWindowFullscreen")
external let is_window_fullscreen(): bool

@link_name("IsWindowMinimized")
external let is_window_minimized(): bool

@link_name("IsWindowMaximized")
external let is_window_maximized(): bool

@link_name("IsWindowFocused")
external let is_window_focused(): bool

@link_name("IsWindowResized")
external let is_window_resized(): bool

/// Toggle between fullscreen and windowed. Window content is
/// rescaled to fit the new mode.
@link_name("ToggleFullscreen")
external let toggle_fullscreen()

@link_name("MaximizeWindow")
external let maximize_window()

@link_name("MinimizeWindow")
external let minimize_window()

@link_name("RestoreWindow")
external let restore_window()

@link_name("SetWindowTitle")
external let set_window_title(title: cstring)

@link_name("SetWindowPosition")
external let set_window_position(x: i32, y: i32)

@link_name("SetWindowSize")
external let set_window_size(width: i32, height: i32)

@link_name("GetScreenWidth")
external let get_screen_width(): i32

@link_name("GetScreenHeight")
external let get_screen_height(): i32

@link_name("GetRenderWidth")
external let get_render_width(): i32

@link_name("GetRenderHeight")
external let get_render_height(): i32

